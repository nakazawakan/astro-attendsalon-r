---
/**
 * ヒーロー右ビジュアル（画像差し替え可）。
 * トップページ既定は両手でハートを支える水彩イラスト。
 * メッシュ SVG 実装を戻す場合は Git 履歴の本ファイルを参照。
 */
interface Props {
  src?: string;
  alt?: string;
  width?: number;
  height?: number;
}

const {
  src = '/images/hero-emotional-ripple-watercolor-heart.png',
  alt = '',
  width = 800,
  height = 738,
} = Astro.props;
---
<div class="c-hero-emotional-ripple">
  <img
    src={src}
    alt={alt}
    class="c-hero-emotional-ripple__img"
    width={width}
    height={height}
    decoding="async"
    loading="eager"
  />
</div>

<style>
  .c-hero-emotional-ripple {
    margin-left: auto;
    margin-right: auto;
    max-width: 100%;
    aspect-ratio: 800 / 738;
    min-height: 180px;
  }

  .c-hero-emotional-ripple__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: center;
  }
</style>
