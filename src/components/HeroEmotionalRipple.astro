---
/**
 * 仮プレースホルダ（ヒーロー右ビジュアル差し替え前）。
 * メッシュ SVG 実装を戻す場合は Git 履歴の本ファイルを参照。
 */
import NoImagePlaceholder from './NoImagePlaceholder.astro';
---
<div class="c-hero-emotional-ripple">
  <NoImagePlaceholder />
</div>

<style>
  .c-hero-emotional-ripple {
    margin-left: auto;
    margin-right: auto;
    max-width: 100%;
    aspect-ratio: 420 / 360;
    min-height: 180px;
  }

  .c-hero-emotional-ripple :global(.c-no-image-placeholder) {
    height: 100%;
  }
</style>
