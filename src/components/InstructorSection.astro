---
import SectionHeading from './SectionHeading.astro';
import InstructorCardsRow from './InstructorCardsRow.astro';
import type { InstructorCard } from './InstructorCardsRow.astro';

interface Props {
  /** サブページでは見出し・リード・装飾を出さず、カード行のみ（親が pageShell + page を持つ想定） */
  embedded?: boolean;
}
const { embedded = false } = Astro.props;

/** Figma `294:719` 左→右: 佐藤、舘野。佐藤写真ノード `294:732` */
const instructors: InstructorCard[] = [
  {
    nameJa: '佐藤 亮子',
    nameEn: 'Sato Ryoko',
    tags: ['元客室乗務員', '一級キャリアコンサルティング'],
    image: '/images/instructor-sato.png',
    imageAlt: '佐藤亮子のポートレート',
    imgWidth: 933,
    imgHeight: 1400,
    objectPosition: 'object-[50%_13%]',
  },
  {
    nameJa: '舘野 理香',
    nameEn: 'Tateno Rika',
    tags: ['元客室乗務員'],
    image: '/images/instructor-tateno.png',
    imageAlt: '舘野理香のポートレート',
    imgWidth: 920,
    imgHeight: 1380,
    objectPosition: 'object-[50%_19%]',
  },
];
---
<section
  id="instructors"
  class:list={['p-instructor-section', embedded && 'p-instructor-section--embedded']}
  {...(!embedded ? { 'data-reveal': true } : {})}
>
  {
    embedded ? (
      <div class="p-instructor-section__embed">
        <InstructorCardsRow instructors={instructors} />
      </div>
    ) : (
      <div class="l-page-shell">
        <div class="l-page-inner">
          <SectionHeading label="FACILITATOR" title="講師紹介" />
          <div class="p-instructor-section__intro">
            <p>客室乗務員として40年、管理職として10年以上、</p>
            <p>感情を扱う現場に携わってきた実務経験をもとに、</p>
            <p>私たちが、感情に振り回されない働き方、イキイキ働くチーム作りを支援します</p>
          </div>
          <InstructorCardsRow instructors={instructors} />
        </div>
      </div>
    )
  }
</section>

<style>
  .p-instructor-section {
    padding-top: 130px;
    padding-bottom: 80px;
  }

  .p-instructor-section--embedded {
    padding-top: 0;
    padding-bottom: 0;
  }

  .p-instructor-section__embed {
    width: 100%;
    min-width: 0;
  }

  .p-instructor-section__intro {
    margin-bottom: 2.5rem;
    font-family: var(--font-family-base);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-black-03);
  }

  .p-instructor-section__intro p {
    margin: 0;
  }

  @media (min-width: 768px) {
    .p-instructor-section__intro {
      margin-bottom: 3rem;
    }
  }
</style>
