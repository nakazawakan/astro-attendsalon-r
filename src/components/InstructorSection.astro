---
import SectionHeading from './SectionHeading.astro';

interface Props {
  /** サブページでは見出し・リード・装飾を出さず、カード行のみ */
  embedded?: boolean;
}
const { embedded = false } = Astro.props;

/** Figma `294:719` 左→右: 佐藤、舘野。佐藤写真ノード `294:732` */
const instructors = [
  {
    nameJa: '佐藤 亮子',
    nameEn: 'Sato Ryoko',
    tags: ['元客室乗務員', '一級キャリアコンサルティング'],
    image: '/images/instructor-sato.png',
    imageAlt: '佐藤亮子のポートレート',
    imgWidth: 933,
    imgHeight: 1400,
    objectPosition: 'object-[50%_13%]',
  },
  {
    nameJa: '舘野 理香',
    nameEn: 'Tateno Rika',
    tags: ['元客室乗務員'],
    image: '/images/instructor-tateno.png',
    imageAlt: '舘野理香のポートレート',
    imgWidth: 920,
    imgHeight: 1380,
    objectPosition: 'object-[50%_19%]',
  },
];
---
<section
  id="instructors"
  class:list={[embedded ? 'pt-0 pb-0' : 'pt-[130px] pb-[80px]']}
  {...(!embedded ? { 'data-reveal': true } : {})}
>
  <div class="mx-auto w-full min-w-0 max-w-page px-6 md:px-0">
    {
      !embedded && (
        <>
          <SectionHeading label="FACILITATOR" title="講師紹介" />
          <div class="mb-10 md:mb-12 text-base font-zen font-medium text-black-03 leading-[1.5]">
            <p class="mb-0">客室乗務員として40年、管理職として10年以上、</p>
            <p class="mb-0">感情を扱う現場に携わってきた実務経験をもとに、</p>
            <p class="mb-0">私たちが、感情に振り回されない働き方、イキイキ働くチーム作りを支援します</p>
          </div>
        </>
      )
    }

    <div class="flex flex-row flex-nowrap justify-center items-stretch gap-3 md:gap-[39px] w-full min-w-0">
      {instructors.map(({ nameJa, nameEn, tags, image, imageAlt, imgWidth, imgHeight, objectPosition }) => (
        <article class="flex min-w-0 flex-1 basis-0 flex-col gap-[14px] max-w-[480px] md:flex-none md:w-[460px] md:shrink-0">
          <div class="relative w-full h-[200px] md:h-[300px] rounded-lg overflow-hidden bg-surface-01">
            <img
              src={image}
              alt={imageAlt}
              width={imgWidth}
              height={imgHeight}
              class:list={['absolute inset-0 w-full h-full object-cover', objectPosition]}
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="flex flex-col gap-[7px] font-zen font-bold text-black-03">
            <h3 class="text-lg leading-none">{nameJa}</h3>
            <p class="text-sm leading-none text-black-03">{nameEn}</p>
          </div>
          <div class="flex flex-wrap gap-1">
            {tags.map((t) => (
              <span class="inline-flex items-center justify-center bg-white px-2 py-1 rounded-sm text-sm font-zen font-bold text-black-03 whitespace-nowrap shadow-sm border border-black/[0.06]">
                {t}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
