---
import SectionHeading from './SectionHeading.astro';
import InstructorCardsRow from './InstructorCardsRow.astro';
import type { InstructorCard } from './InstructorCardsRow.astro';

interface Props {
  /** サブページでは見出し・リード・装飾を出さず、カード行のみ（親が pageShell + page を持つ想定） */
  embedded?: boolean;
}
const { embedded = false } = Astro.props;

/** Figma `294:719` 左→右: 佐藤、舘野。佐藤写真ノード `294:732` */
const instructors: InstructorCard[] = [
  {
    nameJa: '佐藤 亮子',
    nameEn: 'Sato Ryoko',
    tags: ['元客室乗務員', '一級キャリアコンサルティング'],
    image: '/images/instructor-sato.png',
    imageAlt: '佐藤亮子のポートレート',
    imgWidth: 933,
    imgHeight: 1400,
    objectPosition: 'object-[50%_13%]',
  },
  {
    nameJa: '舘野 理香',
    nameEn: 'Tateno Rika',
    tags: ['元客室乗務員'],
    image: '/images/instructor-tateno.png',
    imageAlt: '舘野理香のポートレート',
    imgWidth: 920,
    imgHeight: 1380,
    objectPosition: 'object-[50%_19%]',
  },
];
---
<section
  id="instructors"
  class:list={[embedded ? 'pt-0 pb-0' : 'pt-[130px] pb-[80px]']}
  {...(!embedded ? { 'data-reveal': true } : {})}
>
  {
    embedded ? (
      <div class="w-full min-w-0">
        <InstructorCardsRow instructors={instructors} />
      </div>
    ) : (
      <div class="mx-auto w-full min-w-0 max-w-pageShell px-6">
        <div class="mx-auto w-full min-w-0 max-w-page">
          <SectionHeading label="FACILITATOR" title="講師紹介" />
          <div class="mb-10 md:mb-12 text-base font-zen font-medium text-black-03 leading-[1.5]">
            <p class="mb-0">客室乗務員として40年、管理職として10年以上、</p>
            <p class="mb-0">感情を扱う現場に携わってきた実務経験をもとに、</p>
            <p class="mb-0">私たちが、感情に振り回されない働き方、イキイキ働くチーム作りを支援します</p>
          </div>
          <InstructorCardsRow instructors={instructors} />
        </div>
      </div>
    )
  }
</section>
