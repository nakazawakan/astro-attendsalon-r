---
import SectionHeading from './SectionHeading.astro';
import InstructorCardsRow from './InstructorCardsRow.astro';
import type { InstructorCard } from './InstructorCardsRow.astro';

interface Props {
  /** サブページでは見出し・リード・装飾を出さず、カード行のみ（親が pageShell + page を持つ想定） */
  embedded?: boolean;
}
const { embedded = false } = Astro.props;

/** Figma `294:719` 左→右: 佐藤、舘野。佐藤写真ノード `294:732` */
const instructors: InstructorCard[] = [
  {
    nameJa: '佐藤 亮子',
    nameEn: 'Sato Ryoko',
    nameLocation: '福岡県出身',
    tags: ['元航空会社客室乗務員（乗務管理職）', 'EAPカウンセラー'],
    qualifications: [
      '1級キャリアコンサルティング技能士',
      '2級キャリアコンサルティング技能士',
      'キャリアコンサルタント',
      '公認心理師',
      '産業カウンセラー',
      '心理相談員',
    ],
    image: '/images/instructor-sato.png',
    imageAlt: '佐藤亮子のポートレート',
    imgWidth: 933,
    imgHeight: 1400,
    objectPosition: 'object-[50%_13%]',
  },
  {
    nameJa: '舘野 理香',
    nameEn: 'Tateno Rika',
    tags: ['元航空会社客室乗務員（乗務管理職）', 'エデュケーションアシスタント', '福岡県出身', 'キャリアコンサルタント'],
    image: '/images/instructor-tateno.png',
    imageAlt: '舘野理香のポートレート',
    imgWidth: 920,
    imgHeight: 1380,
    objectPosition: 'object-[50%_19%]',
  },
];
---
<section
  id="instructors"
  class:list={['p-instructor-section', embedded && 'p-instructor-section--embedded']}
  {...(!embedded ? { 'data-reveal': true } : {})}
>
  {
    embedded ? (
      <div class="p-instructor-section__embed">
        <InstructorCardsRow instructors={instructors} />
      </div>
    ) : (
      <div class="l-page-shell">
        <div class="l-page-inner">
          <SectionHeading
            label="FACILITATOR"
            title="講師紹介"
            bottomMarginStyle="content"
          >
            <div slot="intro">
              <p>私たちは長年にわたり、客室乗務員として感情労働の最前線で働き、<br class="u-only-pc">
              管理職として人財育成や相談対応を担ってきました</p>
              <p>感情を扱う現場で起こる、実情に即した研修をご提案し、感情に振り回されない働き方、イキイキ働くチーム作りを支援します</p>
            </div>
          </SectionHeading>
          <InstructorCardsRow instructors={instructors} />
        </div>
      </div>
    )
  }
</section>

<style>
  .p-instructor-section {
    padding-top: 130px;
    padding-bottom: 80px;
  }

  .p-instructor-section--embedded {
    padding-top: 0;
    padding-bottom: 0;
  }

  .p-instructor-section__embed {
    width: 100%;
    min-width: 0;
  }

</style>
