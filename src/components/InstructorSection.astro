---
import ChevronPillCtaLink from './ChevronPillCtaLink.astro';
import SectionHeading from './SectionHeading.astro';
import InstructorCardsRow from './InstructorCardsRow.astro';
import { instructorsForCards } from '../data/instructors';

interface Props {
  /** サブページでは見出し・リード・装飾を出さず、カード行のみ（親が l-container を持つ想定） */
  embedded?: boolean;
}
const { embedded = false } = Astro.props;

const instructors = instructorsForCards;
---
<section
  id="instructors"
  class:list={['l-section', 'p-instructor-section', embedded && 'p-instructor-section--embedded']}
  {...(!embedded ? { 'data-reveal': true } : {})}
>
  {!embedded && <div class="l-wave l-wave--top l-wave--pattern-gentle-a" aria-hidden="true"></div>}
  {
    embedded ? (
      <div class="p-instructor-section__embed">
        <InstructorCardsRow instructors={instructors} />
      </div>
    ) : (
      <div class="l-container">
          <SectionHeading
            label="FACILITATOR"
            title="講師紹介"
            bottomMarginStyle="content"
          >
            <div slot="intro">
              <p>私たちは長年にわたり、客室乗務員として感情労働の最前線で働き、<br class="u-only-pc">
              管理職として人財育成や相談対応を担ってきました</p>
              <p>感情を扱う現場で起こる、実情に即した研修をご提案し、感情に振り回されない働き方、イキイキ働くチーム作りを支援します</p>
            </div>
          </SectionHeading>
          <InstructorCardsRow instructors={instructors} />
          <p class="p-instructor-section__trainer-more">
            <ChevronPillCtaLink href="/trainer/">講師のプロフィール・写真を見る</ChevronPillCtaLink>
          </p>
      </div>
    )
  }
  {!embedded && <div class="l-wave l-wave--bottom l-wave--pattern-gentle-b" aria-hidden="true"></div>}
</section>

<style>
  .p-instructor-section {
    --wave-height: 40px;
    --wave-mask-gentle-a: url("data:image/svg+xml,%3Csvg viewBox='0 0 912 62' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 12 C110 -4 220 -4 330 12 C420 26 510 26 600 12 C704 -4 808 -4 912 10 L912 62 L0 62 Z' fill='black'/%3E%3C/svg%3E");
    --wave-mask-gentle-b: url("data:image/svg+xml,%3Csvg viewBox='0 0 912 62' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 14 C88 -2 176 -2 264 14 C370 30 476 30 582 14 C692 -2 802 -2 912 12 L912 62 L0 62 Z' fill='black'/%3E%3C/svg%3E");
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding-top: calc(var(--section-padding-block-start, var(--section-padding-block-start-default)) + var(--wave-height));
    padding-bottom: calc(var(--section-padding-block-end, var(--section-padding-block-end-default)) + var(--wave-height));
  }

  .p-instructor-section > .l-container,
  .p-instructor-section__embed {
    position: relative;
    z-index: var(--z-section-content, 3);
  }

  .l-wave {
    position: absolute;
    left: 0;
    right: 0;
    width: 100%;
    height: var(--wave-height);
    z-index: var(--section-wave-z-index, var(--z-section-wave, 1));
    pointer-events: none;
    background: #fff;
  }

  .l-wave--top {
    top: 0;
    transform: translateY(-1px) scaleY(-1);
    transform-origin: 50% 50%;
  }

  .l-wave--bottom {
    bottom: 0;
    transform: translateY(1px);
  }

  .l-wave--pattern-gentle-a {
    mask: var(--wave-mask-gentle-a) center / 100% 100% no-repeat;
    -webkit-mask: var(--wave-mask-gentle-a) center / 100% 100% no-repeat;
  }

  .l-wave--pattern-gentle-b {
    mask: var(--wave-mask-gentle-b) center / 100% 100% no-repeat;
    -webkit-mask: var(--wave-mask-gentle-b) center / 100% 100% no-repeat;
  }

  .p-instructor-section--embedded {
    --section-padding-block-start: 0;
    --section-padding-block-end: 0;
    padding-top: 0;
    padding-bottom: 0;
    overflow: visible;
  }

  .p-instructor-section__embed {
    width: 100%;
    min-width: 0;
  }

  .p-instructor-section__trainer-more {
    margin: 1.75rem 0 0;
    text-align: center;
  }

  @media (--bp-md-up) {
    .p-instructor-section {
      --wave-height: 62px;
    }
  }

</style>
