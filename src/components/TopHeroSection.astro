---
import SectionMarkDecor from './SectionMarkDecor.astro';

const topHeroImage = {
  src: '/images/top-hero-main.png',
  width: 897,
  height: 700,
};

const tags = ['ストレスケア', 'アンガーマネジメント', 'ハラスメント対策'];
const blobs = [
  { char: '感', src: '/images/blob-kan.svg' },
  { char: '情', src: '/images/blob-jo.svg' },
  { char: '労', src: '/images/blob-ro.svg' },
  { char: '働', src: '/images/blob-do.svg' },
];
---
<section class="l-section p-top-hero u-hero-soft-enter">
  <!-- 左上装飾「R」— 白・+45°（旧 -45° の逆回り）。Ruika → Rubik 900。影なし -->
  <SectionMarkDecor anchor="tl" variant="hero" />

  <div class="l-container p-top-hero__inner">
      <!-- 右イラストは absolute（SP/PC 共通）。コピーは z-index で前面 -->
      <div class="p-top-hero__copy">
        <div class="p-top-hero__tags">
          {tags.map((t) => (
            <span class="p-top-hero__tag">
              {t}
            </span>
          ))}
        </div>

        <div class="p-top-hero__blobs">
          {blobs.map(({ char, src }) => (
            <span class="p-top-hero__blob">
              <img src={src} alt="" class="p-top-hero__blob-bg" aria-hidden="true" />
              <span class="p-top-hero__blob-char">
                {char}
              </span>
            </span>
          ))}
          の職場向け
        </div>

        <p class="p-top-hero__catch">
          実践型マネジメント研修
        </p>

        <div class="p-top-hero__lead">
          <p class="p-top-hero__lead-line">アテンドサロンRは、</p>
          <p class="p-top-hero__lead-line">感情労働のフィールドで</p>
          <p class="p-top-hero__lead-line">イキイキ働く組織づくりを支援します</p>
        </div>
      </div>

      <figure class="p-top-hero__visual" aria-hidden="true">
        <img
          class="p-top-hero__img"
          src={topHeroImage.src}
          alt=""
          width={topHeroImage.width}
          height={topHeroImage.height}
          decoding="async"
          loading="eager"
        />
      </figure>
  </div>
</section>

<style>
  .p-top-hero {
    --section-padding-block-start: 7rem;
    --section-padding-block-end: 2.5rem;

    position: relative;
    overflow-x: clip;
    background: var(--color-bg-warm);
    min-height: 440px;
  }

  .p-top-hero__inner {
    position: relative;
  }

  .p-top-hero__copy {
    position: relative;
    z-index: 10;
    width: 100%;
    min-width: 0;
  }

  .p-top-hero__tags {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.2rem;
    margin-bottom: 0.4rem;
  }

  .p-top-hero__tag {
    flex-shrink: 0;
    white-space: nowrap;
    border: 1px solid var(--color-blue-01);
    border-radius: 0.125rem;
    background: #fff;
    padding: 0.125rem 0.25rem;
    font-size: 13px;
    line-height: 1;
    font-weight: 700;
    color: var(--color-blue-01);
  }

  .p-top-hero__blobs {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-end;
    gap: 0;
    margin-bottom: 0.25rem;
    margin-left: -0.125rem;
    font-size: 32px;
    font-weight: 700;
  }

  .p-top-hero__blob {
    position: relative;
    display: inline-flex;
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    margin-right: -0.375rem;
    filter: drop-shadow(0 1px 0 rgba(0, 0, 0, 0.04));
  }

  .p-top-hero__blob:last-child {
    margin-right: 0;
  }

  .p-top-hero__blob-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .p-top-hero__blob-char {
    position: relative;
    transform: translateY(1px);
    font-size: 42px;
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 700;
    color: var(--color-pink-01);
  }

  .p-top-hero__catch {
    margin: 0 0 1rem;
    white-space: nowrap;
    color: var(--color-black-03);
    font-size: 32px;
    line-height: 1.25;
    font-weight: 700;
  }

  .p-top-hero__lead {
    color: var(--color-black-03);
    font-size: 18px;
    line-height: 1.4;
    font-weight: 700;
  }

  .p-top-hero__lead-line {
    margin: 0;
    white-space: nowrap;
  }

  .p-top-hero__visual {
    position: absolute;
    right: 0;
    width: 90%;
    margin: 0;
    z-index: 5;
  }

  .p-top-hero__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: center;
  }

  @media (--bp-sp-down) {
    .p-top-hero__blobs {
      font-size: 24px;
    }

    .p-top-hero__blob {
      width: 55px;
      height: 55px;
    }
    .p-top-hero__inner {
      height: 390px;
    }

    .p-top-hero__catch {
      font-size: 28px;
    }
    .p-top-hero__visual {
      bottom: 0;
    }
  }

  @media (--bp-md-up) {
    .p-top-hero {
      --section-padding-block-start: var(--section-padding-block-start-default);
      --section-padding-block-end: var(--section-padding-block-end-default);

      min-height: 0;
    }


    .p-top-hero__tags {
      margin-bottom: 1.5rem;
    }

    .p-top-hero__tag {
      padding: 4px 0.375rem;
      font-size: 1rem;
    }

    .p-top-hero__blobs {
      gap: 0.375rem;
      margin-left: -0.25rem;
      margin-bottom: 0.5rem;
    }

    .p-top-hero__blob {
      width: 4.75rem;
      height: 4.6rem;
      margin-right: -0.5rem;
    }

    .p-top-hero__blob-char {
      transform: translateY(0.125rem);
      font-size: 54px;
    }

    .p-top-hero__catch {
      font-size: 40px;
    }

    .p-top-hero__lead {
      font-size: 26px;
      line-height: 1.5;
    }

    .p-top-hero__visual {
      width: 600px;
      max-width: 62%;
      transform: translateY(-50%);
      top: 50%;
    }
  }

  @media (--bp-md-up) {
    .p-top-hero__blobs {
      gap: 0.125rem;
      margin-left: -0.25rem;
    }

    .p-top-hero__blob {
      margin-right: -0.5rem;
    }
  }

  @media (--bp-lg-up) {
    .p-top-hero__visual {
      width: 580px;
      max-width: 60%;
    }
  }
</style>
