---
const links = [
  { href: '/about/', label: '運営者情報' },
  { href: '/instructor/', label: '講師紹介' },
  { href: '/faq/', label: 'よくある質問' },
];
---
<section class="bg-white py-12 md:py-16 border-t border-[#e9e9e9]">
  <div class="max-w-[960px] mx-auto px-4 md:px-6">
    <h2 class="text-xl md:text-2xl font-zen font-bold text-black-03 text-center mb-8 md:mb-10">
      「アテンドサロンR」について知る
    </h2>
    <div class="flex flex-col md:flex-row gap-px bg-[#ddd] rounded-lg overflow-hidden border border-[#ddd]">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class="flex-1 py-12 md:py-16 text-center bg-[#f4f4f4] hover:bg-[#eaeaea] transition-colors font-zen font-bold text-black-03 text-base md:text-lg px-4"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</section>
