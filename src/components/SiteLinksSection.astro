---
import SectionHeading from './SectionHeading.astro';

const links = [
  { href: '/about/', label: '運営者情報' },
  { href: '/instructor/', label: '講師紹介' },
  { href: '/faq/', label: 'よくある質問' },
];
---
<section class="pt-[130px] pb-[80px]" data-reveal>
  <div class="mx-auto w-full min-w-0 max-w-pageShell px-6">
    <div class="mx-auto w-full min-w-0 max-w-page">
    <SectionHeading label="LINK" title="「アテンドサロンR」について知る" />
    <div class="flex flex-col md:flex-row gap-px bg-border-soft rounded-lg overflow-hidden border border-border-soft">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class="flex-1 py-12 md:py-16 text-center bg-surface-02 hover:bg-surface-hover transition-colors font-zen font-bold text-black-03 text-base md:text-lg px-4"
        >
          {label}
        </a>
      ))}
    </div>
    </div>
  </div>
</section>
