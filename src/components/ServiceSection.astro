---
import SectionHeading from './SectionHeading.astro';
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    id: 'service-mental-health',
    title: 'メンタルヘルス研修',
    body: '不調の早期発見とセルフケア、相談しやすい職場づくりを支援します',
    bodyTone: 'dark' as const,
    icon: '/images/service-icon-heart.png',
    iconSize: 'large' as const,
    ctaLabel: '研修詳細へ',
  },
  {
    id: 'service-anger-management',
    title: 'アンガーマネジメント研修',
    body: '怒りを抑えるのではなく、上手に扱い、冷静に対処できる力を身につけます',
    bodyTone: 'muted' as const,
    icon: '/images/service-icon-fire.png',
    iconSize: 'large' as const,
    ctaLabel: '研修詳細へ',
  },
  {
    id: 'service-harassment',
    title: 'ハラスメント研修',
    body: 'ハラスメントによるトラブルに対して、ひとりで抱え込まない対応と組織としての線引きを学びます',
    bodyTone: 'muted' as const,
    icon: '/images/service-icon-prohibited.png',
    iconSize: 'large' as const,
    ctaLabel: '研修詳細へ',
  },
];

const serviceUseCaseGroups = [
  {
    title: '新入社員向け',
    items: [
      '新しい環境でも戸惑わないセルフケア',
      '自己肯定感を上げるためのビジネスマナー研修',
    ],
  },
  {
    title: '管理者向け',
    items: [
      '部下の変化に気づくラインケア',
      '管理者のためのフィードバック（人事評価）面談研修',
      '傾聴体験講座',
    ],
  },
  {
    title: '個別向け',
    items: ['個別（個人対象）カウンセリング', '個別キャリアコンサルティング（キャリア形成支援）'],
  },
] as const;
---
<section id="services" class="l-section p-service-section" data-reveal>
  <div class="p-section-mark p-section-mark--anchor-br p-section-mark--service" aria-hidden="true">
    <svg
      class="p-section-mark__svg"
      viewBox="0 0 1440 1152"
      xmlns="http://www.w3.org/2000/svg"
      role="presentation"
    >
      <text
        class="p-section-mark__text"
        x="0"
        y="1095"
        fill="currentColor"
        font-size="1296"
        font-weight="900"
        font-family="'Ruika 09', 'Ruika', 'Rubik', sans-serif"
        letter-spacing="-0.04em"
        dominant-baseline="alphabetic"
      >
        R
      </text>
    </svg>
  </div>

  <div class="l-container">
      <SectionHeading
        label="SERVICE"
        title="研修サービス一覧"
        decoLoading="eager"
      >
        <div slot="intro">
          <p>感情労働で働く皆さまがイキイキと働くために、３つの研修をご用意しています</p>
          <p>課題に合わせて、研修内容はカスタマイズいたします</p>
        </div>
      </SectionHeading>

      <!-- SP のみ: カルーセル操作域のため親の左右ガターを相殺。PCでは非表示のためレイアウト仕様書のフルブリード禁止に該当しない -->
      <div class="p-service-section__embla-sp">
        <div class="p-service-section__embla-sp-inner">
          <div
            id="service-section-carousel-viewport"
            class="p-service-section__embla-viewport"
            role="region"
            aria-roledescription="カルーセル"
            aria-label="研修サービス一覧。横にスワイプして全件を表示できます"
            tabindex="0"
          >
            <div id="service-section-carousel-container" class="p-service-section__embla-container">
              {
                services.map((s) => (
                  <div class="p-service-section__embla-slide">
                    <ServiceCard {...s} />
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <!-- md+: 3 カラムグリッド（アンカー id はこちらのみ） -->
      <div
        id="service-carousel"
        class="p-service-section__grid"
        aria-label="研修サービス一覧"
      >
        {
          services.map((s) => (
            <div class="p-service-section__grid-cell">
              <ServiceCard {...s} anchorId={s.id} />
            </div>
          ))
        }
      </div>

      <div
        class="p-service-section__use-cases"
        aria-labelledby="service-use-cases-heading"
      >
        <h3
          id="service-use-cases-heading"
          class="p-service-section__use-cases-heading"
        >
          具体的な研修活用事例
        </h3>
        <div class="p-service-section__use-cases-grid">
          {
            serviceUseCaseGroups.map((group) => (
              <div class="p-service-section__use-cases-group">
                <h4 class="p-service-section__use-cases-group-title">{group.title}</h4>
                <ul class="p-service-section__use-cases-list">
                  {group.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
  </div>
</section>

<style>
  .p-service-section {
    position: relative;
    /* R装飾はセクション外にはみ出すデザインのため、clipしない */
    overflow: visible;
    background: #fff;
    /* 次セクションの wave より前で、はみ出した R を描画する */
    z-index: 1;
  }

  .p-service-section > .l-container {
    position: relative;
    z-index: var(--z-section-content, 3);
  }

  /* SP のみ: 左右ガターを相殺してカルーセル幅を確保 */
  .p-service-section__embla-sp {
    box-sizing: border-box;
    margin-top: 1rem;
    width: calc(100% + 2 * var(--page-gutter));
    min-width: 0;
    max-width: none;
    flex-shrink: 0;
    margin-left: calc(-1 * var(--page-gutter));
    margin-right: calc(-1 * var(--page-gutter));
    padding-top: 1rem;
    padding-bottom: 1.25rem;
  }

  @media (--bp-md-up) {
    .p-service-section__embla-sp {
      display: none;
    }
  }

  .p-service-section__embla-sp-inner {
    min-width: 0;
    width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  .p-service-section__embla-viewport {
    --service-slide-spacing: 1rem;

    box-sizing: border-box;
    min-width: 0;
    overflow: hidden;
    container-type: inline-size;
    container-name: service-section-carousel;
    touch-action: pan-y;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .p-service-section__embla-container {
    display: flex;
    backface-visibility: hidden;
    touch-action: pan-y pinch-zoom;
    margin-left: calc(var(--service-slide-spacing) * -1);
  }

  .p-service-section__embla-slide {
    display: flex;
    flex: 0 0 min(300px, calc(100vw - 10rem));
    flex-grow: 0;
    flex-shrink: 0;
    min-width: 0;
    padding: 0.25rem 0 0.25rem var(--service-slide-spacing);
  }

  @supports (width: 1cqi) {
    .p-service-section__embla-slide {
      flex: 0 0 min(300px, calc(100cqi - 4rem));
    }
  }

  .p-service-section__grid {
    position: relative;
    display: none;
    margin-top: 2.5rem;
    min-width: 0;
    width: 100%;
    align-items: stretch;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 27px;
    row-gap: 0;
  }

  @media (--bp-md-up) {
    .p-service-section__grid {
      display: grid;
    }
  }

  .p-service-section__grid-cell {
    min-width: 0;
  }

  .p-service-section__use-cases {
    margin-top: 2.75rem;
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases {
      margin-top: 3.25rem;
    }
  }

  /* 参考: 二重線を左右に傾けて置く見出し装飾（元サンプルは h2 相当） */
  .p-service-section__use-cases-heading {
    position: relative;
    box-sizing: border-box;
    width: fit-content;
    max-width: 100%;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    font-family: var(--font-family-base);
    font-size: 1.3rem; /* 25px */
    font-weight: 700;
    line-height: 1.45;
    letter-spacing: 0.02em;
    text-align: center;
    text-wrap: balance;
    color: var(--color-black-03);
  }


  .p-service-section__use-cases-heading::before,
  .p-service-section__use-cases-heading::after {
    position: absolute;
    top: calc(50% - 15px + 0.5rem);
    width: 0;
    height: 22px;
    content: '';
    pointer-events: none;
  }

  .p-service-section__use-cases-heading::before {
    left: 0;
    border-left: 6px double currentColor;
    transform: rotate(-30deg);
    transform-origin: left center;
  }

  .p-service-section__use-cases-heading::after {
    right: 0;
    border-right: 6px double currentColor;
    transform: rotate(30deg);
    transform-origin: right center;
  }

  .p-service-section__use-cases-grid {
    display: grid;
    gap: 1.5rem 1.25rem;
    min-width: 0;
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem 1.75rem;
      align-items: start;
    }
  }

  .p-service-section__use-cases-group {
    margin: 0;
    min-width: 0;
    padding: 1rem 1rem 1.125rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-softer);
    background: var(--color-surface-01);
    box-shadow: var(--shadow-soft);
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-group {
      padding: 1.125rem 1.125rem 1.25rem;
    }
  }

  .p-service-section__use-cases-group-title {
    margin: 0 0 0.75rem;
    padding-left: 0.75rem;
    border-left: 4px solid var(--color-blue-01);
    font-family: var(--font-family-base);
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.5;
    color: var(--color-blue-01);
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-group-title {
      font-size: 1rem;
      margin-bottom: 0.875rem;
    }
  }

  .p-service-section__use-cases-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.65;
    color: var(--color-black-03);
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-list {
      font-size: 0.9375rem;
      gap: 0.5625rem;
    }
  }

  .p-service-section__use-cases-list li {
    position: relative;
    padding-left: 1.1em;
    min-width: 0;
  }

  .p-service-section__use-cases-list li::before {
    content: '・';
    position: absolute;
    left: 0;
    color: var(--color-black-05);
    font-weight: 700;
  }
</style>

<script>
  // @ts-nocheck — Embla は動的 import、IDE は .astro 内 script を TS として解釈しないことがある
  import { MEDIA_QUERY_MD_UP } from '../lib/breakpoints';

  const MQ = MEDIA_QUERY_MD_UP;
  let emblaApi = null;

  function destroyEmbla() {
    const vp = document.getElementById('service-section-carousel-viewport');
    if (emblaApi) {
      emblaApi.destroy();
      emblaApi = null;
    }
    if (vp) delete vp.dataset.emblaInit;
  }

  async function initEmbla() {
    const vp = document.getElementById('service-section-carousel-viewport');
    if (!vp || vp.dataset.emblaInit === '1') return;
    if (window.matchMedia(MQ).matches) return;

    const { default: EmblaCarousel } = await import('embla-carousel');
    if (window.matchMedia(MQ).matches) return;
    if (vp.dataset.emblaInit === '1') return;

    vp.dataset.emblaInit = '1';

    const api = EmblaCarousel(vp, {
      loop: true,
      align: 'center',
      dragFree: false,
      skipSnaps: false,
      watchDrag: true,
      watchResize: true,
    });
    emblaApi = api;
    // 全幅化・フォント後の計測ずれで左が詰むことがあるため 1 フレーム後に再計測
    requestAnimationFrame(() => {
      if (emblaApi === api) api.reInit();
    });
  }

  function apply() {
    if (window.matchMedia(MQ).matches) {
      destroyEmbla();
    } else {
      void initEmbla();
    }
  }

  const mq = window.matchMedia(MQ);
  mq.addEventListener('change', apply);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', apply, { once: true });
  } else {
    apply();
  }
</script>
