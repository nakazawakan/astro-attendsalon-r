---
const services = [
  {
    title: 'メンタルヘルス研修',
    body: 'ストレスや心の不調に関する基礎知識から、職場でのセルフケアや相談体制の整え方まで、実務に直結する内容を学びます。',
    icon: 'heart',
  },
  {
    title: 'アンガーマネジメント研修',
    body: '怒りのメカニズムを理解し、冷静に対応するスキルを身につけます。接客・チーム内コミュニケーションの質向上につながります。',
    icon: 'fire',
  },
  {
    title: 'ハラスメント研修',
    body: 'パワハラ・セクハラ等の防止と、早期発見・適切な対応のための知識を習得。コンプライアンスと心理的安全性の両立を支援します。',
    icon: 'prohibited',
  },
];
---
<section id="services" class="bg-white py-12 md:py-20">
  <div class="max-w-[960px] mx-auto px-4 md:px-6">
    <div class="text-center mb-4">
      <h2 class="inline-block relative text-[1.75rem] md:text-[32px] font-zen font-bold text-black-03">
        <span class="relative z-10">研修サービス一覧</span>
        <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-24 h-2 bg-pink-01/20 rounded-full" aria-hidden="true"></span>
      </h2>
    </div>
    <p class="text-center text-base text-black-03 max-w-2xl mx-auto mb-10 md:mb-14 leading-relaxed">
      職場の課題に合わせてカスタマイズ可能な研修プログラムをご用意しています。<br class="hidden md:block" />
      まずはお気軽にご相談ください。
    </p>

    <div class="flex flex-col md:flex-row md:flex-wrap justify-center gap-8 md:gap-6">
      {services.map(({ title, body, icon }) => (
        <article class="w-full md:w-[300px] max-w-[340px] mx-auto bg-bg-warm rounded-2xl p-6 flex flex-col items-center text-center shadow-sm border border-black/5">
          <h3 class="text-xl font-zen font-bold text-black-03 mb-4 order-1">{title}</h3>
          <div class="w-[79px] h-[79px] rounded-full bg-white flex items-center justify-center mb-4 order-2 shadow-sm">
            {icon === 'heart' && (
              <svg class="w-9 h-9 text-pink-01" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
              </svg>
            )}
            {icon === 'fire' && (
              <svg class="w-9 h-9 text-orange-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 23c-3.97-4.21-6-7.38-6-10.5 0-2.24 1.21-4.2 3-5.25.45 2.52 2.01 4.5 3.5 6.5.5-1.5 1-3 1-4.5 2.5 2 4 4.45 4 6.75 0 3.12-2.02 6.29-6 10.5z" />
              </svg>
            )}
            {icon === 'prohibited' && (
              <svg class="w-9 h-9 text-blue-01" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <path d="M5 5l14 14" stroke-linecap="round" />
              </svg>
            )}
          </div>
          <p class="text-sm text-black-03 leading-[1.6] order-3">{body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
