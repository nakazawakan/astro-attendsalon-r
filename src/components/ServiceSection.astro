---
import SectionHeading from './SectionHeading.astro';
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    id: 'service-mental-health',
    title: 'メンタルヘルス研修',
    body: '不調の早期発見とセルフケア、相談しやすい職場づくりを支援します',
    bodyTone: 'dark' as const,
    icon: '/images/service-icon-heart.svg',
    ctaLabel: 'メンタルヘルス研修',
  },
  {
    id: 'service-anger-management',
    title: 'アンガーマネジメント研修',
    body: '怒りを抑えるのではなく、上手に扱い、冷静に対処できる力を身につけます',
    bodyTone: 'muted' as const,
    icon: '/images/service-icon-fire.svg',
    ctaLabel: 'アンガーマネジメント研修',
  },
  {
    id: 'service-harassment',
    title: 'ハラスメント研修',
    body: 'ハラスメントによるトラブルに対して、ひとりで抱え込まない対応と組織としての線引きを学びます',
    bodyTone: 'muted' as const,
    icon: '/images/service-icon-prohibited.svg',
    ctaLabel: 'ハラスメント研修',
  },
];
---
<section id="services" class="p-service-section" data-reveal>
  <div class="l-page-shell">
    <div class="l-page-inner">
    <SectionHeading label="SERVICE" title="研修サービス一覧" decoLoading="eager">
      <div
        slot="after"
        class="p-service-section__intro"
      >
        <p>感情労働で働く皆さまがイキイキと働くために、３つの研修をご用意しています</p>
        <p>課題に合わせて、研修内容はカスタマイズいたします</p>
      </div>
    </SectionHeading>

    <!-- SP のみ: カルーセル操作域のため親の左右ガターを相殺。PCでは非表示のためレイアウト仕様書のフルブリード禁止に該当しない -->
    <div class="p-service-section__embla-sp">
      <div class="p-service-section__embla-sp-inner">
        <div
          id="service-embla-viewport"
          class="service-embla__viewport p-service-section__embla-viewport"
          role="region"
          aria-roledescription="カルーセル"
          aria-label="研修サービス一覧。横にスワイプして全件を表示できます"
          tabindex="0"
        >
          <div id="service-embla-container" class="service-embla__container">
            {
              services.map((s) => (
                <div class="service-embla__slide">
                  <ServiceCard {...s} />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- md+: 3 カラムグリッド（アンカー id はこちらのみ） -->
    <div
      id="service-carousel"
      class="p-service-section__grid"
      aria-label="研修サービス一覧"
    >
      {
        services.map((s) => (
          <div class="p-service-section__grid-cell">
            <ServiceCard {...s} anchorId={s.id} />
          </div>
        ))
      }
    </div>
    </div>
  </div>
</section>

<style is:global>
  .service-embla__viewport {
    touch-action: pan-y;
    box-sizing: border-box;
    container-type: inline-size;
    container-name: service-embla;
    /* loop + gap は「3枚目↔1枚目」に隙間が出ないため、公式の padding 方式（旧 gap-4 = 1rem） */
    --service-slide-spacing: 1rem;
  }
  .service-embla__container {
    display: flex;
    backface-visibility: hidden;
    touch-action: pan-y pinch-zoom;
    margin-left: calc(var(--service-slide-spacing) * -1);
  }
  .service-embla__slide {
    display: flex;
    flex: 0 0 min(300px, calc(100vw - 10rem));
    flex-grow: 0;
    flex-shrink: 0;
    min-width: 0;
    padding: 0.25rem 0 0.25rem var(--service-slide-spacing);
  }
  @supports (width: 1cqi) {
    .service-embla__slide {
      flex: 0 0 min(300px, calc(100cqi - 4rem));
    }
  }
</style>

<style>
  .p-service-section {
    background: #fff;
    padding-top: 130px;
    padding-bottom: 80px;
  }

  .p-service-section__intro {
    margin-top: 0.5rem;
    max-width: 720px;
  }

  .p-service-section__intro p {
    margin: 0;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-black-03);
  }

  .p-service-section__intro p + p {
    margin-top: 1em;
  }

  /* SP のみ: 左右ガターを相殺してカルーセル幅を確保 */
  .p-service-section__embla-sp {
    box-sizing: border-box;
    margin-top: 1rem;
    width: calc(100% + 2 * var(--page-gutter));
    min-width: 0;
    max-width: none;
    flex-shrink: 0;
    margin-left: calc(-1 * var(--page-gutter));
    margin-right: calc(-1 * var(--page-gutter));
    padding-top: 1rem;
    padding-bottom: 1.25rem;
  }

  @media (min-width: 768px) {
    .p-service-section__embla-sp {
      display: none;
    }
  }

  .p-service-section__embla-sp-inner {
    min-width: 0;
    width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  .p-service-section__embla-viewport {
    min-width: 0;
    overflow: hidden;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .p-service-section__grid {
    position: relative;
    display: none;
    margin-top: 2.5rem;
    min-width: 0;
    width: 100%;
    align-items: stretch;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 27px;
    row-gap: 0;
  }

  @media (min-width: 768px) {
    .p-service-section__grid {
      display: grid;
    }
  }

  .p-service-section__grid-cell {
    min-width: 0;
  }
</style>

<script>
  // @ts-nocheck — Embla は動的 import、IDE は .astro 内 script を TS として解釈しないことがある
  const MQ = '(min-width: 768px)';
  let emblaApi = null;

  function destroyEmbla() {
    const vp = document.getElementById('service-embla-viewport');
    if (emblaApi) {
      emblaApi.destroy();
      emblaApi = null;
    }
    if (vp) delete vp.dataset.emblaInit;
  }

  async function initEmbla() {
    const vp = document.getElementById('service-embla-viewport');
    if (!vp || vp.dataset.emblaInit === '1') return;
    if (window.matchMedia(MQ).matches) return;

    const { default: EmblaCarousel } = await import('embla-carousel');
    if (window.matchMedia(MQ).matches) return;
    if (vp.dataset.emblaInit === '1') return;

    vp.dataset.emblaInit = '1';

    const api = EmblaCarousel(vp, {
      loop: true,
      align: 'center',
      dragFree: false,
      skipSnaps: false,
      watchDrag: true,
      watchResize: true,
    });
    emblaApi = api;
    // 全幅化・フォント後の計測ずれで左が詰むことがあるため 1 フレーム後に再計測
    requestAnimationFrame(() => {
      if (emblaApi === api) api.reInit();
    });
  }

  function apply() {
    if (window.matchMedia(MQ).matches) {
      destroyEmbla();
    } else {
      void initEmbla();
    }
  }

  const mq = window.matchMedia(MQ);
  mq.addEventListener('change', apply);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', apply, { once: true });
  } else {
    apply();
  }
</script>
