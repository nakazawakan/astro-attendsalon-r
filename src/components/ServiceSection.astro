---
import SectionHeading from './SectionHeading.astro';
import SectionMarkDecor from './SectionMarkDecor.astro';
import ServiceCard from './ServiceCard.astro';
import { serviceOfferings } from '../data/service-offerings';

const serviceUseCaseGroups = [
  {
    audience: '新入社員向け',
    catchphrase: '社会人としての働くこころの整え方',
    description: '無理をため込まず、長く働き続けるための土台作りを支援します',
    items: ['新しい環境でも戸惑わないためのセルフケア', '自信をもって対応する'],
  },
  {
    audience: '管理者向け',
    catchphrase: '人を育てる力を磨く',
    description:
      '部下の成長に適切に関わり、管理者自身の心の負担を軽くすることでチーム全体の安定を支えます',
    items: [
      '部下の変化に気づいて早期に改善、解決するためのラインケア',
      '納得感のある人事評価（フィードバック）面談研修',
      '日常的に働きかけ、指示指導だけで終わらない傾聴体験',
    ],
  },
  {
    audience: '個別向け',
    catchphrase: '一人ひとりが安心して話せる相談サポート',
    description:
      '今つらいことの整理からこれからの働き方への行動化を促します　また研修後の個別フォローとしても活用できます',
    items: ['（個人対象）カウンセリング', 'キャリアコンサルティング（キャリア形成支援）'],
  },
] as const;
---
<section id="services" class="l-section p-service-section" data-reveal>
  <SectionMarkDecor anchor="br" variant="service" />

  <div class="l-container">
      <SectionHeading
        label="SERVICE"
        title="研修サービス一覧"
        decoLoading="eager"
      >
        <Fragment slot="intro">
          <p>感情労働で働く皆さまがイキイキと働くために、３つの研修をご用意しています</p>
          <p>課題に合わせて、研修内容はカスタマイズいたします</p>
        </Fragment>
      </SectionHeading>

      <!-- SP のみ: カルーセル操作域のため親の左右ガターを相殺。PCでは非表示のためレイアウト仕様書のフルブリード禁止に該当しない -->
      <div class="p-service-section__embla-sp">
        <div class="p-service-section__embla-sp-inner">
          <div
            id="service-section-carousel-viewport"
            class="p-service-section__embla-viewport"
            role="region"
            aria-roledescription="カルーセル"
            aria-label="研修サービス一覧。横にスワイプして全件を表示できます"
            tabindex="0"
          >
            <div id="service-section-carousel-container" class="p-service-section__embla-container">
              {
                serviceOfferings.map((service) => (
                  <div class="p-service-section__embla-slide">
                    <ServiceCard
                      title={service.title}
                      body={service.summary}
                      bodyTone={service.bodyTone}
                      icon={service.icon}
                      iconSize={service.iconSize}
                      ctaLabel={service.ctaLabel}
                      href={service.detailPath}
                    />
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <!-- md+: 3 カラムグリッド（アンカー id はこちらのみ） -->
      <div
        id="service-carousel"
        class="p-service-section__grid"
        aria-label="研修サービス一覧"
      >
        {
          serviceOfferings.map((service) => (
            <div class="p-service-section__grid-cell">
              <ServiceCard
                title={service.title}
                body={service.summary}
                bodyTone={service.bodyTone}
                icon={service.icon}
                iconSize={service.iconSize}
                ctaLabel={service.ctaLabel}
                href={service.detailPath}
                anchorId={service.homeAnchorId}
              />
            </div>
          ))
        }
      </div>

      <div
        class="p-service-section__use-cases"
        aria-labelledby="service-use-cases-heading"
      >
        <h3
          id="service-use-cases-heading"
          class="p-service-section__use-cases-heading"
        >
          具体的な研修活用事例
        </h3>
        <div class="p-service-section__use-cases-grid">
          {
            serviceUseCaseGroups.map((group) => (
              <div
                class="p-service-section__use-cases-group"
                role="group"
                aria-label={`${group.audience}の研修活用事例`}
              >
                <div class="p-service-section__use-cases-meta">
                  <div class="p-service-section__use-cases-lead">
                    <p class="p-service-section__use-cases-line p-service-section__use-cases-line--audience">
                      {group.audience}
                    </p>
                    <p class="p-service-section__use-cases-line p-service-section__use-cases-line--catch">
                      {group.catchphrase}
                    </p>
                  </div>
                  <p class="p-service-section__use-cases-line p-service-section__use-cases-line--desc">
                    {group.description}
                  </p>
                </div>
                <ul class="p-service-section__use-cases-list">
                  {group.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
  </div>
</section>

<style>
  .p-service-section {
    position: relative;
    /* R装飾はセクション外にはみ出すデザインのため、clipしない */
    overflow: visible;
    background: #fff;
    /* 次セクションの wave より前で、はみ出した R を描画する */
    z-index: 1;
  }

  .p-service-section > .l-container {
    position: relative;
    z-index: var(--z-section-content, 3);
  }

  /* SP のみ: 左右ガターを相殺してカルーセル幅を確保 */
  .p-service-section__embla-sp {
    box-sizing: border-box;
    margin-top: 1rem;
    width: calc(100% + 2 * var(--page-gutter));
    min-width: 0;
    max-width: none;
    flex-shrink: 0;
    margin-left: calc(-1 * var(--page-gutter));
    margin-right: calc(-1 * var(--page-gutter));
    padding-top: 1rem;
    padding-bottom: 1.25rem;
  }

  @media (--bp-md-up) {
    .p-service-section__embla-sp {
      display: none;
    }
  }

  .p-service-section__embla-sp-inner {
    min-width: 0;
    width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  .p-service-section__embla-viewport {
    --service-slide-spacing: 1rem;

    box-sizing: border-box;
    min-width: 0;
    overflow: hidden;
    container-type: inline-size;
    container-name: service-section-carousel;
    touch-action: pan-y;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .p-service-section__embla-container {
    display: flex;
    backface-visibility: hidden;
    touch-action: pan-y pinch-zoom;
    margin-left: calc(var(--service-slide-spacing) * -1);
  }

  .p-service-section__embla-slide {
    display: flex;
    flex: 0 0 min(300px, calc(100vw - 10rem));
    flex-grow: 0;
    flex-shrink: 0;
    min-width: 0;
    padding: 0.25rem 0 0.25rem var(--service-slide-spacing);
  }

  @supports (width: 1cqi) {
    .p-service-section__embla-slide {
      flex: 0 0 min(300px, calc(100cqi - 4rem));
    }
  }

  .p-service-section__grid {
    position: relative;
    display: none;
    margin-top: 2.5rem;
    min-width: 0;
    width: 100%;
    align-items: stretch;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 27px;
    row-gap: 0;
  }

  @media (--bp-md-up) {
    .p-service-section__grid {
      display: grid;
    }
  }

  .p-service-section__grid-cell {
    min-width: 0;
  }

  .p-service-section__use-cases {
    margin-top: 2.75rem;
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases {
      margin-top: 3.25rem;
    }
  }

  /* 参考: 二重線を左右に傾けて置く見出し装飾（元サンプルは h2 相当） */
  .p-service-section__use-cases-heading {
    position: relative;
    box-sizing: border-box;
    width: fit-content;
    max-width: 100%;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    font-family: var(--font-family-base);
    font-size: 1.3rem; /* 25px */
    font-weight: 700;
    line-height: 1.45;
    letter-spacing: 0.02em;
    text-align: center;
    text-wrap: balance;
    color: var(--color-black-03);
  }


  .p-service-section__use-cases-heading::before,
  .p-service-section__use-cases-heading::after {
    position: absolute;
    top: calc(50% - 15px + 0.5rem);
    width: 0;
    height: 22px;
    content: '';
    pointer-events: none;
  }

  .p-service-section__use-cases-heading::before {
    left: 0;
    border-left: 6px double currentColor;
    transform: rotate(-30deg);
    transform-origin: left center;
  }

  .p-service-section__use-cases-heading::after {
    right: 0;
    border-right: 6px double currentColor;
    transform: rotate(30deg);
    transform-origin: right center;
  }

  .p-service-section__use-cases-grid {
    display: grid;
    gap: 1.5rem 1.25rem;
    min-width: 0;
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem 1.75rem;
      align-items: stretch;
    }
  }

  .p-service-section__use-cases-group {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    margin: 0;
    min-width: 0;
    padding: 1rem 1rem 1.125rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-softer);
    background: var(--color-surface-01);
    box-shadow: var(--shadow-soft);
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-group {
      padding: 1.125rem 1.125rem 1.25rem;
    }
  }

  /* 説明＋上段リード。リード外は左揃えのまま読みやすく */
  .p-service-section__use-cases-meta {
    margin: 0 0 0.75rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    min-width: 0;
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-meta {
      margin-bottom: 0.875rem;
      gap: 0.65rem;
    }
  }

  /* 誰向け＋キャッチを1塊で中央 */
  .p-service-section__use-cases-lead {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    margin: 0;
    min-width: 0;
    width: 100%;
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-lead {
      gap: 0.5625rem;
    }
  }

  .p-service-section__use-cases-line {
    margin: 0;
    max-width: 100%;
    font-family: var(--font-family-base);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.65;
    letter-spacing: 0.02em;
    text-wrap: pretty;
    color: var(--color-black-03);
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-line {
      font-size: 0.875rem;
      letter-spacing: 0.025em;
    }
  }

  .p-service-section__use-cases-line--audience {
    width: 100%;
    font-size: 0.8125rem;
    font-weight: 700;
    line-height: 1.45;
    letter-spacing: 0.06em;
    text-wrap: balance;
    color: var(--color-blue-01);
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-line--audience {
      font-size: 0.875rem;
      letter-spacing: 0.07em;
    }
  }

  /* キャッチ：固定高さの装飾ブロック内で縦横中央（高さは従来比 2/3） */
  .p-service-section__use-cases-line--catch {
    --service-catch-block-height: calc(5.375rem * 2 / 3);

    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 100%;
    height: var(--service-catch-block-height);
    min-height: var(--service-catch-block-height);
    margin: 0;
    padding: 0.5rem 0.85rem;
    border-radius: 0.5rem;
    background:
      linear-gradient(
        125deg,
        rgb(127 154 168 / 0.14) 0%,
        rgb(251 107 106 / 0.09) 48%,
        rgb(127 154 168 / 0.08) 100%
      ),
      rgb(255 255 255 / 0.45);
    font-size: 0.8125rem;
    font-weight: 700;
    line-height: 1.55;
    letter-spacing: 0.04em;
    text-align: center;
    text-wrap: balance;
    color: var(--color-black-03);
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.04);
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-line--catch {
      --service-catch-block-height: calc(5.875rem * 2 / 3);

      padding-inline: 1rem;
      font-size: 0.875rem;
      letter-spacing: 0.045em;
    }
  }

  .p-service-section__use-cases-line--desc {
    font-weight: 500;
    color: var(--color-black-03);
    text-align: start;
  }

  .p-service-section__use-cases-list {
    flex: 1 1 auto;
    min-height: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.65;
    color: var(--color-black-03);
  }

  @media (--bp-md-up) {
    .p-service-section__use-cases-list {
      font-size: 0.9375rem;
      gap: 0.5625rem;
    }
  }

  .p-service-section__use-cases-list li {
    position: relative;
    padding-left: 1.1em;
    min-width: 0;
  }

  .p-service-section__use-cases-list li::before {
    content: '・';
    position: absolute;
    left: 0;
    color: var(--color-black-05);
    font-weight: 700;
  }
</style>

<script>
  // @ts-nocheck — Embla は動的 import、IDE は .astro 内 script を TS として解釈しないことがある
  import { MEDIA_QUERY_MD_UP } from '../lib/breakpoints';

  const MQ = MEDIA_QUERY_MD_UP;
  let emblaApi = null;

  function destroyEmbla() {
    const vp = document.getElementById('service-section-carousel-viewport');
    if (emblaApi) {
      emblaApi.destroy();
      emblaApi = null;
    }
    if (vp) delete vp.dataset.emblaInit;
  }

  async function initEmbla() {
    const vp = document.getElementById('service-section-carousel-viewport');
    if (!vp || vp.dataset.emblaInit === '1') return;
    if (window.matchMedia(MQ).matches) return;

    const { default: EmblaCarousel } = await import('embla-carousel');
    if (window.matchMedia(MQ).matches) return;
    if (vp.dataset.emblaInit === '1') return;

    vp.dataset.emblaInit = '1';

    const api = EmblaCarousel(vp, {
      loop: true,
      align: 'center',
      dragFree: false,
      skipSnaps: false,
      watchDrag: true,
      watchResize: true,
    });
    emblaApi = api;
    // 全幅化・フォント後の計測ずれで左が詰むことがあるため 1 フレーム後に再計測
    requestAnimationFrame(() => {
      if (emblaApi === api) api.reInit();
    });
  }

  function apply() {
    if (window.matchMedia(MQ).matches) {
      destroyEmbla();
    } else {
      void initEmbla();
    }
  }

  const mq = window.matchMedia(MQ);
  mq.addEventListener('change', apply);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', apply, { once: true });
  } else {
    apply();
  }
</script>
