---
const secondaryGroups = [
  {
    heading: 'サービス',
    links: [
      { href: '/comming-soon/', label: 'ハラスメント研修' },
      { href: '/comming-soon/', label: 'メンタルヘルス研修' },
      { href: '/comming-soon/', label: 'アンガーマネジメント研修' },
    ],
  },
  {
    heading: '研修について',
    links: [
      { href: '/comming-soon/', label: '選ばれる理由' },
      { href: '/column/about-emotional-labor', label: '感情労働とは' },
      { href: '/comming-soon/', label: 'お客様の声' },
      { href: '/faq/', label: 'よくある質問' },
      { href: '/philosophy/', label: '研修ポリシー' },
    ],
  },
  {
    heading: '運営情報',
    links: [
      { href: '/trainer/', label: '講師紹介' },
      { href: '/company/', label: '運営者情報' },
      { href: '/contact/', label: 'お問い合わせ' },
      { href: '/request/', label: '資料請求' },
      { href: '/news/', label: 'お知らせ' },
    ],
  },
  {
    heading: '情報コンテンツ',
    links: [{ href: '/column/', label: 'お役立ち情報' }],
  },
];

const legalLinks = [
  { href: '/sitemap/', label: 'サイトマップ' },
  { href: '/privacy-policy/', label: 'プライバシーポリシー' },
];
---
<footer class="l-footer">
  <div class="l-container l-footer__inner">
    <section class="l-footer__secondary l-footerSecondary" aria-label="サンプル">
      {secondaryGroups.map(({ heading, links }) => (
        <div class="l-footerSecondary__column">
          <p class="l-footerSecondary__heading">{heading}</p>
          <ul class="l-footerSecondary__list">
            {links.map(({ href, label }) => (
              <li class="l-footerSecondary__item">
                <a href={href} class="l-footerSecondary__link">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <div class="l-footer__bottom">
      <nav class="l-footer__legal" aria-label="サンプル">
        {legalLinks.map(({ href, label }) => (
          <a href={href} class="l-footer__legalLink">
            {label}
          </a>
        ))}
      </nav>
      <p class="l-footer__copy">© {new Date().getFullYear()} アテンドサロンR</p>
    </div>
  </div>
</footer>

<style>
  .l-footer {
    background: var(--color-footer-bg);
    color: rgb(255 255 255 / 0.9);
    padding-block: 2.5rem 1.75rem;
  }

  .l-footer__inner {
    display: grid;
  }

  .l-footerSecondary__link,
  .l-footer__legalLink {
    color: rgb(255 255 255 / 0.82);
    text-decoration: none;
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }

  .l-footerSecondary__link:hover,
  .l-footer__legalLink:hover {
    color: #fff;
  }

  .l-footer__legalLink:hover {
    text-decoration: underline;
  }

  .l-footerSecondary {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 0;
    padding: 0 0 1.25rem;
    border: 0;
  }

  .l-footerSecondary__heading {
    margin: 0 0 0.75rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.05em;
  }

  .l-footerSecondary__list {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .l-footerSecondary__link {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-size: 0.9em;
    line-height: 1.7;
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  .l-footerSecondary__link::before {
    content: "";
    flex: 0 0 auto;
    width: 0.42em;
    height: 0.42em;
    border-block-start: 1px solid currentColor;
    border-inline-end: 1px solid currentColor;
    opacity: 0.66;
    transform: rotate(45deg);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .l-footerSecondary__link:hover::before {
    opacity: 1;
    transform: translateX(0.12em) rotate(45deg);
  }

  .l-footer__bottom {
    display: grid;
    justify-items: center;
    gap: 0.875rem;
    padding-top: 1rem;
    border-top: 1px solid rgb(255 255 255 / 0.15);
  }

  .l-footer__legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    column-gap: 1rem;
    row-gap: 0.625rem;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }

  .l-footer__copy {
    margin: 0;
    font-size: 0.6875rem;
    color: rgb(255 255 255 / 0.52);
    letter-spacing: 0.03em;
  }

  @media (--bp-md-up) {
    .l-footer {
      padding-block: 3.25rem 2rem;
    }

    .l-footer__inner {
    }

    .l-footerSecondary {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.5rem;
      padding-bottom: 1.5rem;
    }

    .l-footer__bottom {
      grid-template-columns: 1fr auto;
      align-items: center;
      justify-items: stretch;
      gap: 1rem;
      padding-top: 1.25rem;
    }

    .l-footer__legal {
      justify-content: flex-start;
      font-size: 0.8125rem;
    }

    .l-footer__copy {
      justify-self: end;
      font-size: 0.75rem;
    }
  }
</style>
