---
const footerLinks = [
  { href: '/', label: 'トップ' },
  { href: '/kanjorodou/', label: '感情労働とは' },
  { href: '/instructor/', label: '講師紹介' },
  { href: '/faq/', label: 'よくある質問' },
  { href: '/about/', label: '運営者情報' },
  { href: '/contact/', label: 'お問い合わせ' },
];
---
<footer class="c-site-footer" data-reveal>
  <div class="l-page-shell c-site-footer__shell">
    <div class="l-page-inner c-site-footer__inner">
    <nav aria-label="フッターナビ" class="c-site-footer__nav">
      {footerLinks.map(({ href, label }) => (
        <a href={href} class="c-site-footer__link">
          {label}
        </a>
      ))}
    </nav>
    <p class="c-site-footer__copy">© {new Date().getFullYear()} アテンドサロンR. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .c-site-footer {
    background: var(--color-footer-bg);
    color: #fff;
    padding-block: 2.5rem;
  }

  .c-site-footer__inner {
    text-align: center;
  }

  .c-site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    column-gap: 1.5rem;
    row-gap: 0.75rem;
    font-size: 0.875rem;
    font-weight: 400;
  }

  .c-site-footer__link {
    color: rgb(255 255 255 / 0.9);
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }

  .c-site-footer__link:hover {
    color: #fff;
    text-decoration: underline;
  }

  .c-site-footer__copy {
    margin: 2rem 0 0;
    font-size: 0.75rem;
    color: rgb(255 255 255 / 0.5);
  }

  @media (min-width: 768px) {
    .c-site-footer {
      padding-block: 3rem;
    }

    .c-site-footer__nav {
      font-size: 1rem;
    }
  }
</style>
