---
import IconChatConsult from './IconChatConsult.astro';
import IconDocumentRequest from './IconDocumentRequest.astro';
import IconChevronCtaPink from './IconChevronCtaPink.astro';
import { serviceOfferings } from '../data/service-offerings';

const serviceNavLinks: { href: string; label: string }[] = serviceOfferings.map(({ detailPath, title }) => ({
  href: detailPath,
  label: title,
}));

const mobileNavLinks: { href: string; label: string }[] = [
  { href: '/#about', label: '選ばれる理由' },
  { href: '/column/about-emotional-labor', label: '感情労働とは' },
  ...serviceNavLinks,
  { href: '/company/', label: '運営者情報' },
  { href: '/trainer/', label: '講師紹介' },
];
---
<header
  id="site-header"
  class="c-site-header"
>
  <div class="l-container c-site-header__inner">
      <a href="/" class="c-site-header__brand">
      <img
        src="/images/logo.png"
        alt="アテンドサロンR"
        width="60"
        height="60"
        class="c-site-header__logo"
        decoding="async"
      />
      <div class="c-site-header__brand-copy">
        <span class="c-site-header__brand-line">イキイキと自分らしく働くための</span>
        <span class="c-site-header__brand-line c-site-header__brand-line--medium">ウェルビーイング経営支援</span>
      </div>
      </a>

    <nav
      class="c-site-header__desktop-nav"
      aria-label="メインナビゲーション"
    >
      <a href="/#about" class="c-site-header__desktop-link">選ばれる理由</a>
      <!-- <a href="/column/about-emotional-labor" class="c-site-header__desktop-link">感情労働とは</a> -->
      <div id="mega-services-wrap" class="c-site-header__mega-wrap">
        <button
          type="button"
          class="c-site-header__mega-trigger"
          id="mega-services-trigger"
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="mega-services-panel"
        >
          研修サービス
          <span class="c-site-header__mega-caret" aria-hidden="true">▼</span>
        </button>
        <div
          id="mega-services-panel"
          class="c-site-header__mega-panel"
          role="region"
          aria-label="研修サービス"
        >
          <div class="c-site-header__mega-menu">
            {
              serviceOfferings.map((service) => (
                <a href={service.detailPath} class="c-site-header__mega-link">
                  {service.title}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </nav>

    <div class="c-site-header__desktop-ctas">
      <a
        href="/contact/"
        class="c-button c-button--outline-pink"
      >
        <IconChatConsult />
        無料相談
      </a>
      <a
        href="/request/"
        class="c-button c-button--solid-pink"
      >
        <IconDocumentRequest class="c-site-header__cta-icon" />
        資料請求
      </a>
    </div>

    <details id="site-header-mobile-details" class="c-site-header__mobile-details">
      <summary
        class="c-site-header__mobile-summary"
        aria-label="メニューを開く"
        aria-controls="site-header-mobile-panel"
      >
        <span class="u-visually-hidden">メニュー</span>
        <span class="c-site-header__hamburger" aria-hidden="true">
          <span class="c-site-header__hamburger-line"></span>
          <span class="c-site-header__hamburger-line"></span>
          <span class="c-site-header__hamburger-line"></span>
        </span>
      </summary>
      <div
        id="site-header-mobile-panel"
        class="c-site-header__mobile-panel"
      >
        <nav class="c-site-header__mobile-links" aria-label="モバイルナビ">
          {
            mobileNavLinks.map(({ href, label }) => (
              <a
                href={href}
                class="c-site-header__mobile-link"
              >
                <IconChevronCtaPink class="c-site-header__mobile-link-icon" />
                <span>{label}</span>
              </a>
            ))
          }
        </nav>
        <div class="c-site-header__mobile-ctas">
          <a href="/contact/" class="c-button c-button--outline-pink">
            <IconChatConsult />
            無料相談
          </a>
          <a href="/request/" class="c-button c-button--solid-pink">
            <IconDocumentRequest class="c-site-header__cta-icon" />
            資料請求
          </a>
        </div>
      </div>
    </details>
  </div>
</header>

<style>
  .c-site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    border-bottom: 1px solid transparent;
    background: transparent;
    box-shadow: none;
    transition: background-color 0.2s ease-out, box-shadow 0.2s ease-out, border-color 0.2s ease-out;
  }

  .c-site-header.is-scrolled {
    background: #fff;
    border-bottom-color: rgb(0 0 0 / 0.05);
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.08);
  }

  .c-site-header__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  .c-site-header__brand {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 6px;
  }

  .c-site-header__logo {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    object-fit: contain;
  }

  .c-site-header__brand-copy {
    font-size: 12px;
    line-height: 1.25;
    color: var(--color-black-03);
  }

  .c-site-header__brand-line {
    display: block;
  }

  .c-site-header__brand-line--medium {
    font-weight: 500;
  }

  .c-site-header__desktop-nav,
  .c-site-header__desktop-ctas {
    display: none;
  }

  .c-site-header__desktop-link,
  .c-site-header__mega-trigger {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0;
    line-height: 1.25;
    color: var(--color-black-03);
    font-size: 15px;
    font-weight: 700;
    transition: color 0.2s ease;
  }

  .c-site-header__desktop-link {
    text-decoration: none;
  }

  .c-site-header__mega-caret {
    display: inline-block;
    font-size: 10px;
    line-height: 1;
    opacity: 0.7;
  }

  .c-site-header__desktop-link:hover,
  .c-site-header__mega-trigger:hover {
    color: var(--color-pink-01);
  }

  .c-site-header__mega-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .c-site-header__mega-trigger {
    gap: 0.25rem;
    border: 0;
    background: transparent;
    cursor: pointer;
    /* UA の button 用フォントを避ける。`font: inherit` は font-weight も親に戻すため使わない */
    font-family: inherit;
  }

  .c-site-header__mega-panel {
    position: absolute;
    left: 50%;
    top: 100%;
    z-index: 70;
    width: max-content;
    min-width: min(100vw - 3rem, 280px);
    padding-top: 0.5rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateX(-50%);
    transition: opacity 0.15s ease-out, visibility 0.15s ease-out;
  }

  .c-site-header__mega-wrap:hover .c-site-header__mega-panel,
  .c-site-header__mega-wrap:focus-within .c-site-header__mega-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .c-site-header__mega-menu {
    border: 1px solid rgb(0 0 0 / 0.1);
    border-radius: var(--radius-lg);
    background: #fff;
    box-shadow: 0 10px 30px rgb(0 0 0 / 0.12);
    padding: 0.5rem 0;
  }

  .c-site-header__mega-link {
    display: block;
    white-space: nowrap;
    padding: 0.625rem 1rem;
    color: var(--color-black-03);
    font-size: 15px;
    font-weight: 700;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .c-site-header__mega-link:hover {
    color: var(--color-pink-01);
    background: var(--color-bg-warm);
  }

  .c-site-header__cta-icon {
    color: #fff;
  }

  .c-site-header__mobile-details {
    position: relative;
  }

  .c-site-header__mobile-summary {
    list-style: none;
    cursor: pointer;
    margin-right: -0.5rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.375rem;
    border: 0;
    background: var(--color-pink-01);
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }

  .c-site-header__mobile-summary::-webkit-details-marker {
    display: none;
  }

  .c-site-header__mobile-summary:hover {
    opacity: 0.9;
  }

  .c-site-header__hamburger {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 1.25rem;
    height: 0.875rem;
  }

  .c-site-header__hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 9999px;
    background: #fff;
    transform-origin: center;
    transition: transform 0.2s ease-out, opacity 0.2s ease-out;
  }

  .c-site-header__mobile-details[open] .c-site-header__hamburger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .c-site-header__mobile-details[open] .c-site-header__hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .c-site-header__mobile-details[open] .c-site-header__hamburger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .c-site-header__mobile-panel {
    position: fixed;
    left: 50%;
    top: calc(var(--site-header-bottom, 84px) + 0.5rem);
    z-index: 60;
    width: calc(100vw - 3rem);
    transform: translateX(-50%);
    transform-origin: top;
    border: 1px solid rgb(0 0 0 / 0.1);
    border-radius: var(--radius-lg);
    background: #fff;
    padding: 1rem;
    box-shadow: 0 14px 30px rgb(0 0 0 / 0.14);
  }

  .c-site-header__mobile-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    font-size: 15px;
    font-weight: 700;
  }

  .c-site-header__mobile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    min-height: 2.75rem;
    border-bottom: 1px solid rgb(0 0 0 / 0.05);
    padding: 0.625rem 0;
    color: var(--color-black-03);
    transition: color 0.2s ease;
  }

  .c-site-header__mobile-link:hover {
    color: var(--color-pink-01);
  }

  .c-site-header__mobile-link-icon {
    transform: translateY(1px);
  }

  .c-site-header__mobile-ctas {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  @media (--bp-md-up) {
    .c-site-header__inner {
      padding-top: 1rem;
      padding-bottom: 1rem;
    }

    .c-site-header__brand {
      gap: 0.75rem;
    }

    .c-site-header__logo {
      width: 60px;
      height: 60px;
    }

    .c-site-header__brand-copy {
      font-size: 13px;
    }

    .c-site-header__desktop-nav {
      display: flex;
      flex: 1;
      align-items: center;
      justify-content: flex-end;
      gap: 1.5rem;
      flex-wrap: nowrap;
    }

    .c-site-header__desktop-ctas {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-shrink: 0;
    }

    .c-site-header__mobile-details {
      display: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .c-site-header__mobile-details[open] .c-site-header__mobile-panel {
      animation: c-site-header-panel-in 0.38s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .c-site-header__mobile-details[open] .c-site-header__mobile-links > a {
      animation: c-site-header-item-in 0.34s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .c-site-header__mobile-details[open] .c-site-header__mobile-links > a:nth-child(1) {
      animation-delay: 0.04s;
    }
    .c-site-header__mobile-details[open] .c-site-header__mobile-links > a:nth-child(2) {
      animation-delay: 0.07s;
    }
    .c-site-header__mobile-details[open] .c-site-header__mobile-links > a:nth-child(3) {
      animation-delay: 0.1s;
    }
    .c-site-header__mobile-details[open] .c-site-header__mobile-links > a:nth-child(4) {
      animation-delay: 0.13s;
    }
    .c-site-header__mobile-details[open] .c-site-header__mobile-links > a:nth-child(5) {
      animation-delay: 0.16s;
    }
    .c-site-header__mobile-details[open] .c-site-header__mobile-links > a:nth-child(6) {
      animation-delay: 0.19s;
    }
    .c-site-header__mobile-details[open] .c-site-header__mobile-links > a:nth-child(7) {
      animation-delay: 0.22s;
    }

    .c-site-header__mobile-details[open] .c-site-header__mobile-ctas > a {
      animation: c-site-header-item-in 0.34s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .c-site-header__mobile-details[open] .c-site-header__mobile-ctas > a:nth-child(1) {
      animation-delay: 0.26s;
    }
    .c-site-header__mobile-details[open] .c-site-header__mobile-ctas > a:nth-child(2) {
      animation-delay: 0.3s;
    }
  }

  @keyframes c-site-header-panel-in {
    from {
      opacity: 0;
      transform: translate(-50%, -0.5rem) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
    }
  }

  @keyframes c-site-header-item-in {
    from {
      opacity: 0;
      transform: translateY(0.4rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline>
  (function () {
    var el = document.getElementById('site-header');
    if (!el) return;
    function sync() {
      var on = (window.scrollY || window.pageYOffset) > 4;
      el.classList.toggle('is-scrolled', on);
      var h = el.offsetHeight + 'px';
      el.style.setProperty('--site-header-bottom', h);
      document.documentElement.style.setProperty('--scroll-padding-top', h);
    }
    sync();
    document.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync);
    window.addEventListener('pageshow', sync);

    var details = document.getElementById('site-header-mobile-details');
    var sum = details && details.querySelector('summary');
    if (details && sum) {
      details.addEventListener('toggle', function () {
        sum.setAttribute('aria-label', details.open ? 'メニューを閉じる' : 'メニューを開く');
      });
    }
    var panel = document.getElementById('site-header-mobile-panel');
    if (details && panel) {
      panel.addEventListener('click', function (e) {
        if (e.target.closest('a')) details.removeAttribute('open');
      });
    }

    var megaWrap = document.getElementById('mega-services-wrap');
    var megaBtn = document.getElementById('mega-services-trigger');
    if (megaWrap && megaBtn) {
      function setMegaExpanded(on) {
        megaBtn.setAttribute('aria-expanded', on ? 'true' : 'false');
      }
      megaWrap.addEventListener('focusin', function () {
        setMegaExpanded(true);
      });
      megaWrap.addEventListener('focusout', function (e) {
        if (!megaWrap.contains(e.relatedTarget)) setMegaExpanded(false);
      });
      megaWrap.addEventListener('mouseenter', function () {
        setMegaExpanded(true);
      });
      megaWrap.addEventListener('mouseleave', function () {
        if (!megaWrap.contains(document.activeElement)) setMegaExpanded(false);
      });
    }
  })();
</script>
