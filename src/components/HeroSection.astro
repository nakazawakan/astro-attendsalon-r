---
import HeroEmotionalRipple from './HeroEmotionalRipple.astro';

const tags = ['ストレスケア', '接客対応', 'ハラスメント対応'];
const blobs = [
  { char: '感', src: '/images/blob-kan.svg' },
  { char: '情', src: '/images/blob-jo.svg' },
  { char: '労', src: '/images/blob-ro.svg' },
  { char: '働', src: '/images/blob-do.svg' },
];
---
<section
  class="hero-soft-enter relative overflow-x-clip bg-bg-warm pt-[6rem] pb-10 md:pt-[130px] md:pb-[80px] min-h-[520px] md:min-h-0"
>
  <!-- 左上装飾「R」— 白・+45°（旧 -45° の逆回り）。Ruika → Rubik 900。影なし -->
  <div
    class="pointer-events-none select-none absolute left-0 top-0 z-0 origin-top-left scale-[1.5] md:scale-[0.85] rotate-45
      translate-x-[calc(8%+20px)] md:translate-x-[3%] -translate-y-[calc(38%+64px)] md:-translate-y-[34%]
      w-[370px] md:w-[clamp(320px,86vw,1480px)]"
    aria-hidden="true"
  >
    <svg class="block h-auto w-full text-white antialiased" viewBox="0 0 1440 1152"
      xmlns="http://www.w3.org/2000/svg"
      role="presentation"
    >
      <text
        x="0"
        y="1095"
        fill="currentColor"
        font-size="1296"
        font-weight="900"
        font-family="'Ruika 09', 'Ruika', 'Rubik', sans-serif"
        letter-spacing="-0.04em"
        dominant-baseline="alphabetic"
        style="text-shadow: none"
      >
        R
      </text>
    </svg>
  </div>

  <!-- 外: 1008 + 左右24px。内: max-w-page で本文カラム 960px を明示 -->
  <div class="relative mx-auto w-full min-w-0 max-w-pageShell px-6">
    <div
      class="relative mx-auto w-full min-w-0 max-w-page md:flex md:flex-row md:items-center md:justify-between md:gap-6 lg:gap-8"
    >
      <!-- md: flex 行で右イラストと並べ、translate による img のにじみを避ける（旧: absolute + pr 予約） -->
      <div class="relative z-10 w-full min-w-0 md:flex-1 md:min-w-0">
        <div class="flex flex-nowrap gap-2 mb-[0.7rem] md:mb-6">
          {tags.map((t) => (
            <span class="shrink-0 whitespace-nowrap rounded-sm border border-blue-01 bg-white px-1 py-0.5 font-zen text-[13px] font-bold leading-none text-blue-01 md:px-1.5 md:py-1 md:text-base">
              {t}
            </span>
          ))}
        </div>

        <div
          class="flex flex-nowrap items-end gap-0 sm:gap-0.5 md:gap-1.5 mb-1 md:mb-2 -ml-0.5 sm:-ml-1"
        >
          {blobs.map(({ char, src }) => (
            <span class="relative inline-flex shrink-0 items-center justify-center w-[calc(5.175rem*0.85)] h-[calc(5.025rem*0.85)] sm:w-[calc(5.4rem*0.85)] sm:h-[calc(5.25rem*0.85)] md:w-[4.75rem] md:h-[4.6rem] -mr-1.5 sm:-mr-2 md:-mr-2 last:mr-0 drop-shadow-[0_1px_0_rgba(0,0,0,0.04)]">
              <img src={src} alt="" class="absolute inset-0 w-full h-full object-contain" aria-hidden="true" />
              <span class="relative text-pink-01 text-[calc(3.075rem*0.85)] sm:text-[calc(3.9rem*0.85)] md:text-[54px] font-zen font-bold leading-none tracking-tight translate-y-[1px] md:translate-y-0.5">
                {char}
              </span>
            </span>
          ))}
        </div>

        <p class="text-black-03 text-[2.25rem] md:text-[40px] font-zen font-bold leading-tight mb-4 whitespace-nowrap">
          の職場向け研修支援
        </p>

        <div class="text-black-03 text-xl md:text-[30px] font-zen font-bold leading-[1.5]">
          <p class="mb-0 whitespace-nowrap">アテンドサロンRは、</p>
          <p class="mb-0 whitespace-nowrap">感情労働のフィールドで</p>
          <p class="mb-0 whitespace-nowrap">イキイキ働く組織づくりを支援します</p>
        </div>
      </div>

      <!-- ヒーロー右：仮は `HeroEmotionalRipple` の NO IMAGE（本番ビジュアルは後から差し替え） -->
      <figure
        class="mt-16 w-full max-w-[min(100%,420px)] mx-auto shrink-0 md:mx-0 md:mt-0 md:w-[min(380px,40vw)] lg:w-[min(420px,38vw)] md:max-w-[440px] z-[5]"
        aria-hidden="true"
      >
        <HeroEmotionalRipple />
      </figure>
    </div>
  </div>
</section>
