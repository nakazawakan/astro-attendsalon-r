---
import HeroEmotionalRipple from './HeroEmotionalRipple.astro';
import SectionMarkDecor from './SectionMarkDecor.astro';

const tags = ['ストレスケア', 'アンガーマネジメント', 'ハラスメント対策'];
const blobs = [
  { char: '感', src: '/images/blob-kan.svg' },
  { char: '情', src: '/images/blob-jo.svg' },
  { char: '労', src: '/images/blob-ro.svg' },
  { char: '働', src: '/images/blob-do.svg' },
];
---
<section class="l-section p-hero-section p-hero-section--soft-enter">
  <!-- 左上装飾「R」— 白・+45°（旧 -45° の逆回り）。Ruika → Rubik 900。影なし -->
  <SectionMarkDecor anchor="tl" variant="hero" />

  <!-- 1008px 幅の l-container で、左右24pxガター込みの本文カラムを作る -->
  <div class="l-container p-hero-section__inner">
      <!-- md: flex 行で右イラストと並べ、translate による img のにじみを避ける（旧: absolute + pr 予約） -->
      <div class="p-hero-section__copy">
        <div class="p-hero-section__tags">
          {tags.map((t) => (
            <span class="p-hero-section__tag">
              {t}
            </span>
          ))}
        </div>

        <div class="p-hero-section__blobs">
          {blobs.map(({ char, src }) => (
            <span class="p-hero-section__blob">
              <img src={src} alt="" class="p-hero-section__blob-bg" aria-hidden="true" />
              <span class="p-hero-section__blob-char">
                {char}
              </span>
            </span>
          ))}
          の職場向け
        </div>

        <p class="p-hero-section__heading-sub">
          実践型マネジメント研修
        </p>

        <div class="p-hero-section__lead">
          <p class="p-hero-section__lead-line">アテンドサロンRは、</p>
          <p class="p-hero-section__lead-line">感情労働のフィールドで</p>
          <p class="p-hero-section__lead-line">イキイキ働く組織づくりを支援します</p>
        </div>
      </div>

      <!-- ヒーロー右：仮は `HeroEmotionalRipple` の NO IMAGE（本番ビジュアルは後から差し替え） -->
      <figure
        class="p-hero-section__visual"
        aria-hidden="true"
      >
        <HeroEmotionalRipple />
      </figure>
  </div>
</section>
