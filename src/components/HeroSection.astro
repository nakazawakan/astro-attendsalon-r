---
import HeroEmotionalRipple from './HeroEmotionalRipple.astro';

const tags = ['ストレスケア', 'アンガーマネジメント', 'ハラスメント対策'];
const blobs = [
  { char: '感', src: '/images/blob-kan.svg' },
  { char: '情', src: '/images/blob-jo.svg' },
  { char: '労', src: '/images/blob-ro.svg' },
  { char: '働', src: '/images/blob-do.svg' },
];
---
<section class="p-hero hero-soft-enter">
  <!-- 左上装飾「R」— 白・+45°（旧 -45° の逆回り）。Ruika → Rubik 900。影なし -->
  <div
    class="p-hero__r-mark"
    aria-hidden="true"
  >
    <svg class="p-hero__r-svg" viewBox="0 0 1440 1152"
      xmlns="http://www.w3.org/2000/svg"
      role="presentation"
    >
      <text
        class="p-hero__r-text"
        x="0"
        y="1095"
        fill="currentColor"
        font-size="1296"
        font-weight="900"
        font-family="'Ruika 09', 'Ruika', 'Rubik', sans-serif"
        letter-spacing="-0.04em"
        dominant-baseline="alphabetic"
      >
        R
      </text>
    </svg>
  </div>

  <!-- 外: 1008 + 左右24px。内: max-w-page で本文カラム 960px を明示 -->
  <div class="l-page-shell p-hero__shell">
    <div class="l-page-inner p-hero__inner">
      <!-- md: flex 行で右イラストと並べ、translate による img のにじみを避ける（旧: absolute + pr 予約） -->
      <div class="p-hero__copy">
        <div class="p-hero__tags">
          {tags.map((t) => (
            <span class="p-hero__tag">
              {t}
            </span>
          ))}
        </div>

        <div class="p-hero__blobs">
          {blobs.map(({ char, src }) => (
            <span class="p-hero__blob">
              <img src={src} alt="" class="p-hero__blob-bg" aria-hidden="true" />
              <span class="p-hero__blob-char">
                {char}
              </span>
            </span>
          ))}
          の
        </div>

        <p class="p-hero__heading-sub">
          職場向け実践型マネジメント研修
        </p>

        <div class="p-hero__lead">
          <p class="p-hero__lead-line">アテンドサロンRは、</p>
          <p class="p-hero__lead-line">感情労働のフィールドで</p>
          <p class="p-hero__lead-line">イキイキ働く組織づくりを支援します</p>
        </div>
      </div>

      <!-- ヒーロー右：仮は `HeroEmotionalRipple` の NO IMAGE（本番ビジュアルは後から差し替え） -->
      <figure
        class="p-hero__visual"
        aria-hidden="true"
      >
        <HeroEmotionalRipple />
      </figure>
    </div>
  </div>
</section>

<style>
  .p-hero {
    position: relative;
    overflow-x: clip;
    background: var(--color-bg-warm);
    padding-top: 7rem;
    padding-bottom: 2.5rem;
    min-height: 520px;
  }

  .p-hero__r-mark {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 0;
    width: 370px;
    transform-origin: top left;
    transform: translate(calc(8% + 20px), calc(-38% - 64px)) rotate(45deg) scale(1.5);
    pointer-events: none;
    user-select: none;
  }

  .p-hero__r-svg {
    display: block;
    width: 100%;
    height: auto;
    color: #fff;
    -webkit-font-smoothing: antialiased;
  }

  .p-hero__r-text {
    text-shadow: none;
  }

  .p-hero__shell,
  .p-hero__inner {
    position: relative;
  }

  .p-hero__copy {
    position: relative;
    z-index: 10;
    width: 100%;
    min-width: 0;
  }

  .p-hero__tags {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .p-hero__tag {
    flex-shrink: 0;
    white-space: nowrap;
    border: 1px solid var(--color-blue-01);
    border-radius: 0.125rem;
    background: #fff;
    padding: 0.125rem 0.25rem;
    font-size: 13px;
    line-height: 1;
    font-weight: 700;
    color: var(--color-blue-01);
  }

  .p-hero__blobs {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-end;
    gap: 0;
    margin-bottom: 0.25rem;
    margin-left: -0.125rem;
    font-size: 32px;
    font-weight: 700;
  }

  .p-hero__blob {
    position: relative;
    display: inline-flex;
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    margin-right: -0.375rem;
    filter: drop-shadow(0 1px 0 rgba(0, 0, 0, 0.04));
  }

  .p-hero__blob:last-child {
    margin-right: 0;
  }

  .p-hero__blob-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .p-hero__blob-char {
    position: relative;
    transform: translateY(1px);
    font-size: 42px;
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 700;
    color: var(--color-pink-01);
  }

  .p-hero__heading-sub {
    margin: 0 0 1rem;
    white-space: nowrap;
    color: var(--color-black-03);
    font-size: 32px;
    line-height: 1.25;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .p-hero__heading-sub {
      font-size: 24px;
    }
  }

  .p-hero__lead {
    color: var(--color-black-03);
    font-size: 18px;
    line-height: 1.4;
    font-weight: 700;
  }

  .p-hero__lead-line {
    margin: 0;
    white-space: nowrap;
  }

  .p-hero__visual {
    margin: 4rem auto 0;
    width: 100%;
    max-width: min(100%, 420px);
    flex-shrink: 0;
    z-index: 5;
  }

  @media (min-width: 640px) {
    .p-hero__blobs {
      gap: 0.125rem;
      margin-left: -0.25rem;
    }

    .p-hero__blob {
      margin-right: -0.5rem;
    }
  }

  @media (min-width: 768px) {
    .p-hero {
      padding-top: 130px;
      padding-bottom: 80px;
      min-height: 0;
    }

    .p-hero__r-mark {
      width: clamp(320px, 86vw, 1480px);
      transform: translate(3%, -34%) rotate(45deg) scale(0.85);
    }

    .p-hero__inner {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .p-hero__copy {
      flex: 1;
      min-width: 0;
    }

    .p-hero__tags {
      margin-bottom: 1.5rem;
    }

    .p-hero__tag {
      padding: 4px 0.375rem;
      font-size: 1rem;
    }

    .p-hero__blobs {
      gap: 0.375rem;
      margin-left: -0.25rem;
      margin-bottom: 0.5rem;
    }

    .p-hero__blob {
      width: 4.75rem;
      height: 4.6rem;
      margin-right: -0.5rem;
    }

    .p-hero__blob-char {
      transform: translateY(0.125rem);
      font-size: 54px;
    }

    .p-hero__heading-sub {
      font-size: 40px;
    }

    .p-hero__lead {
      font-size: 26px;
      line-height: 1.5;
    }

    .p-hero__visual {
      margin: 0;
      width: min(380px, 40vw);
      max-width: 440px;
    }
  }

  @media (min-width: 1024px) {
    .p-hero__inner {
      gap: 2rem;
    }

    .p-hero__visual {
      width: min(420px, 38vw);
    }
  }
</style>
