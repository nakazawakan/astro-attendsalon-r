---
import HeroEmotionalRipple from './HeroEmotionalRipple.astro';

const tags = ['ストレスケア', 'アンガーマネジメント', 'ハラスメント対策'];
const blobs = [
  { char: '感', src: '/images/blob-kan.svg' },
  { char: '情', src: '/images/blob-jo.svg' },
  { char: '労', src: '/images/blob-ro.svg' },
  { char: '働', src: '/images/blob-do.svg' },
];
---
<section class="l-section p-hero-section p-hero-section--soft-enter">
  <!-- 左上装飾「R」— 白・+45°（旧 -45° の逆回り）。Ruika → Rubik 900。影なし -->
  <div
    class="p-section-mark p-section-mark--anchor-tl p-section-mark--hero"
    aria-hidden="true"
  >
    <svg class="p-section-mark__svg" viewBox="0 0 1440 1152"
      xmlns="http://www.w3.org/2000/svg"
      role="presentation"
    >
      <text
        class="p-section-mark__text"
        x="0"
        y="1095"
        fill="currentColor"
        font-size="1296"
        font-weight="900"
        font-family="'Ruika 09', 'Ruika', 'Rubik', sans-serif"
        letter-spacing="-0.04em"
        dominant-baseline="alphabetic"
      >
        R
      </text>
    </svg>
  </div>

  <!-- 1008px 幅の l-container で、左右24pxガター込みの本文カラムを作る -->
  <div class="l-container p-hero-section__inner">
      <!-- md: flex 行で右イラストと並べ、translate による img のにじみを避ける（旧: absolute + pr 予約） -->
      <div class="p-hero-section__copy">
        <div class="p-hero-section__tags">
          {tags.map((t) => (
            <span class="p-hero-section__tag">
              {t}
            </span>
          ))}
        </div>

        <div class="p-hero-section__blobs">
          {blobs.map(({ char, src }) => (
            <span class="p-hero-section__blob">
              <img src={src} alt="" class="p-hero-section__blob-bg" aria-hidden="true" />
              <span class="p-hero-section__blob-char">
                {char}
              </span>
            </span>
          ))}
          の職場向け
        </div>

        <p class="p-hero-section__heading-sub">
          実践型マネジメント研修
        </p>

        <div class="p-hero-section__lead">
          <p class="p-hero-section__lead-line">アテンドサロンRは、</p>
          <p class="p-hero-section__lead-line">感情労働のフィールドで</p>
          <p class="p-hero-section__lead-line">イキイキ働く組織づくりを支援します</p>
        </div>
      </div>

      <!-- ヒーロー右：仮は `HeroEmotionalRipple` の NO IMAGE（本番ビジュアルは後から差し替え） -->
      <figure
        class="p-hero-section__visual"
        aria-hidden="true"
      >
        <HeroEmotionalRipple />
      </figure>
  </div>
</section>

<style>
  .p-hero-section {
    --section-padding-block-start: 7rem;
    --section-padding-block-end: 2.5rem;

    position: relative;
    overflow-x: clip;
    background: var(--color-bg-warm);
    min-height: 520px;
  }

  .p-hero-section__inner {
    position: relative;
  }

  .p-hero-section__copy {
    position: relative;
    z-index: 10;
    width: 100%;
    min-width: 0;
  }

  .p-hero-section__tags {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.2rem;
    margin-bottom: 0.4rem;
  }

  .p-hero-section__tag {
    flex-shrink: 0;
    white-space: nowrap;
    border: 1px solid var(--color-blue-01);
    border-radius: 0.125rem;
    background: #fff;
    padding: 0.125rem 0.25rem;
    font-size: 13px;
    line-height: 1;
    font-weight: 700;
    color: var(--color-blue-01);
  }

  .p-hero-section__blobs {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-end;
    gap: 0;
    margin-bottom: 0.25rem;
    margin-left: -0.125rem;
    font-size: 32px;
    font-weight: 700;
  }
  @media (--bp-sp-down) {
    .p-hero-section__blobs {
      font-size: 24px;
    }
  }


  .p-hero-section__blob {
    position: relative;
    display: inline-flex;
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    margin-right: -0.375rem;
    filter: drop-shadow(0 1px 0 rgba(0, 0, 0, 0.04));
  }
  @media (--bp-sp-down) {

  .p-hero-section__blob {
    width: 55px;
    height: 55px;
  }

  }

  .p-hero-section__blob:last-child {
    margin-right: 0;
  }

  .p-hero-section__blob-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .p-hero-section__blob-char {
    position: relative;
    transform: translateY(1px);
    font-size: 42px;
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 700;
    color: var(--color-pink-01);
  }

  .p-hero-section__heading-sub {
    margin: 0 0 1rem;
    white-space: nowrap;
    color: var(--color-black-03);
    font-size: 32px;
    line-height: 1.25;
    font-weight: 700;
  }
  @media (--bp-sp-down) {
    .p-hero-section__heading-sub {
      font-size: 28px;
    }
  }

  .p-hero-section__lead {
    color: var(--color-black-03);
    font-size: 18px;
    line-height: 1.4;
    font-weight: 700;
  }

  .p-hero-section__lead-line {
    margin: 0;
    white-space: nowrap;
  }

  .p-hero-section__visual {
    margin: 4rem auto 0;
    width: 100%;
    max-width: min(100%, 420px);
    flex-shrink: 0;
    z-index: 5;
  }

  @media (--bp-md-up) {
    .p-hero-section__blobs {
      gap: 0.125rem;
      margin-left: -0.25rem;
    }

    .p-hero-section__blob {
      margin-right: -0.5rem;
    }
  }

  @media (--bp-md-up) {
    .p-hero-section {
      --section-padding-block-start: var(--section-padding-block-start-default);
      --section-padding-block-end: var(--section-padding-block-end-default);

      min-height: 0;
    }

    .p-hero-section__inner {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .p-hero-section__copy {
      flex: 1;
      min-width: 0;
    }

    .p-hero-section__tags {
      margin-bottom: 1.5rem;
    }

    .p-hero-section__tag {
      padding: 4px 0.375rem;
      font-size: 1rem;
    }

    .p-hero-section__blobs {
      gap: 0.375rem;
      margin-left: -0.25rem;
      margin-bottom: 0.5rem;
    }

    .p-hero-section__blob {
      width: 4.75rem;
      height: 4.6rem;
      margin-right: -0.5rem;
    }

    .p-hero-section__blob-char {
      transform: translateY(0.125rem);
      font-size: 54px;
    }

    .p-hero-section__heading-sub {
      font-size: 40px;
    }

    .p-hero-section__lead {
      font-size: 26px;
      line-height: 1.5;
    }

    .p-hero-section__visual {
      margin: 0;
      width: min(380px, 40vw);
      max-width: 440px;
    }
  }

  @media (--bp-lg-up) {
    .p-hero-section__inner {
      gap: 2rem;
    }

    .p-hero-section__visual {
      width: min(420px, 38vw);
    }
  }
</style>
