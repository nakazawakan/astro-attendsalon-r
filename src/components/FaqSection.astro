---
import SectionHeading from './SectionHeading.astro';
import { faqsForHome } from '../data/faqs';
---
<section
  id="faq"
  class="l-section p-faq-section"
  data-reveal
>
  <div class="l-container">
      <SectionHeading label="FAQ" title="よくある質問" />
      <div class="p-faq-section__list">
        {
          faqsForHome.map(({ q, a, cta }) => (
            <details class="p-faq-section__item">
              <summary class="p-faq-section__summary">
                <span class="p-faq-section__question">{q}</span>
                <span
                  class="p-faq-section__chevron"
                  aria-hidden="true"
                >
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 20 20"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    class="p-faq-section__chevron-svg"
                  >
                    <path
                      d="M5 7.5L10 12.5L15 7.5"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </summary>
              <div
                class="p-faq-section__panel"
                data-faq-panel
              >
                <div class="p-faq-section__body">
                  <p>{a}</p>
                  {cta && (
                    <p class="p-faq-section__cta">
                      <a
                        href={cta.href}
                        class="p-faq-section__link"
                      >
                        {cta.label}
                      </a>
                    </p>
                  )}
                </div>
              </div>
            </details>
          ))
        }
      </div>
  </div>
</section>

<style>
  .p-faq-section {
    background: #fff;
  }

  .p-faq-section__list {
    display: flex;
    width: 100%;
    max-width: 740px;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0 auto;
  }

  @media (--bp-md-up) {
    .p-faq-section__list {
      gap: 1rem;
    }
  }

  .p-faq-section__item {
    /* box-shadow は高さが変わるたびに影の再トレースが走りカクつきの原因になるため border のみ */
    border-radius: 0.5rem;
    border: 1px solid var(--color-border-softer);
    background: #fff;
  }

  .p-faq-section__summary {
    display: flex;
    list-style: none;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem;
    cursor: pointer;
    font-family: var(--font-family-base);
    font-weight: 700;
    color: var(--color-black-03);
  }

  .p-faq-section__summary::-webkit-details-marker {
    display: none;
  }

  @media (--bp-md-up) {
    .p-faq-section__summary {
      padding: 1.25rem;
    }
  }

  .p-faq-section__question {
    min-width: 0;
    text-align: left;
    font-size: 1rem;
    line-height: 1.4;
  }

  @media (--bp-md-up) {
    .p-faq-section__question {
      font-size: 1.125rem;
    }
  }

  .p-faq-section__chevron {
    flex-shrink: 0;
    color: var(--color-pink-01);
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p-faq-section__chevron-svg {
    display: block;
  }

  /**
   * 開閉: 実測 scrollHeight への max-height 遷移のみ（0→正確px）
   * grid 0fr/1fr より WebKit で安定しやすい。JS は FaqSection 末尾スクリプト。
   */
  .p-faq-section__panel {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: auto;
  }

  .p-faq-section__panel.p-faq-section__panel--anim {
    will-change: max-height;
  }

  @media (prefers-reduced-motion: reduce) {
    .p-faq-section__panel,
    .p-faq-section__chevron {
      transition: none;
    }
  }

  .p-faq-section__body {
    box-sizing: border-box;
    overflow: hidden;
    border-top: 1px solid var(--color-border-softer);
    padding: 0.75rem 1rem 1rem;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    line-height: 1.625;
    color: var(--color-black-03);
  }

  @media (--bp-md-up) {
    .p-faq-section__body {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
      padding-bottom: 1.25rem;
      font-size: 1rem;
    }
  }

  .p-faq-section__body p {
    margin: 0;
  }

  .p-faq-section__body .p-faq-section__cta {
    margin: 0.75rem 0 0;
  }

  .p-faq-section__link {
    font-weight: 700;
    color: var(--color-pink-01);
    text-decoration: underline;
    text-decoration-color: rgba(251, 107, 106, 0.4);
    text-underline-offset: 4px;
    transition: opacity 0.2s ease;
  }

  .p-faq-section__link:hover {
    opacity: 0.85;
  }

  /**
   * 回転は [open] ではなく JS が付与する --expanded
   * （close 中も [open] は true のまま → アイコンだけ遅延していたのを防ぐ）
   */
  .p-faq-section__item.p-faq-section__item--expanded .p-faq-section__chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  const PANEL_DUR_MS = 600;

  function cancelPanelInFlight(panel: HTMLElement) {
    try {
      panel.getAnimations?.().forEach((a) => a.cancel());
    } catch {
      /* ignore */
    }
  }

  document.querySelectorAll<HTMLDetailsElement>('.p-faq-section__item').forEach((details) => {
    const summary = details.querySelector<HTMLElement>('.p-faq-section__summary')!;
    const panel   = details.querySelector<HTMLElement>('[data-faq-panel]')!;

    let   opSeq     = 0;
    let   closeTmr: ReturnType<typeof setTimeout> | null = null;

    const prefersReduced = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const endAnimHint = () => {
      panel.classList.remove('p-faq-section__panel--anim');
    };

    const clearCloseFallback = () => {
      if (closeTmr != null) {
        clearTimeout(closeTmr);
        closeTmr = null;
      }
    };

    const finishClose = (myClose: number) => {
      if (myClose !== opSeq) return;
      if (!details.classList.contains('p-faq-section__item--closing')) return;
      clearCloseFallback();
      details.open = false;
      panel.removeAttribute('style');
      details.classList.remove('p-faq-section__item--closing');
      endAnimHint();
    };

    const startClose = () => {
      const myClose = ++opSeq;
      cancelPanelInFlight(panel);
      clearCloseFallback();
      /* 遅延する transitionend や未発火向け: 前の id は finish で弾かれる */
      details.classList.remove('p-faq-section__item--expanded');
      details.classList.add('p-faq-section__item--closing');

      const h = Math.ceil(panel.scrollHeight);
      panel.style.maxHeight = `${h}px`;
      void panel.offsetHeight;
      panel.classList.add('p-faq-section__panel--anim');
      panel.style.maxHeight = '0px';

      const onEnd = (ev: Event) => {
        const t = ev as TransitionEvent;
        if (t.target !== panel) return;
        if (t.propertyName !== 'max-height') return;
        if (myClose !== opSeq) return;
        finishClose(myClose);
      };
      panel.addEventListener('transitionend', onEnd, { once: true });

      closeTmr = setTimeout(() => {
        closeTmr = null;
        finishClose(myClose);
      }, PANEL_DUR_MS);
    };

    const runOpen = () => {
      const myOpen = ++opSeq;
      cancelPanelInFlight(panel);
      clearCloseFallback();

      details.classList.remove('p-faq-section__item--closing');
      details.open = true;
      details.classList.add('p-faq-section__item--expanded');
      panel.style.maxHeight = '0px';
      void panel.offsetHeight;

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (myOpen !== opSeq) return;
          const bodyEl = panel.querySelector<HTMLElement>('.p-faq-section__body');
          let   h = Math.ceil(panel.scrollHeight);
          if (h < 1 && bodyEl) {
            h = Math.ceil(bodyEl.getBoundingClientRect().height);
          }
          h += 1;
          if (myOpen !== opSeq) return;
          panel.classList.add('p-faq-section__panel--anim');
          panel.style.maxHeight = `${h}px`;

          const onEnd = (ev: Event) => {
            const t = ev as TransitionEvent;
            if (t.target !== panel) return;
            if (t.propertyName !== 'max-height') return;
            if (myOpen !== opSeq) return;
            panel.style.maxHeight = 'none';
            endAnimHint();
          };
          panel.addEventListener('transitionend', onEnd, { once: true });
        });
      });
    };

    summary.addEventListener('click', (e) => {
      e.preventDefault();

      if (prefersReduced()) {
        if (details.open) {
          details.classList.remove('p-faq-section__item--expanded', 'p-faq-section__item--closing');
          details.open = false;
          panel.removeAttribute('style');
        } else {
          details.open = true;
          details.classList.add('p-faq-section__item--expanded');
          panel.removeAttribute('style');
        }
        endAnimHint();
        clearCloseFallback();
        return;
      }

      /* 閉じアニメ中のクリック: 同じ要約行は「戻る」= すぐ再展開 */
      if (details.classList.contains('p-faq-section__item--closing')) {
        runOpen();
        return;
      }

      if (details.open) {
        startClose();
        return;
      }
      runOpen();
    });
  });
</script>
