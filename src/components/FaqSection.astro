---
import SectionHeading from './SectionHeading.astro';
import { faqs } from '../data/faqs';
---
<section
  id="faq"
  class="bg-bg-warm pt-[130px] pb-[80px]"
  data-reveal
>
  <div class="mx-auto w-full min-w-0 max-w-pageShell px-6">
    <div class="mx-auto w-full min-w-0 max-w-page">
      <SectionHeading label="FAQ" title="よくある質問" />
      <div class="flex flex-col gap-3 md:gap-4">
        {
          faqs.map(({ q, a, cta }) => (
            <details class="group rounded-lg border border-border-softer bg-white shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-3 p-4 font-zen font-bold text-black-03 md:p-5 [&::-webkit-details-marker]:hidden">
                <span class="min-w-0 text-left text-base md:text-lg">{q}</span>
                <span
                  class="faq-chevron shrink-0 text-pink-01 transition-transform duration-200"
                  aria-hidden="true"
                >
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 20 20"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    class="block"
                  >
                    <path
                      d="M5 7.5L10 12.5L15 7.5"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </summary>
              <div class="border-t border-border-softer px-4 pb-4 pt-3 font-zen text-sm leading-relaxed text-black-05 md:px-5 md:pb-5 md:text-base">
                <p>{a}</p>
                {cta && (
                  <p class="mt-3">
                    <a
                      href={cta.href}
                      class="font-bold text-pink-01 underline decoration-pink-01/40 underline-offset-4 transition-opacity hover:opacity-85"
                    >
                      {cta.label}
                    </a>
                  </p>
                )}
              </div>
            </details>
          ))
        }
      </div>
      <p class="mt-8 flex flex-col items-center gap-4 text-center sm:flex-row sm:justify-center sm:gap-6">
        <a
          href="/faq/"
          class="inline-flex items-center justify-center rounded-full border-2 border-pink-01 bg-transparent px-6 py-3 font-zen text-sm font-bold text-pink-01 transition-opacity hover:opacity-85"
        >
          よくある質問一覧へ
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center rounded-full bg-pink-01 px-6 py-3 font-zen text-sm font-bold text-white transition-opacity hover:opacity-90"
        >
          お問い合わせ
        </a>
      </p>
    </div>
  </div>
</section>

<style>
  details[open] .faq-chevron {
    transform: rotate(180deg);
  }
</style>
