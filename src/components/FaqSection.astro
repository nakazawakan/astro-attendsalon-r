---
import SectionHeading from './SectionHeading.astro';
import { faqs } from '../data/faqs';
---
<section
  id="faq"
  class="p-faq"
  data-reveal
>
  <div class="l-page-shell">
    <div class="l-page-inner">
      <SectionHeading label="FAQ" title="よくある質問" />
      <div class="p-faq__list">
        {
          faqs.map(({ q, a, cta }) => (
            <details class="p-faq__item">
              <summary class="p-faq__summary">
                <span class="p-faq__question">{q}</span>
                <span
                  class="p-faq__chevron"
                  aria-hidden="true"
                >
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 20 20"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    class="p-faq__chevron-svg"
                  >
                    <path
                      d="M5 7.5L10 12.5L15 7.5"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </summary>
              <div class="p-faq__body">
                <p>{a}</p>
                {cta && (
                  <p class="p-faq__cta">
                    <a
                      href={cta.href}
                      class="p-faq__link"
                    >
                      {cta.label}
                    </a>
                  </p>
                )}
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .p-faq {
    background: var(--color-bg-warm);
    padding-top: 130px;
    padding-bottom: 80px;
  }

  .p-faq__list {
    display: flex;
    width: 100%;
    max-width: 740px;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .p-faq__list {
      gap: 1rem;
    }
  }

  .p-faq__item {
    border-radius: 0.5rem;
    border: 1px solid var(--color-border-softer);
    background: #fff;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  }

  .p-faq__summary {
    display: flex;
    list-style: none;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem;
    cursor: pointer;
    font-family: var(--font-family-base);
    font-weight: 700;
    color: var(--color-black-03);
  }

  .p-faq__summary::-webkit-details-marker {
    display: none;
  }

  @media (min-width: 768px) {
    .p-faq__summary {
      padding: 1.25rem;
    }
  }

  .p-faq__question {
    min-width: 0;
    text-align: left;
    font-size: 1rem;
  }

  @media (min-width: 768px) {
    .p-faq__question {
      font-size: 1.125rem;
    }
  }

  .p-faq__chevron {
    flex-shrink: 0;
    color: var(--color-pink-01);
    transition: transform 0.2s ease;
  }

  .p-faq__chevron-svg {
    display: block;
  }

  .p-faq__body {
    box-sizing: border-box;
    border-top: 1px solid var(--color-border-softer);
    padding: 0.75rem 1rem 1rem;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    line-height: 1.625;
    color: var(--color-black-03);
  }

  @media (min-width: 768px) {
    .p-faq__body {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
      padding-bottom: 1.25rem;
      font-size: 1rem;
    }
  }

  .p-faq__body p {
    margin: 0;
  }

  .p-faq__body .p-faq__cta {
    margin: 0.75rem 0 0;
  }

  .p-faq__link {
    font-weight: 700;
    color: var(--color-pink-01);
    text-decoration: underline;
    text-decoration-color: rgba(251, 107, 106, 0.4);
    text-underline-offset: 4px;
    transition: opacity 0.2s ease;
  }

  .p-faq__link:hover {
    opacity: 0.85;
  }

  details[open] .p-faq__chevron {
    transform: rotate(180deg);
  }
</style>
