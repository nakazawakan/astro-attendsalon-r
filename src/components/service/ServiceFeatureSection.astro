---
import NoImagePlaceholder from '../NoImagePlaceholder.astro';
import SectionHeading from '../SectionHeading.astro';

export interface ServiceFeatureItem {
  layout: 'image-left' | 'image-right';
  num: string;
  title: string;
  body: string;
}

interface Props {
  id: string;
  label: string;
  title: string;
  intro: string;
  features: ServiceFeatureItem[];
}

const { id, label, title, intro, features } = Astro.props;
---

<section id="features" class="l-section p-feature-section p-service-feature-section" data-reveal>
  <div class="p-feature-section__bg-haze" aria-hidden="true"></div>
  <div class="l-container">
    <SectionHeading label={label} title={title} id={id} bottomMarginStyle="content">
      <p slot="intro">{intro}</p>
    </SectionHeading>

    <div class="l-stack l-stack--wide p-feature-section__list">
      {
        features.map(({ layout, num, title: itemTitle, body }) => (
          <div
            class:list={[
              'p-feature-section__item',
              layout === 'image-left' ? 'p-feature-section__item--image-left' : 'p-feature-section__item--image-right',
            ]}
          >
            <div class="p-feature-section__media">
              <NoImagePlaceholder />
            </div>
            <article class="p-feature-section__card">
              <div class="p-feature-section__card-head">
                <h3 class="p-feature-section__title">{itemTitle}</h3>
                <p class="p-feature-section__num" aria-hidden="true">
                  {num}
                </p>
              </div>
              <p class="p-feature-section__body">{body}</p>
            </article>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* `FeatureSection.astro` と同一の見た目（研修サービス下位ページ用に props 化） */
  .p-service-feature-section.p-feature-section {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background:
      linear-gradient(
        180deg,
        #fefcf9 0%,
        #fdfaf4 52%,
        #fcf8f1 100%
      );
  }

  .p-service-feature-section .p-feature-section__bg-haze {
    position: absolute;
    inset: -10% -6%;
    z-index: var(--z-section-bg, 0);
    pointer-events: none;
    background:
      radial-gradient(
        138% 96% at 10% -6%,
        rgb(251 107 106 / 0.02) 0%,
        rgb(251 107 106 / 0.006) 34%,
        rgb(251 107 106 / 0) 72%
      ),
      radial-gradient(
        132% 92% at 92% 6%,
        rgb(127 154 168 / 0.018) 0%,
        rgb(127 154 168 / 0.005) 38%,
        rgb(127 154 168 / 0) 74%
      );
    transform: translate3d(0, 0, 0) scale(1.02);
  }

  .p-service-feature-section.is-visible .p-feature-section__bg-haze {
    animation: p-service-feature-section-bg-sway 10s ease-in-out infinite alternate;
  }

  .p-service-feature-section > .l-container {
    position: relative;
    z-index: var(--z-section-content, 3);
  }

  @keyframes p-service-feature-section-bg-sway {
    0% {
      transform: translate3d(-1.2%, -0.6%, 0) scale(1.02) rotate(-0.25deg);
    }

    50% {
      transform: translate3d(0.8%, 0.7%, 0) scale(1.035) rotate(0.22deg);
    }

    100% {
      transform: translate3d(-0.5%, 1%, 0) scale(1.03) rotate(-0.12deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .p-service-feature-section.is-visible .p-feature-section__bg-haze {
      animation: none;
      transform: none;
    }
  }

  .p-service-feature-section .p-feature-section__item {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .p-service-feature-section .p-feature-section__media {
    display: flex;
    flex-direction: column;
    width: 100%;
    flex-shrink: 0;
    min-height: 200px;
  }

  .p-service-feature-section .p-feature-section__media :global(.c-no-image-placeholder) {
    box-sizing: border-box;
    flex: 1 1 auto;
    width: 100%;
    min-height: 200px;
  }

  .p-service-feature-section .p-feature-section__card {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1rem;
    border-radius: 0 0 0.5rem 0.5rem;
    background: #fff;
    box-shadow: var(--shadow-soft);
  }

  .p-service-feature-section .p-feature-section__card-head {
    display: flex;
    width: 100%;
    align-items: flex-start;
    justify-content: flex-end;
    gap: 1rem;
    flex-direction: row-reverse;
    text-align: left;
    color: var(--color-pink-01);
  }

  .p-service-feature-section .p-feature-section__title {
    margin: 0;
    min-width: 0;
    flex-shrink: 1;
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 700;
    text-align: left;
  }

  .p-service-feature-section .p-feature-section__num {
    margin: 0;
    flex-shrink: 0;
    font-size: 2rem;
    line-height: 1;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    font-family: "Lato", sans-serif;
  }

  .p-service-feature-section .p-feature-section__body {
    width: 100%;
    margin: 0;
    color: var(--color-black-03);
    font-size: 0.875rem;
    line-height: var(--line-height-base);
    font-weight: 500;
  }

  @media (--bp-md-up) {
    .p-service-feature-section .p-feature-section__item {
      gap: 1.5rem;
      align-items: stretch;
    }

    .p-service-feature-section .p-feature-section__item--image-left {
      flex-direction: row;
    }

    .p-service-feature-section .p-feature-section__item--image-right {
      flex-direction: row-reverse;
    }

    .p-service-feature-section .p-feature-section__media {
      width: 420px;
      max-width: 48%;
      min-height: 275px;
    }

    .p-service-feature-section .p-feature-section__media :global(.c-no-image-placeholder) {
      min-height: 275px;
    }

    .p-service-feature-section .p-feature-section__card {
      gap: 1.5rem;
      padding: 2.5rem;
      border-radius: 0.5rem;
    }

    .p-service-feature-section .p-feature-section__card-head {
      flex-direction: row;
      justify-content: space-between;
      text-align: center;
    }

    .p-service-feature-section .p-feature-section__title {
      font-size: 1.5rem;
    }

    .p-service-feature-section .p-feature-section__num {
      font-size: 40px;
    }

    .p-service-feature-section .p-feature-section__body {
      font-size: 0.9375rem;
      line-height: 1.6;
      font-weight: 400;
    }
  }
</style>
