---
import NoImagePlaceholder from '../NoImagePlaceholder.astro';
import SectionHeading from '../SectionHeading.astro';
import SectionMarkDecor from '../SectionMarkDecor.astro';

export interface ServiceFeatureItem {
  num: string;
  title: string;
  body: string;
  imageSrc?: string;
  imageAlt?: string;
}

interface Props {
  id: string;
  label: string;
  title: string;
  intro: string;
  features: ServiceFeatureItem[];
}

const { id, label, title, intro, features } = Astro.props;
---

<section id="features" class="l-section p-feature-section p-service-feature-section" data-reveal>
  <div class="l-wave l-wave--top l-wave--pattern-gentle-a" aria-hidden="true"></div>
  <SectionMarkDecor anchor="tl" variant="feature" />
  <div class="p-feature-section__bg-haze" aria-hidden="true"></div>
  <div class="l-container">
    <SectionHeading label={label} title={title} id={id} bottomMarginStyle="content">
      <p slot="intro">{intro}</p>
    </SectionHeading>

    <div class="p-feature-section__list">
      {
        features.map(({ num, title: itemTitle, body, imageSrc, imageAlt }) => (
          <div class="p-feature-section__item">
            <p class="p-feature-section__num" aria-hidden="true">
              {num}
            </p>
            <article class="p-feature-section__card">
              <h3 class="p-feature-section__title">
                {itemTitle}
              </h3>
              <div class="p-feature-section__media">
                {imageSrc ? (
                  <img
                    class="p-feature-section__image"
                    src={imageSrc}
                    alt={imageAlt ?? ''}
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <NoImagePlaceholder />
                )}
              </div>
              <p class="p-feature-section__body">{body}</p>
            </article>
          </div>
        ))
      }
    </div>
  </div>
  <div class="l-wave l-wave--bottom l-wave--pattern-gentle-b" aria-hidden="true"></div>
</section>

<style>
  /* `FeatureSection.astro` と同一の見た目（研修サービス下位ページ用に props 化） */
  .p-service-feature-section.p-feature-section {
    --feature-media-aspect: 3 / 2;
    --wave-height: 40px;
    --wave-mask-gentle-a: url("data:image/svg+xml,%3Csvg viewBox='0 0 912 62' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 14 C90 -2 180 -2 270 14 C360 30 450 30 540 14 C630 -2 720 -2 810 14 C844 20 878 20 912 14 L912 62 L0 62 Z' fill='black'/%3E%3C/svg%3E");
    --wave-mask-gentle-b: url("data:image/svg+xml,%3Csvg viewBox='0 0 912 62' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 16 C118 0 236 0 354 16 C442 31 530 31 618 16 C716 0 814 0 912 12 L912 62 L0 62 Z' fill='black'/%3E%3C/svg%3E");
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding-top: calc(var(--section-padding-block-start, var(--section-padding-block-start-default)) + var(--wave-height));
    padding-bottom: calc(var(--section-padding-block-end, var(--section-padding-block-end-default)) + var(--wave-height));
    background:
      linear-gradient(
        180deg,
        #fefcf9 0%,
        #fdfaf4 52%,
        #fcf8f1 100%
      );
  }

  .p-service-feature-section .p-feature-section__bg-haze {
    position: absolute;
    inset: -10% -6%;
    z-index: var(--z-section-bg, 0);
    pointer-events: none;
    background:
      radial-gradient(
        138% 96% at 10% -6%,
        rgb(251 107 106 / 0.02) 0%,
        rgb(251 107 106 / 0.006) 34%,
        rgb(251 107 106 / 0) 72%
      ),
      radial-gradient(
        132% 92% at 92% 6%,
        rgb(127 154 168 / 0.018) 0%,
        rgb(127 154 168 / 0.005) 38%,
        rgb(127 154 168 / 0) 74%
      );
    transform: translate3d(0, 0, 0) scale(1.02);
  }

  .p-service-feature-section.is-visible .p-feature-section__bg-haze {
    animation: p-service-feature-section-bg-sway 10s ease-in-out infinite alternate;
  }

  .p-service-feature-section > .l-container {
    position: relative;
    z-index: var(--z-section-content, 3);
  }

  @keyframes p-service-feature-section-bg-sway {
    0% {
      transform: translate3d(-1.2%, -0.6%, 0) scale(1.02) rotate(-0.25deg);
    }

    50% {
      transform: translate3d(0.8%, 0.7%, 0) scale(1.035) rotate(0.22deg);
    }

    100% {
      transform: translate3d(-0.5%, 1%, 0) scale(1.03) rotate(-0.12deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .p-service-feature-section.is-visible .p-feature-section__bg-haze {
      animation: none;
      transform: none;
    }
  }

  .p-service-feature-section .p-feature-section__list {
    display: flex;
    flex-direction: column;
    gap: var(--stack-gap-wide, 2.5rem);
  }

  .p-service-feature-section .p-feature-section__list > * {
    min-width: 0;
  }

  .p-service-feature-section .p-feature-section__item {
    position: relative;
    min-width: 0;
    overflow: visible;
  }

  .p-service-feature-section .p-feature-section__media {
    position: relative;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    flex-shrink: 0;
    aspect-ratio: var(--feature-media-aspect);
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .p-service-feature-section .p-feature-section__media :global(.c-no-image-placeholder) {
    position: absolute;
    inset: 0;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    min-height: 0;
    border-radius: 0;
  }

  .p-service-feature-section .p-feature-section__image {
    box-sizing: border-box;
    display: block;
    width: auto;
    height: auto;
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    object-position: center;
  }

  .p-service-feature-section .p-feature-section__card {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    min-width: 0;
    height: 100%;
    padding: 1rem;
    border-radius: 0.5rem;
    background: #fff;
    box-shadow: var(--shadow-soft);
  }

  .p-service-feature-section .p-feature-section__title {
    margin: 0;
    min-width: 0;
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 700;
    text-align: center;
  }

  .p-service-feature-section .p-feature-section__num {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    margin: 0;
    color: var(--color-pink-01);
    font-size: 2rem;
    line-height: 1;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    font-family: "Lato", sans-serif;
    pointer-events: none;
    transform: translate(-28%, -52%);
  }

  .p-service-feature-section .p-feature-section__body {
    width: 100%;
    margin: 0;
    color: var(--color-black-03);
    font-size: 0.875rem;
    line-height: var(--line-height-base);
    font-weight: 500;
  }

  @media (--bp-md-up) {
    .p-service-feature-section.p-feature-section {
      --wave-height: 62px;
    }

    .p-service-feature-section .p-feature-section__list {
      flex-direction: row;
      align-items: stretch;
      gap: var(--stack-gap-wide-md, 3rem);
    }

    .p-service-feature-section .p-feature-section__item {
      flex: 1;
    }

    .p-service-feature-section .p-feature-section__card {
      gap: 0.5rem;
      padding: 1.5rem;
    }

    .p-service-feature-section .p-feature-section__num {
      font-size: 40px;
    }

    .p-service-feature-section .p-feature-section__body {
      font-size: 0.9375rem;
      line-height: 1.6;
      font-weight: 400;
    }
  }
</style>
