---
import ServiceSectionBlock from './ServiceSectionBlock.astro';
import type { ServiceSectionBackground } from './ServiceSectionBlock.astro';

interface Props {
  id: string;
  worries: string[];
  lead: string;
  paragraphs: string[];
  label?: string;
  title?: string;
  background?: ServiceSectionBackground;
}

const {
  id,
  worries,
  lead,
  paragraphs,
  label = 'WORRIES',
  title = '職場でこんな「困った」は\nありませんか？',
  background = 'gray',
} = Astro.props;
---

<ServiceSectionBlock
  id={id}
  label={label}
  title={title}
  background={background}
  withBottomMargin
>
  <div class="l-stack p-service-worries">
    <ul class="p-service-worries__list">
      {worries.map((worry) => <li>{worry}</li>)}
    </ul>
    <div class="l-stack p-service-worries__body">
      <p class="p-service-worries__lead">{lead}</p>
      {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
</ServiceSectionBlock>

<style>
  .p-service-worries {
    --stack-gap: 1.25rem;
  }

  .p-service-worries__list {
    margin: 0;
    padding: 1.125rem 1.125rem 1.125rem 2.4rem;
    border-radius: 14px;
    background: #fff;
    border: 1px solid var(--color-border-soft);
    display: grid;
    gap: 0.75rem;
    color: var(--color-black-03);
    font-size: 0.95rem;
    line-height: var(--line-height-base);
    font-weight: 500;
  }

  .p-service-worries__body {
    --stack-gap: 0.9rem;
    color: var(--color-black-03);
    line-height: var(--line-height-base);
    font-size: 0.95rem;
  }

  .p-service-worries__body p {
    margin: 0;
  }

  .p-service-worries__lead {
    color: var(--color-pink-01);
    font-weight: 700;
    font-size: 1.2em;
  }

  :global(h2[id$='-worries-title']) {
    white-space: pre-line;
  }

  @media (--bp-md-up) {
    :global(h2[id$='-worries-title']) {
      white-space: normal;
    }

    .p-service-worries {
      --stack-gap: 1.5rem;
    }

    .p-service-worries__list {
      padding: 1.25rem 1.25rem 1.25rem 2.65rem;
      font-size: 1rem;
    }

    .p-service-worries__body {
      font-size: 1rem;
    }
  }
</style>
