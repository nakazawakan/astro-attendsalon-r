---
import ServiceSectionBlock from './ServiceSectionBlock.astro';
import type { ServiceSectionBackground } from './ServiceSectionBlock.astro';

interface Props {
  id: string;
  worries: string[];
  lead: string;
  label?: string;
  title?: string;
  background?: ServiceSectionBackground;
}

const {
  id,
  worries,
  lead,
  label = 'WORRIES',
  title = '職場でこんな「困った」は\nありませんか？',
  background = 'gray',
} = Astro.props;

/** 各サービスページの worryLead は「アテンドサロンRは、」で始まる想定 */
const leadBrandName = 'アテンドサロンR';
const leadBrandPrefix = `${leadBrandName}は、`;
const hasLeadBrandPrefix = lead.startsWith(leadBrandPrefix);
const leadBody = hasLeadBrandPrefix ? lead.slice(leadBrandPrefix.length) : lead;
---

<ServiceSectionBlock
  id={id}
  label={label}
  title={title}
  background={background}
  withBottomMargin
>
  <div class="p-service-worries">
    <ul class="p-service-worries__list">
      {worries.map((worry) => <li>{worry}</li>)}
    </ul>
    <div class="p-service-worries__arrow" aria-hidden="true">
      <svg
        class="p-service-worries__arrow-icon"
        width="32"
        height="37"
        viewBox="0 0 24 28"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M7 5 L7 23 L19 14 Z"
          fill="currentColor"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linejoin="round"></path>
      </svg>
    </div>
    <div class="p-service-worries__solution" role="note">
      <p class="p-service-worries__lead">
        {
          hasLeadBrandPrefix ? (
            <>
              <span class="p-service-worries__lead-brand">
                <span class="p-service-worries__lead-brand-text">{leadBrandName}</span>
                は、
              </span>
              {leadBody}
            </>
          ) : (
            lead
          )
        }
      </p>
    </div>
  </div>
</ServiceSectionBlock>

<style>
  .p-service-worries {
    display: grid;
    gap: 1.25rem;
    align-items: stretch;
    grid-template-columns: minmax(0, 1fr);
  }

  .p-service-worries__arrow {
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--color-pink-01);
  }

  .p-service-worries__arrow-icon {
    display: block;
    width: 2rem;
    height: 2.35rem;
    transform: rotate(90deg);
  }

  .p-service-worries__list {
    margin: 0;
    padding: 1.125rem 1.125rem 1.125rem 2.4rem;
    border-radius: 14px;
    background: #fff;
    border: 1px solid var(--color-border-soft);
    display: grid;
    gap: 0.75rem;
    color: var(--color-black-03);
    font-size: 0.95rem;
    line-height: var(--line-height-base);
    font-weight: 500;
  }

  .p-service-worries__solution {
    position: relative;
    margin: 0;
    padding: 1.125rem 1.125rem 1.125rem 1.25rem;
    border-radius: 14px;
    border: 1px solid var(--color-border-soft);
    background: var(--color-bg-warm);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }


  .p-service-worries__lead {
    position: relative;
    z-index: 1;
    margin: 0;
    color: var(--color-black-03);
    font-size: 0.95rem;
    line-height: 1.75;
    font-weight: 700;
  }

  .p-service-worries__lead-brand {
    display: inline;
    white-space: nowrap;
  }

  .p-service-worries__lead-brand-text {
    position: relative;
    z-index: 0;
    color: var(--color-black-03);
  }

  .p-service-worries__lead-brand-text::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.1em;
    z-index: -1;
    height: 0.55em;
    border-radius: 0.125rem;
    background: #ffddd2;
  }

  :global(h2[id$='-worries-title']) {
    white-space: pre-line;
  }

  @media (--bp-md-up) {
    :global(h2[id$='-worries-title']) {
      white-space: normal;
    }

    .p-service-worries {
      gap: 1.5rem;
      align-items: center;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    }

    .p-service-worries__arrow-icon {
      transform: none;
    }

    .p-service-worries__list {
      padding: 1.25rem 1.25rem 1.25rem 2.65rem;
      font-size: 1rem;
    }

    .p-service-worries__solution {
      padding: 1.25rem 1.375rem 1.25rem 1.5rem;
    }

    .p-service-worries__lead {
      font-size: 1rem;
    }
  }
</style>
