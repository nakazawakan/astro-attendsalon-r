---
export interface ServiceStepItem {
  title: string;
}

export interface ServiceSyllabusCard {
  tag: string;
  title: string;
  bullets: string[];
}

export interface ServiceSyllabusGroup {
  heading: string;
  cards: ServiceSyllabusCard[];
}

interface Props {
  idPrefix: string;
  stepsSectionTitle: string;
  steps: ServiceStepItem[];
  syllabusSectionTitle: string;
  syllabusGroups: ServiceSyllabusGroup[];
}

const { idPrefix, stepsSectionTitle, steps, syllabusSectionTitle, syllabusGroups } = Astro.props;

const stepLabel = (index: number) => `STEP ${String(index + 1).padStart(2, '0')}`;
const stepsHeadingId = `${idPrefix}-steps-heading`;
const syllabusHeadingId = `${idPrefix}-syllabus-heading`;
const syllabusGroupHeadingId = (index: number) => `${idPrefix}-syllabus-group-${index + 1}`;
const syllabusTabId = (index: number) => `${idPrefix}-syllabus-tab-${index + 1}`;
const syllabusPanelId = (index: number) => `${idPrefix}-syllabus-panel-${index + 1}`;
---

<div class="p-service-subheading-cards">
  <section class="p-service-subheading-cards__section" aria-labelledby={stepsHeadingId}>
    <h3 class="c-section-subheading" id={stepsHeadingId}>
      {stepsSectionTitle}
    </h3>
    <ol class="p-service-subheading-cards__steps">
      {
        steps.map((item, index) => (
          <li class="p-service-subheading-cards__step">
            <span class="p-service-subheading-cards__step-label" aria-hidden="true">
              {stepLabel(index)}
            </span>
            <span class="p-service-subheading-cards__step-title">{item.title}</span>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="p-service-subheading-cards__section" aria-labelledby={syllabusHeadingId}>
    <h3 class="c-section-subheading" id={syllabusHeadingId}>
      {syllabusSectionTitle}
    </h3>
    <div class="p-service-subheading-cards__tabs" data-syllabus-tabs>
      <div class="p-service-subheading-cards__tab-list" role="tablist" aria-label={`${syllabusSectionTitle}の対象者`}>
        {
          syllabusGroups.map((group, groupIndex) => (
            <button
              type="button"
              id={syllabusTabId(groupIndex)}
              class:list={['p-service-subheading-cards__tab', groupIndex === 0 && 'is-active']}
              role="tab"
              aria-selected={groupIndex === 0 ? 'true' : 'false'}
              aria-controls={syllabusPanelId(groupIndex)}
              tabindex={groupIndex === 0 ? 0 : -1}
              data-syllabus-tab
            >
              {group.heading}
            </button>
          ))
        }
      </div>
      <div class="p-service-subheading-cards__groups">
        {
          syllabusGroups.map((group, groupIndex) => (
            <section
              class="p-service-subheading-cards__group"
              id={syllabusPanelId(groupIndex)}
              role="tabpanel"
              aria-labelledby={syllabusTabId(groupIndex)}
              tabindex="0"
              hidden={groupIndex > 0}
              data-syllabus-panel
            >
              <h4 class="u-visually-hidden" id={syllabusGroupHeadingId(groupIndex)}>
                {group.heading}
              </h4>
              <div class="p-service-subheading-cards__syllabus">
                {group.cards.map((card) => (
                  <article class="p-service-subheading-cards__card">
                    <p class="p-service-subheading-cards__tag">{card.tag}</p>
                    <div class="p-service-subheading-cards__card-body">
                      <h5 class="p-service-subheading-cards__card-title">{card.title}</h5>
                      <ul class="p-service-subheading-cards__bullets">
                        {card.bullets.map((bullet) => (
                          <li>{bullet}</li>
                        ))}
                      </ul>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>
</div>

<script>
  const tabRoots = document.querySelectorAll<HTMLElement>('[data-syllabus-tabs]');

  tabRoots.forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-syllabus-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-syllabus-panel]'));

    const activateTab = (nextTab: HTMLButtonElement, shouldFocus = false) => {
      tabs.forEach((tab, index) => {
        const isSelected = tab === nextTab;
        tab.setAttribute('aria-selected', String(isSelected));
        tab.tabIndex = isSelected ? 0 : -1;
        tab.classList.toggle('is-active', isSelected);

        if (panels[index]) {
          panels[index].hidden = !isSelected;
        }
      });
      panels.slice(tabs.length).forEach((panel) => {
        panel.hidden = true;
      });

      if (shouldFocus) {
        nextTab.focus();
      }
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => activateTab(tab));
      tab.addEventListener('keydown', (event) => {
        const lastIndex = tabs.length - 1;
        let nextIndex = index;

        if (event.key === 'ArrowRight') {
          nextIndex = index === lastIndex ? 0 : index + 1;
        } else if (event.key === 'ArrowLeft') {
          nextIndex = index === 0 ? lastIndex : index - 1;
        } else if (event.key === 'Home') {
          nextIndex = 0;
        } else if (event.key === 'End') {
          nextIndex = lastIndex;
        } else {
          return;
        }

        event.preventDefault();
        const nextTab = tabs[nextIndex];
        if (nextTab) {
          activateTab(nextTab, true);
        }
      });
    });

    const selectedTab = tabs.find((tab) => tab.getAttribute('aria-selected') === 'true') ?? tabs[0];
    if (selectedTab) {
      activateTab(selectedTab);
    }
  });
</script>

<noscript>
  <style>
    .p-service-subheading-cards__tab-list {
      display: none !important;
    }

    .p-service-subheading-cards__group[hidden] {
      display: block;
    }

    .p-service-subheading-cards__tabs .u-visually-hidden {
      position: static;
      width: auto;
      height: auto;
      margin: 0 0 0.75rem;
      overflow: visible;
      clip: auto;
      white-space: normal;
    }
  </style>
</noscript>

<style>
  .p-service-subheading-cards {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-top: 1.75rem;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards {
      gap: 3rem;
      margin-top: 2rem;
    }
  }

  .p-service-subheading-cards__section {
    margin: 0;
  }

  /* --- 3 steps --- */
  .p-service-subheading-cards__steps {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__steps {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  .p-service-subheading-cards__step {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
    border: 1px solid var(--color-border-soft);
    border-radius: 8px;
    background: #fff;
    padding: 1rem 1.125rem;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__step {
      padding: 1.125rem 1.25rem;
    }
  }

  .p-service-subheading-cards__step-label {
    color: var(--color-blue-01);
    font-family: Lato, sans-serif;
    font-size: 0.8125rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    line-height: 1.2;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__step-label {
      font-size: 0.875rem;
    }
  }

  .p-service-subheading-cards__step-title {
    color: var(--color-black-03);
    font-family: var(--font-family-base);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.6;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__step-title {
      font-size: 1.0625rem;
    }
  }

  /* --- syllabus tabs --- */
  .p-service-subheading-cards__tabs {
    display: grid;
    gap: 1.25rem;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__tabs {
      gap: 1.5rem;
    }
  }

  .p-service-subheading-cards__tab-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
    width: min(100%, 30rem);
    margin-inline: auto;
  }

  .p-service-subheading-cards__tab {
    margin: 0;
    border: 1px solid var(--color-pink-01);
    border-radius: var(--radius-full);
    background: #fff;
    padding: 0.75rem 1rem;
    color: var(--color-black-03);
    font-family: var(--font-family-base);
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.4;
    text-align: center;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .p-service-subheading-cards__tab:hover:not(.is-active) {
    background: var(--color-bg-warm);
  }

  .p-service-subheading-cards__tab:focus-visible {
    outline: 2px solid var(--color-blue-01);
    outline-offset: 2px;
  }

  .p-service-subheading-cards__tab.is-active {
    border-color: var(--color-pink-01);
    background: var(--color-pink-01);
    color: #fff;
    box-shadow: none;
  }

  .p-service-subheading-cards__groups {
    display: block;
  }

  .p-service-subheading-cards__group {
    position: relative;
    margin: 0;
    border: 1px solid var(--color-border-soft);
    border-radius: 1rem;
    background: linear-gradient(155deg, var(--color-surface-01) 0%, #fff 62%);
    padding: 1rem;
    overflow: clip;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__group {
      padding: 1.25rem;
    }
  }

  .p-service-subheading-cards__group::before,
  .p-service-subheading-cards__group::after {
    content: '';
    position: absolute;
    border-radius: var(--radius-full);
    pointer-events: none;
    opacity: 0.42;
  }

  .p-service-subheading-cards__group::before {
    top: -1.75rem;
    right: -1.5rem;
    width: 7.5rem;
    height: 7.5rem;
    background: var(--color-surface-blue-soft);
  }

  .p-service-subheading-cards__group::after {
    bottom: -2.25rem;
    left: -2rem;
    width: 6.25rem;
    height: 6.25rem;
    background: var(--color-pink-03);
  }

  .p-service-subheading-cards__group:focus-visible {
    outline: 2px solid var(--color-pink-01);
    outline-offset: 0.25rem;
  }

  .p-service-subheading-cards__syllabus {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.875rem;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__syllabus {
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 13.75rem), 1fr));
      gap: 1rem;
      align-items: stretch;
    }
  }

  .p-service-subheading-cards__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    margin: 0;
    border: 1px solid var(--color-border-soft);
    border-radius: 0.875rem;
    background: #fff;
    box-shadow: var(--shadow-soft);
    padding: 0.9rem 1rem 1rem;
    min-width: 0;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__card {
      min-height: 12.25rem;
      padding: 1rem 1.125rem 1.125rem;
    }
  }

  .p-service-subheading-cards__tag {
    margin: 0;
    border-radius: var(--radius-full);
    background: var(--color-surface-blue-soft);
    padding: 0.2rem 0.8rem;
    color: var(--color-blue-01);
    font-family: var(--font-family-base);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0.03em;
    text-align: left;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__tag {
      font-size: 0.8125rem;
    }
  }

  .p-service-subheading-cards__card-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    min-width: 0;
    width: 100%;
  }

  .p-service-subheading-cards__card-title {
    margin: 0;
    color: var(--color-black-03);
    font-family: var(--font-family-base);
    font-size: 0.9875rem;
    font-weight: 700;
    line-height: 1.5;
    text-align: left;
  }

  .p-service-subheading-cards__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    color: var(--color-black-03);
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: var(--line-height-base);
    width: 100%;
  }

  @media (--bp-md-up) {
    .p-service-subheading-cards__bullets {
      font-size: 0.9375rem;
    }
  }

  .p-service-subheading-cards__bullets li {
    position: relative;
    padding-left: 1.1rem;
  }

  .p-service-subheading-cards__bullets li::before {
    content: '';
    position: absolute;
    top: 0.7em;
    left: 0;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: var(--radius-full);
    background: var(--color-pink-01);
    transform: translateY(-50%);
  }

  .p-service-subheading-cards__bullets li + li {
    margin-top: 0.35rem;
  }
</style>
