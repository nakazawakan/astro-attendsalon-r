---
import SectionHeading from '../SectionHeading.astro';

export interface ServicePlanPrice {
  amount: string;
  suffix: string;
}

export interface ServicePlanCard {
  tabLabel: string;
  trainingType: string;
  prices: ServicePlanPrice[];
}

export interface ServicePlanPillar {
  title: string;
  subtitle: string;
  imageSrc?: string;
  imageAlt?: string;
}

export interface ServicePlanExample {
  titleLines: string[];
  descriptionLines: string[];
}

export interface ServicePlanData {
  cards: ServicePlanCard[];
  packageTitle: string;
  packageParagraphs: string[];
  packagePillars: ServicePlanPillar[];
  examplesTitle: string;
  examples: ServicePlanExample[];
}

interface Props {
  id: string;
  label: string;
  title: string;
  data: ServicePlanData;
  whiteBackground?: boolean;
}

const { id, label, title, data, whiteBackground = false } = Astro.props;
---

<section
  class:list={['l-section', 'p-service-plan-section', whiteBackground && 'p-service-plan-section--white']}
  aria-labelledby={id}
>
  <div class="l-container">
    <SectionHeading id={id} label={label} title={title} />

    <div class="l-stack p-service-plan-section__body">
      <div class="p-service-plan-section__cards">
        {
          data.cards.map((card) => (
            <div class="p-service-plan-section__card">
              <p class="p-service-plan-section__card-tab">{card.tabLabel}</p>
              <div class="p-service-plan-section__card-body">
                <dl class="p-service-plan-section__table">
                  <div class="p-service-plan-section__row">
                    <dt>研修種類</dt>
                    <dd>{card.trainingType}</dd>
                  </div>
                  <div class="p-service-plan-section__row">
                    <dt>料金目安</dt>
                    <dd class="p-service-plan-section__prices">
                      {card.prices.map((price) => (
                        <p class="p-service-plan-section__price">
                          <span class="p-service-plan-section__price-amount">{price.amount}</span>
                          <span class="p-service-plan-section__price-suffix">{price.suffix}</span>
                        </p>
                      ))}
                    </dd>
                  </div>
                </dl>
              </div>
            </div>
          ))
        }
      </div>

      <div class="l-stack">
        <section class="l-stack p-service-plan-section__package" aria-label={data.packageTitle}>
          <h3 class="p-service-plan-section__package-title">{data.packageTitle}</h3>

          <div class="l-stack p-service-plan-section__package-main">
            <div class="p-service-plan-section__package-copy">
              {data.packageParagraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>

            <div class="p-service-plan-section__pillars">
              {
                data.packagePillars.map((pillar) => (
                  <div class="p-service-plan-section__pillar">
                    <div class="p-service-plan-section__pillar-illustration-wrap">
                      {pillar.imageSrc ? (
                        <img
                          src={pillar.imageSrc}
                          alt={pillar.imageAlt ?? ''}
                          width="48"
                          height="48"
                          class="p-service-plan-section__pillar-illustration"
                          loading="lazy"
                          decoding="async"
                          aria-hidden="true"
                        />
                      ) : (
                        <div class="p-service-plan-section__image-placeholder" aria-hidden="true"></div>
                      )}
                    </div>
                    <p class="p-service-plan-section__pillar-title">{pillar.title}</p>
                    <p class="p-service-plan-section__pillar-subtitle">{pillar.subtitle}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </section>

        <section class="l-stack p-service-plan-section__package" aria-label={data.examplesTitle}>
          <h3 class="p-service-plan-section__package-title">{data.examplesTitle}</h3>
          <div class="p-service-plan-section__example-grid">
            {
              data.examples.map((example) => (
                <div class="p-service-plan-section__example">
                  <h5 class="p-service-plan-section__example-title">
                    {example.titleLines.map((line, lineIndex) => (
                      <>
                        {line}
                        {lineIndex < example.titleLines.length - 1 && <br />}
                      </>
                    ))}
                  </h5>
                  <div class="p-service-plan-section__example-image" aria-hidden="true"></div>
                  <p class="p-service-plan-section__example-description">
                    {example.descriptionLines.map((line, lineIndex) => (
                      <>
                        {line}
                        {lineIndex < example.descriptionLines.length - 1 && <br />}
                      </>
                    ))}
                  </p>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </div>
</section>

<style>
  .p-service-plan-section {
    border-bottom: 1px solid var(--color-border-soft);
  }
  .p-service-plan-section--white {
    background: #fff;
  }

  .p-service-plan-section__cards {
    display: grid;
    gap: 1rem;
  }

  .p-service-plan-section__body {
    --stack-gap: 1.5rem;
  }

  .p-service-plan-section__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    align-self: stretch;
    gap: 0;
  }

  .p-service-plan-section__card-tab {
    width: min(160px, 100%);
    margin: 0;
    padding: 0.4rem 1rem;
    background: var(--color-surface-02);
    color: var(--color-black-03);
    font-size: 1rem;
    line-height: 1.4;
    font-weight: 700;
    text-align: center;
  }

  .p-service-plan-section__card-body {
    flex: 1 1 auto;
    width: 100%;
    margin: 0;
    border: 1px solid var(--color-border-softer);
    border-radius: 8px;
    background: #fff;
    padding: 0.875rem;
  }

  .p-service-plan-section__table {
    margin: 0;
  }

  .p-service-plan-section__row {
    display: grid;
    grid-template-columns: 80px 1fr;
    align-items: center;
    column-gap: 0.75rem;
    font-size: 0.9rem;
  }

  .p-service-plan-section__row + .p-service-plan-section__row {
    margin-top: 0.75rem;
  }

  .p-service-plan-section__row dt {
    margin: 0;
    min-height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-blue-01);
    border-radius: 2px;
    color: var(--color-blue-01);
    line-height: 1.4;
    font-weight: 700;
  }

  .p-service-plan-section__row dd {
    margin: 0;
    color: var(--color-black-03);
    line-height: 1.4;
    font-weight: 700;
  }

  .p-service-plan-section__prices {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: flex-end;
  }

  .p-service-plan-section__price {
    margin: 0;
    display: inline-flex;
    align-items: flex-end;
    gap: 0.125rem;
    white-space: nowrap;
  }

  .p-service-plan-section__price-amount {
    font-size: 1.3rem;
    line-height: 0.9;
    font-weight: 700;
  }

  .p-service-plan-section__price-suffix {
    font-size: 0.95rem;
    line-height: 1;
    font-weight: 700;
  }

  .p-service-plan-section__package {
    --stack-gap: 1rem;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border-soft);
    border-radius: 1rem;
    padding: 1.5rem 1rem;
    background:
      linear-gradient(
        180deg,
        var(--color-surface-01) 0%,
        #fff 56%,
        var(--color-bg-warm) 100%
      );
    box-shadow: var(--shadow-soft);
  }


  .p-service-plan-section__package::after {
    content: "";
    position: absolute;
    top: 1rem;
    right: -3.5rem;
    width: 8.5rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--color-surface-02);
    opacity: 0.72;
    pointer-events: none;
  }

  .p-service-plan-section__package-main::before {
    content: "";
    position: absolute;
    top: 0.3rem;
    left: 1rem;
    width: 6rem;
    height: 1.25rem;
    border-radius: var(--radius-full);
    background: rgb(127 154 168 / 0.12);
    filter: blur(6px);
    pointer-events: none;
  }

  .p-service-plan-section__package > * {
    position: relative;
    z-index: 1;
  }

  .p-service-plan-section__package-main {
    position: relative;
    --stack-gap: 1.5rem;
  }

  .p-service-plan-section__package-title {
    margin: 0;
    width: fit-content;
    margin-inline: auto;
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-full);
    background: #fff;
    box-shadow: 0 1px 0 rgb(255 255 255 / 0.75) inset;
    color: var(--color-black-03);
    font-size: 1.1rem;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-align: center;
  }

  .p-service-plan-section__package-copy {
    margin: 0;
    color: var(--color-black-03);
    font-size: 0.875rem;
    line-height: 1.6;
    font-weight: 500;
  }

  .p-service-plan-section__package-copy p {
    margin: 0;
  }

  .p-service-plan-section__package-copy p + p {
    margin-top: 0.6em;
  }

  .p-service-plan-section__pillars {
    display: grid;
    gap: 1rem;
  }

  .p-service-plan-section__pillar {
    margin: 0;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    column-gap: 0.75rem;
    row-gap: 0;
    align-items: start;
    text-align: left;
  }

  .p-service-plan-section__pillar-illustration-wrap {
    width: 85px;
    height: 85px;
    margin-inline: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    background: #fff;
    border: 1px solid var(--color-border-softer);
    box-shadow: var(--shadow-soft);
    grid-row: 1 / 3;
    align-self: center;
  }

  .p-service-plan-section__pillar-illustration {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .p-service-plan-section__image-placeholder {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: var(--color-surface-02);
  }

  .p-service-plan-section__pillar-title {
    margin: 0;
    color: var(--color-black-03);
    font-size: 1rem;
    line-height: 1.4;
    font-weight: 700;
    align-self: end;
  }

  .p-service-plan-section__pillar-subtitle {
    margin: 0;
    color: var(--color-black-03);
    font-size: 0.75rem;
    line-height: 1.4;
    font-weight: 700;
    align-self: start;
  }

  .p-service-plan-section__examples {
    --stack-gap: 1rem;
  }

  .p-service-plan-section__examples-title {
    margin: 0;
    color: var(--color-black-03);
    font-size: 1.125rem;
    line-height: 1.4;
    font-weight: 700;
    text-align: center;
  }

  .p-service-plan-section__example-grid {
    display: grid;
    gap: 1.25rem;
  }

  .p-service-plan-section__example {
    margin: 0;
    color: var(--color-black-03);
  }

  .p-service-plan-section__example-title {
    margin: 0;
    color: var(--color-black-03);
    font-size: 1rem;
    line-height: 1.2;
    font-weight: 700;
    text-align: center;
  }

  .p-service-plan-section__example-image {
    margin-top: 0.5rem;
    width: 100%;
    height: 139px;
    background: var(--color-surface-02);
  }

  .p-service-plan-section__example-description {
    margin: 0.5rem 0 0;
    color: var(--color-black-03);
    font-size: 0.8125rem;
    line-height: 1.4;
    font-weight: 500;
  }

  @media (--bp-md-up) {
    .p-service-plan-section__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .p-service-plan-section__card-body {
      padding: 1.25rem 0.875rem 1rem;
    }

    .p-service-plan-section__package {
      padding: 1.875rem 2.5rem;
    }

    .p-service-plan-section__package::before {
      height: 0.625rem;
    }

    .p-service-plan-section__package::after {
      top: 1.25rem;
      right: -2rem;
      width: 10rem;
    }

    .p-service-plan-section__package-title {
      padding: 0.55rem 1.25rem;
    }

    .p-service-plan-section__package-copy {
      max-width: 820px;
      margin-inline: auto;
    }

    .p-service-plan-section__pillars {
      grid-template-columns: repeat(3, minmax(0, 172px));
      justify-content: center;
      gap: 59px;
    }

    .p-service-plan-section__pillar {
      display: block;
      text-align: center;
    }

    .p-service-plan-section__pillar-illustration-wrap {
      margin-inline: auto;
    }

    .p-service-plan-section__pillar-title {
      margin-top: 0.5rem;
    }

    .p-service-plan-section__examples {
      --stack-gap: 0.75rem;
    }

    .p-service-plan-section__example-grid {
      grid-template-columns: repeat(3, minmax(0, 238px));
      justify-content: center;
      gap: 53px;
    }

    .p-service-plan-section__example-title {
      min-height: 60px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>
