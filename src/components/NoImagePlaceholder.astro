---
/**
 * 仮ビジュアル枠（実画像・イラスト差し替え前）。ヒーロー右・特徴バナー等で共通利用。
 */
interface Props {
  /** 幅・min-height、アスペクト比などレイアウト用の追加クラス */
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<div
  class:list={['c-no-image-placeholder', className]}
  aria-hidden="true"
>
  <span class="c-no-image-placeholder__label">
    NO IMAGE
  </span>
</div>

<style>
  .c-no-image-placeholder {
    pointer-events: none;
    position: relative;
    isolation: isolate;
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    border: 1px dashed var(--color-border-soft);
    background-color: #d6d3d1;
  }

  @media (min-width: 768px) {
    .c-no-image-placeholder {
      border-radius: var(--radius-lg);
    }
  }

  .c-no-image-placeholder__label {
    user-select: none;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    line-height: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-black-05);
  }
</style>
