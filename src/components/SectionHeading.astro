---
/**
 * Figma セクション見出し（例: `294:720`）— 英字ラベル + 左装飾 + Zen 32px 見出しで統一
 */
interface Props {
  label: string;
  title: string;
  /** h2 の id（アンカー・アクセシビリティ用） */
  id?: string;
  /** 見出しブロック下の余白（デフォルト: セクション標準） */
  withBottomMargin?: boolean;
  /** 次要素との余白バリエーション */
  bottomMarginStyle?: 'section' | 'content';
  /** ファーストビュー付近なら eager */
  decoLoading?: 'eager' | 'lazy';
}
const {
  label,
  title,
  id,
  withBottomMargin = true,
  bottomMarginStyle = 'section',
  decoLoading = 'lazy',
} = Astro.props;
const rootClass = [
  'c-section-heading',
  withBottomMargin && 'c-section-heading--with-margin',
  withBottomMargin && bottomMarginStyle === 'content' && 'c-section-heading--with-content-margin',
]
  .filter(Boolean)
  .join(' ');
const hasIntro = Astro.slots.has('intro');
---
<div class={rootClass}>
  <!-- 装飾の基準は英字ラベル＋h2。必要なら intro も同一コンポーネントで受ける -->
  <div class="c-section-heading__inner">
    <img
      src="/images/section-heading-deco.svg"
      alt=""
      width="114"
      height="111"
      class="c-section-heading__deco"
      aria-hidden="true"
      loading={decoLoading}
      decoding="async"
    />
    <div class="c-section-heading__content">
      <p class="c-section-heading__label">{label}</p>
      <h2 id={id} class="c-section-heading__title">
        {title}
      </h2>
    </div>
  </div>
  {
    hasIntro && (
      <div class="c-section-heading__intro">
        <slot name="intro" />
      </div>
    )
  }
</div>

<style>
  .c-section-heading {
    display: grid;
    row-gap: 0.5rem;
    text-align: left;
  }

  .c-section-heading--with-margin {
    margin-bottom: 2.5rem;
  }

  .c-section-heading--with-content-margin {
    margin-bottom: 2.5rem;
  }

  .c-section-heading__inner {
    position: relative;
    text-align: left;
  }

  .c-section-heading__deco {
    position: absolute;
    top: 0;
    left: 8px;
    z-index: 0;
    width: 57px;
    height: auto;
    pointer-events: none;
    user-select: none;
    transform: translate(-47%, -61%);
  }

  .c-section-heading__content {
    position: relative;
    z-index: 10;
  }

  .c-section-heading__label {
    margin: 0 0 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-pink-01);
  }

  .c-section-heading__title {
    margin: 0;
    font-size: 1.75rem;
    line-height: 1.3;
    font-weight: 700;
    color: var(--color-black-03);
  }

  .c-section-heading__intro {
    max-width: 720px;
    margin-top: 2rem;
    font-family: var(--font-family-base);
    color: var(--color-black-03);
  }

  .c-section-heading__intro :global(p) {
    margin: 0;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
  }

  .c-section-heading__intro :global(p + p) {
    margin-top: 0;
  }

  @media (min-width: 768px) {
    .c-section-heading--with-margin {
      margin-bottom: 54px;
    }

    .c-section-heading--with-content-margin {
      margin-bottom: 3rem;
    }

    .c-section-heading__deco {
      left: 0;
      width: 114px;
    }

    .c-section-heading__title {
      font-size: 32px;
    }

    .c-section-heading__intro :global(p) {
      font-size: 0.9375rem;
      line-height: 1.6;
      font-weight: 400;
    }
  }
</style>
