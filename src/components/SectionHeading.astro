---
/**
 * Figma セクション見出し（例: `294:720`）— 英字ラベル + 左装飾 + Zen 32px 見出しで統一。
 * 既定はセクション用 h2。`headingLevel={1}` でページ見出しの h1 にも流用可。
 */
interface Props {
  label: string;
  title: string;
  /** 見出しの id（アンカー・アクセシビリティ用） */
  id?: string;
  /** 1: ページ H1（下位ページ見出し）。未指定は 2（セクション h2） */
  headingLevel?: 1 | 2;
  /** 見出しブロックの字揃え（未指定は左） */
  align?: 'start' | 'center';
  /** 見出しブロック下の余白（デフォルト: セクション標準） */
  withBottomMargin?: boolean;
  /** 次要素との余白バリエーション */
  bottomMarginStyle?: 'section' | 'content';
  /** ファーストビュー付近なら eager */
  decoLoading?: 'eager' | 'lazy';
}

const {
  label,
  title,
  id,
  headingLevel = 2,
  align = 'start',
  withBottomMargin = true,
  bottomMarginStyle = 'section',
  decoLoading = 'lazy',
} = Astro.props;

const rootClass = [
  'c-section-heading',
  'l-section-heading',
  align === 'center' && 'c-section-heading--align-center',
  !withBottomMargin && 'c-section-heading--no-margin',
  withBottomMargin && bottomMarginStyle === 'content' && 'l-section-heading--content',
]
  .filter(Boolean)
  .join(' ');
const titleLines = title.split(/<br\s*\/?>/i);
/** `slots.has` だけでは空の intro ラッパーが出ることがあるため、実体の有無で判定する */
const introMarkup = Astro.slots.has('intro') ? await Astro.slots.render('intro') : '';
const hasIntroContent = introMarkup.trim().length > 0;
---
<div class={rootClass}>
  <!-- 装飾の基準は英字ラベル＋h2。必要なら intro も同一コンポーネントで受ける -->
  <div class="c-section-heading__inner">
    <img
      src="/images/section-heading-deco.svg"
      alt=""
      width="114"
      height="111"
      class="c-section-heading__deco"
      aria-hidden="true"
      loading={decoLoading}
      decoding="async"
    />
    <div class="c-section-heading__content">
      <p class="c-section-heading__label">{label}</p>
      {
        headingLevel === 1 ? (
          <h1 id={id} class="c-section-heading__title">
            {
              titleLines.map((line, index) => (
                <>
                  {line}
                  {index < titleLines.length - 1 && <br />}
                </>
              ))
            }
          </h1>
        ) : (
          <h2 id={id} class="c-section-heading__title">
            {
              titleLines.map((line, index) => (
                <>
                  {line}
                  {index < titleLines.length - 1 && <br />}
                </>
              ))
            }
          </h2>
        )
      }
    </div>
  </div>
  {
    hasIntroContent && (
      <div class="c-section-heading__intro" set:html={introMarkup} />
    )
  }
</div>

<style>
  .c-section-heading {
    display: grid;
    row-gap: 0.5rem;
    text-align: left;
  }

  .c-section-heading--align-center {
    text-align: center;
  }

  .c-section-heading--align-center .c-section-heading__inner {
    text-align: center;
  }

  .c-section-heading--no-margin {
    margin-bottom: 0;
  }

  .c-section-heading__inner {
    position: relative;
    text-align: left;
  }

  .c-section-heading__deco {
    position: absolute;
    top: 0;
    left: 8px;
    z-index: 0;
    width: 57px;
    height: auto;
    pointer-events: none;
    user-select: none;
    transform: translate(-47%, -61%);
  }

  .c-section-heading__content {
    position: relative;
    z-index: 10;
  }

  .c-section-heading__label {
    margin: 0 0 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-pink-01);
  }

  .c-section-heading__title {
    margin: 0;
    font-size: 1.6rem;
    line-height: 1.3;
    font-weight: 700;
    color: var(--color-black-03);
    white-space: pre-line;
  }

  .c-section-heading__intro {
    margin-top: 1rem;
    font-family: var(--font-family-base);
    color: var(--color-black-03);
  }

  .c-section-heading__intro :global(p) {
    margin: 0;
    font-size: .9rem;
    font-weight: 400;
    line-height: 1.6;
  }

  .c-section-heading__intro :global(p + p) {
    margin-top: 0.75em;
  }

  @media (--bp-md-up) {
    .c-section-heading__deco {
      left: 0;
      width: 114px;
    }

    .c-section-heading__title {
      font-size: 32px;
      white-space: normal;
    }

    .c-section-heading__intro :global(p) {
      font-size: 0.9375rem;
      line-height: 1.6;
      font-weight: 400;
    }
  }
</style>
