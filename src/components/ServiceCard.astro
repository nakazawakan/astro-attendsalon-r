---
export interface Props {
  title: string;
  body: string;
  bodyTone: 'dark' | 'muted';
  icon: string;
  ctaLabel: string;
  /** デスクトップグリッドでアンカー用。SP カルーセルでは重複 id を避けて省略 */
  anchorId?: string;
}

const { title, body, bodyTone, icon, ctaLabel, anchorId } = Astro.props;
---

<article
  {...anchorId ? { id: anchorId } : {}}
  data-service-card
  class="mx-0 flex w-full min-w-0 max-w-[300px] flex-col items-center gap-[18px] self-stretch rounded-2xl border border-black/[0.06] bg-bg-warm p-6 text-center shadow-sm md:max-w-none md:w-full"
>
  <h3
    class="mx-0 block min-w-0 max-w-full self-stretch whitespace-nowrap text-center text-xl font-zen font-bold text-black-03 leading-[1.3]"
  >
    {title}
  </h3>
  <div class="flex h-[79px] w-[79px] shrink-0 items-center justify-center overflow-hidden rounded-full bg-white">
    <img src={icon} alt="" width="32" height="32" class="h-8 w-8 object-contain" aria-hidden="true" loading="lazy" decoding="async" />
  </div>
  <p
    class:list={[
      'flex min-h-[70px] w-full flex-1 items-start justify-start text-left text-sm font-zen font-medium leading-[1.6]',
      bodyTone === 'muted' ? 'text-black-05' : 'text-black-03',
    ]}
  >
    {body}
  </p>
  <a
    href="/contact/"
    class="mt-auto inline-flex w-full max-w-[240px] items-center justify-center gap-2.5 rounded-full bg-pink-01 px-0 py-[1.3rem] font-zen text-base font-bold leading-[1.1] text-white transition-opacity hover:opacity-90"
  >
    <img
      src="/images/about-chevron-cta.svg"
      alt=""
      width="10"
      height="10"
      class="h-2.5 w-2.5 shrink-0 rotate-180"
      aria-hidden="true"
      decoding="async"
    />
    {ctaLabel}
  </a>
</article>
