---
import NoImagePlaceholder from './NoImagePlaceholder.astro';
import SectionHeading from './SectionHeading.astro';
import SectionMarkDecor from './SectionMarkDecor.astro';

const features = [
  {
    layout: 'image-left' as const,
    num: '01',
    title: '現場力',
    body: '客室乗務員経験40年以上、管理職経験10年以上、クレーム対応、感情コントロールの最前線で培った圧倒的現場力で、実際の現場で起こる悩みをもとに実情に即した研修を提案します',
  },
  {
    layout: 'image-right' as const,
    num: '02',
    title: '組織構築実績',
    body: '職場に日常相談窓口、セルフキャリアドック（キャリア相談室）を立ち上げた経験から、メンタルヘルス対応、キャリア形成支援の観点で組織開発を支援します',
  },
  {
    layout: 'image-left' as const,
    num: '03',
    title: '国家資格×実務経験',
    body: '公認心理師、産業カウンセラー、1級キャリアコンサルティング技能士、キャリアコンサルタントなどの専門資格を有し、教育と産業の現場での実務経験を武器に、個人と組織支援の双方にアプローチします',
  },
];
---
<section id="features" class="l-section p-feature-section" data-reveal>
  <div class="l-wave l-wave--top l-wave--pattern-gentle-a" aria-hidden="true"></div>
  <SectionMarkDecor anchor="tl" variant="feature" />
  <div class="p-feature-section__bg-haze" aria-hidden="true"></div>
  <div class="l-container">
    <SectionHeading label="FEATURE" title="アテンドサロンRの特徴" />

    <div class="p-feature-section__list">
      {features.map(({ layout, num, title, body }) => (
        <div
          class:list={[
            'p-feature-section__item',
            layout === 'image-left' ? 'p-feature-section__item--image-left' : 'p-feature-section__item--image-right',
          ]}
        >
          <div class="p-feature-section__media">
            <NoImagePlaceholder />
          </div>
          <article
            class="p-feature-section__card"
          >
            <div class="p-feature-section__card-head">
              <h3 class="p-feature-section__title">
                {title}
              </h3>
              <p
                class="p-feature-section__num"
                aria-hidden="true"
              >
                {num}
              </p>
            </div>
            <p class="p-feature-section__body">
              {body}
            </p>
          </article>
        </div>
      ))}
    </div>
  </div>
  <div class="l-wave l-wave--bottom l-wave--pattern-gentle-b" aria-hidden="true"></div>
</section>

<style>
  .p-feature-section {
    --wave-height: 40px;
    --wave-mask-gentle-a: url("data:image/svg+xml,%3Csvg viewBox='0 0 912 62' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 14 C90 -2 180 -2 270 14 C360 30 450 30 540 14 C630 -2 720 -2 810 14 C844 20 878 20 912 14 L912 62 L0 62 Z' fill='black'/%3E%3C/svg%3E");
    --wave-mask-gentle-b: url("data:image/svg+xml,%3Csvg viewBox='0 0 912 62' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 16 C118 0 236 0 354 16 C442 31 530 31 618 16 C716 0 814 0 912 12 L912 62 L0 62 Z' fill='black'/%3E%3C/svg%3E");
    position: relative;
    overflow: hidden;
    isolation: isolate;
    /* Keep l-section default spacing and add wave area at top/bottom. */
    padding-top: calc(var(--section-padding-block-start, var(--section-padding-block-start-default)) + var(--wave-height));
    padding-bottom: calc(var(--section-padding-block-end, var(--section-padding-block-end-default)) + var(--wave-height));
    background:
      linear-gradient(
        180deg,
        #fefcf9 0%,
        #fdfaf4 52%,
        #fcf8f1 100%
      );
  }

  .p-feature-section__bg-haze {
    position: absolute;
    inset: -10% -6%;
    z-index: var(--z-section-bg, 0);
    pointer-events: none;
    background:
      radial-gradient(
        138% 96% at 10% -6%,
        rgb(251 107 106 / 0.02) 0%,
        rgb(251 107 106 / 0.006) 34%,
        rgb(251 107 106 / 0) 72%
      ),
      radial-gradient(
        132% 92% at 92% 6%,
        rgb(127 154 168 / 0.018) 0%,
        rgb(127 154 168 / 0.005) 38%,
        rgb(127 154 168 / 0) 74%
      );
    transform: translate3d(0, 0, 0) scale(1.02);
  }

  .p-feature-section.is-visible .p-feature-section__bg-haze {
    animation: p-feature-section-bg-sway 10s ease-in-out infinite alternate;
  }

  .p-feature-section > .l-container {
    position: relative;
    z-index: var(--z-section-content, 3);
  }

  @keyframes p-feature-section-bg-sway {
    0% {
      transform: translate3d(-1.2%, -0.6%, 0) scale(1.02) rotate(-0.25deg);
    }

    50% {
      transform: translate3d(0.8%, 0.7%, 0) scale(1.035) rotate(0.22deg);
    }

    100% {
      transform: translate3d(-0.5%, 1%, 0) scale(1.03) rotate(-0.12deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .p-feature-section.is-visible .p-feature-section__bg-haze {
      animation: none;
      transform: none;
    }
  }

  .p-feature-section__list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .p-feature-section__item {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .p-feature-section__media {
    display: flex;
    flex-direction: column;
    width: 100%;
    flex-shrink: 0;
    min-height: 200px;
  }

  .p-feature-section__media :global(.c-no-image-placeholder) {
    box-sizing: border-box;
    flex: 1 1 auto;
    width: 100%;
    min-height: 200px;
  }

  .p-feature-section__card {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1rem;
    border-radius: 0 0 0.5rem 0.5rem;
    background: #fff;
    box-shadow: var(--shadow-soft);
  }

  .p-feature-section__card-head {
    display: flex;
    width: 100%;
    align-items: flex-start;
    justify-content: flex-end;
    gap: 1rem;
    flex-direction: row-reverse;
    text-align: left;
    color: var(--color-pink-01);
  }

  .p-feature-section__title {
    margin: 0;
    min-width: 0;
    flex-shrink: 1;
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 700;
    text-align: left;
  }

  .p-feature-section__num {
    margin: 0;
    flex-shrink: 0;
    font-size: 2rem;
    line-height: 1;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    font-family: "Lato", sans-serif;
  }

  .p-feature-section__body {
    width: 100%;
    margin: 0;
    color: var(--color-black-03);
    font-size: 0.875rem;
    line-height: 1.8;
    font-weight: 500;
  }

  @media (--bp-md-up) {
    .p-feature-section {
      --wave-height: 62px;
    }

    .p-feature-section__list {
      gap: 3rem;
    }

    .p-feature-section__item {
      gap: 1.5rem;
      align-items: stretch;
    }

    .p-feature-section__item--image-left {
      flex-direction: row;
    }

    .p-feature-section__item--image-right {
      flex-direction: row-reverse;
    }

    .p-feature-section__media {
      width: 420px;
      max-width: 48%;
      min-height: 275px;
    }

    .p-feature-section__media :global(.c-no-image-placeholder) {
      min-height: 275px;
    }

    .p-feature-section__card {
      gap: 1.5rem;
      padding: 2.5rem;
      border-radius: 0.5rem;
    }

    .p-feature-section__card-head {
      flex-direction: row;
      justify-content: space-between;
      text-align: center;
    }

    .p-feature-section__title {
      font-size: 1.5rem;
    }

    .p-feature-section__num {
      font-size: 40px;
    }

    .p-feature-section__body {
      font-size: 0.9375rem;
      line-height: 1.6;
      font-weight: 400;
    }
  }
</style>
