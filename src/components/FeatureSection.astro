---
import NoImagePlaceholder from './NoImagePlaceholder.astro';
import SectionHeading from './SectionHeading.astro';

const features = [
  {
    layout: 'image-left' as const,
    num: '01',
    title: '現場力',
    body: '客室乗務員経験40年以上、管理職経験10年以上、クレーム対応、感情コントロールの最前線で培った圧倒的現場力で、実際の現場で起こる悩みをもとに実情に即した研修を提案します',
  },
  {
    layout: 'image-right' as const,
    num: '02',
    title: '組織構築実績',
    body: '職場に日常相談スペース、セルフキャリアドックを立ち上げた経験から、メンタルヘルス支援、キャリア支援の観点で組織開発を支援します',
  },
  {
    layout: 'image-left' as const,
    num: '03',
    title: '国家資格×実務経験',
    body: '公認心理師、産業カウンセラー、1級キャリアコンサルティング技能士、キャリアコンサルタントなどの専門資格を有し、教育と産業の現場での実務経験を武器に、個人と組織支援の双方にアプローチします',
  },
];
---
<section id="features" class="pt-[130px] pb-[80px]" data-reveal>
  <div class="mx-auto w-full min-w-0 max-w-pageShell px-6">
    <div class="mx-auto w-full min-w-0 max-w-page">
    <SectionHeading label="FEATURE" title="アテンドサロンRの特徴" />

    <div class="flex flex-col gap-10 md:gap-12">
      {features.map(({ layout, num, title, body }) => (
        <div
          class:list={[
            'flex flex-col gap-0 md:gap-6 md:items-stretch',
            layout === 'image-left' ? 'md:flex-row' : 'md:flex-row-reverse',
          ]}
        >
          <NoImagePlaceholder class="w-full shrink-0 md:w-[420px] md:max-w-[48%] min-h-[200px] md:min-h-[275px]" />
          <article
            class="flex-1 min-w-0 bg-white rounded-b-lg p-4 md:rounded-lg md:p-10 flex flex-col gap-6"
          >
            <div class="flex flex-row-reverse justify-end items-start gap-4 text-left text-pink-01 md:flex-row md:justify-between md:text-center w-full">
              <h3 class="text-left text-xl md:text-2xl font-zen font-bold leading-[1.3] shrink min-w-0">
                {title}
              </h3>
              <p
                class="shrink-0 text-[2rem] md:text-[40px] font-black leading-none tabular-nums font-['Lato',sans-serif]"
                aria-hidden="true"
              >
                {num}
              </p>
            </div>
            <p class="text-sm font-zen font-medium text-black-03 leading-[1.8] w-full">
              {body}
            </p>
          </article>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>
