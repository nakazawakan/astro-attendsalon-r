---
const features = [
  {
    num: '01',
    title: '現場力',
    body: '客室乗務員経験40年以上の講師が、接客・対人業務の現場感覚に根ざした研修を提供。机上の空論ではなく、明日から使える実践的なスキル習得を重視します。',
  },
  {
    num: '02',
    title: '組織構築実績',
    body: '職場に日常相談スペースを設計・運用支援してきた実績があります。制度だけでなく、心理的安全性が育つ「場づくり」まで伴走します。',
  },
  {
    num: '03',
    title: '国家資格×実務経験',
    body: '公認心理師、産業カウンセラーなどの資格を持つ講師陣が、エビデンスに基づくアプローチで組織のメンタルヘルス対策を支援します。',
  },
];
---
<section id="features" class="bg-white border-t border-[#ddd] py-12 md:py-16">
  <div class="max-w-[960px] mx-auto px-4 md:px-6">
    <h2 class="text-xl md:text-2xl font-noto font-bold text-black-03 text-center md:text-left mb-10">
      「アテンドサロンR」の特徴
    </h2>
    <div class="flex flex-col md:flex-row md:flex-wrap justify-center gap-6 md:gap-5">
      {features.map(({ num, title, body }) => (
        <article class="w-full md:w-[310px] max-w-[400px] mx-auto border border-[#cfcfcf] p-[22px] bg-white">
          <p class="text-sm text-black-05 mb-1 font-noto">特徴 {num}</p>
          <h3 class="text-lg font-noto font-bold text-black-03 mb-3">{title}</h3>
          <div class="bg-[#ebebeb] h-[111px] rounded-sm mb-4 w-full" aria-hidden="true"></div>
          <p class="text-sm text-black-03 leading-[1.6] font-noto">{body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
