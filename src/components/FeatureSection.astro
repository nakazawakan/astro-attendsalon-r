---
import NoImagePlaceholder from './NoImagePlaceholder.astro';
import SectionHeading from './SectionHeading.astro';

const features = [
  {
    layout: 'image-left' as const,
    num: '01',
    title: '現場力',
    body: '客室乗務員経験40年以上、管理職経験10年以上、クレーム対応、感情コントロールの最前線で培った圧倒的現場力で、実際の現場で起こる悩みをもとに実情に即した研修を提案します',
  },
  {
    layout: 'image-right' as const,
    num: '02',
    title: '組織構築実績',
    body: '職場に日常相談スペース、セルフキャリアドックを立ち上げた経験から、メンタルヘルス支援、キャリア支援の観点で組織開発を支援します',
  },
  {
    layout: 'image-left' as const,
    num: '03',
    title: '国家資格×実務経験',
    body: '公認心理師、産業カウンセラー、1級キャリアコンサルティング技能士、キャリアコンサルタントなどの専門資格を有し、教育と産業の現場での実務経験を武器に、個人と組織支援の双方にアプローチします',
  },
];
---
<section id="features" class="p-feature" data-reveal>
  <div class="l-page-shell">
    <div class="l-page-inner">
    <SectionHeading label="FEATURE" title="アテンドサロンRの特徴" />

    <div class="p-feature__list">
      {features.map(({ layout, num, title, body }) => (
        <div
          class:list={[
            'p-feature__item',
            layout === 'image-left' ? 'p-feature__item--image-left' : 'p-feature__item--image-right',
          ]}
        >
          <div class="p-feature__media">
            <NoImagePlaceholder />
          </div>
          <article
            class="p-feature__card"
          >
            <div class="p-feature__card-head">
              <h3 class="p-feature__title">
                {title}
              </h3>
              <p
                class="p-feature__num"
                aria-hidden="true"
              >
                {num}
              </p>
            </div>
            <p class="p-feature__body">
              {body}
            </p>
          </article>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<style>
  .p-feature {
    padding-top: 130px;
    padding-bottom: 80px;
  }

  .p-feature__list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .p-feature__item {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .p-feature__media {
    display: flex;
    flex-direction: column;
    width: 100%;
    flex-shrink: 0;
    min-height: 200px;
  }

  .p-feature__media :global(.c-no-image-placeholder) {
    box-sizing: border-box;
    flex: 1 1 auto;
    width: 100%;
    min-height: 200px;
  }

  .p-feature__card {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1rem;
    border-radius: 0 0 0.5rem 0.5rem;
    background: #fff;
  }

  .p-feature__card-head {
    display: flex;
    width: 100%;
    align-items: flex-start;
    justify-content: flex-end;
    gap: 1rem;
    flex-direction: row-reverse;
    text-align: left;
    color: var(--color-pink-01);
  }

  .p-feature__title {
    margin: 0;
    min-width: 0;
    flex-shrink: 1;
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 700;
    text-align: left;
  }

  .p-feature__num {
    margin: 0;
    flex-shrink: 0;
    font-size: 2rem;
    line-height: 1;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    font-family: "Lato", sans-serif;
  }

  .p-feature__body {
    width: 100%;
    margin: 0;
    color: var(--color-black-03);
    font-size: 0.875rem;
    line-height: 1.8;
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .p-feature__list {
      gap: 3rem;
    }

    .p-feature__item {
      gap: 1.5rem;
      align-items: stretch;
    }

    .p-feature__item--image-left {
      flex-direction: row;
    }

    .p-feature__item--image-right {
      flex-direction: row-reverse;
    }

    .p-feature__media {
      width: 420px;
      max-width: 48%;
      min-height: 275px;
    }

    .p-feature__media :global(.c-no-image-placeholder) {
      min-height: 275px;
    }

    .p-feature__card {
      gap: 1.5rem;
      padding: 2.5rem;
      border-radius: 0.5rem;
    }

    .p-feature__card-head {
      flex-direction: row;
      justify-content: space-between;
      text-align: center;
    }

    .p-feature__title {
      font-size: 1.5rem;
    }

    .p-feature__num {
      font-size: 40px;
    }
  }
</style>
