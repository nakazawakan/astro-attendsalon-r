---
import SectionHeading from './SectionHeading.astro';

export interface VoiceSectionImage {
  src: string;
  alt: string;
  width?: number;
  height?: number;
}

export interface VoiceSectionDetailRow {
  label: string;
  value: string;
  note?: string;
}

export interface VoiceSectionCompareCard {
  label: string;
  body: string[];
}

export interface VoiceSectionCase {
  quoteTitleLines: string[];
  quoteItems: string[];
  images: VoiceSectionImage[];
  details: VoiceSectionDetailRow[];
  compareCards: VoiceSectionCompareCard[];
}

interface Props {
  id?: string;
  label?: string;
  title?: string;
  voices?: VoiceSectionCase[];
  reveal?: boolean;
}

const DEFAULT_VOICE_CASES: VoiceSectionCase[] = [
  {
    quoteTitleLines: ['食べる×休むで整う', 'メンタルヘルス向上セミナー'],
    quoteItems: [
      '空に関わる仕事をしていくためには、体調管理はもちろん、メンタルヘルスについてもコントロールできなければと思っていました。今回の研修で、食事や休養がメンタルヘルスに与える影響について学ぶことができました。',
      'ご自身の経験も踏まえたお話はとても参考になりましたし、最後に自分の言葉で発表した実行宣言は、明日からの決意を表明できました。',
    ],
    images: [
      {
        src: '/images/voice-01.png',
        alt: 'メンタルヘルス研修の様子（写真1枚目）',
        width: 536,
        height: 402,
      },
      {
        src: '/images/voice-02.png',
        alt: 'メンタルヘルス研修の様子（写真2枚目）',
        width: 536,
        height: 402,
      },
    ],
    details: [
      {
        label: '導入団体',
        value: '一般社団法人 日本女性航空協会',
        note: '女性パイロット、管制官等で構成される日本の航空界で唯一の女性のための公益法人',
      },
      {
        label: '研修名',
        value: '「食べる×休むで整うメンタルヘルス向上セミナー」',
      },
    ],
    compareCards: [
      {
        label: '研修前（課題）',
        body: [
          '空に関わる仕事では、決まった時間に食事を摂ることや、休養することが難しいという環境特性があります。',
          '効果的に食事や休養をとるためには、どのような考え方や生活習慣が必要なのかあまり意識していない実態があるようでした。',
        ],
      },
      {
        label: '研修後（成果）',
        body: [
          '参加者はココロとからだ、メンタルヘルスの関係を正しく理解し、特に食事や休養についてはこれまで自分が意識して実施してきたことを否定することなく、新たに研修で学んだことを明日からの実行宣言として発表することで自分事としてとらえることができていたできているようでした。',
          'また、他の方の宣言を聞くことにより、参加者同士の良好なコミュニケーションにもつながったようでした。',
        ],
      },
    ],
  },
];

const {
  id,
  label = 'VOICE',
  title = 'お客様の声',
  voices = DEFAULT_VOICE_CASES,
  reveal = true,
} = Astro.props;
---
<section
  class="l-section p-voice-section"
  aria-labelledby={id}
  aria-label={id ? undefined : title}
  data-reveal={reveal ? true : undefined}
>
  <div class="l-container">
      <SectionHeading id={id} label={label} title={title} />

      {
        voices.map((voice) => (
      <article class="l-stack p-voice-section__panel">
        <div class="p-voice-section__quote">
          <h3 class="p-voice-section__quote-title">
            {voice.quoteTitleLines.map((line, lineIndex) => (
              <>
                {line}
                {lineIndex < voice.quoteTitleLines.length - 1 && <br />}
              </>
            ))}
          </h3>
          <ul class="l-stack p-voice-section__quote-list">
            {voice.quoteItems.map((item) => (
              <li class="p-voice-section__quote-item">
                <span class="p-voice-section__bullet" aria-hidden="true">・</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="p-voice-section__top">
          <div class="p-voice-section__photo-row">
            {voice.images.map((image) => (
              <div class="p-voice-section__photo">
                <img
                  src={image.src}
                  alt={image.alt}
                  class="p-voice-section__img"
                  width={image.width}
                  height={image.height}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ))}
          </div>
          <div class="p-voice-section__table-wrap">
            <table class="p-voice-section__table">
              <tbody>
                {voice.details.map((detail) => (
                  <tr class="p-voice-section__tr">
                    <th class="p-voice-section__th">{detail.label}</th>
                    <td class="p-voice-section__td">
                      {detail.value}
                      {
                        detail.note && (
                          <>
                            <br />
                            <span class="p-voice-section__td-note">{detail.note}</span>
                          </>
                        )
                      }
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div class="p-voice-section__compare">
          {voice.compareCards.map((card) => (
            <div class="l-stack p-voice-section__compare-card">
              <p class="p-voice-section__compare-label">{card.label}</p>
              <p class="p-voice-section__compare-body">
                {card.body.map((line, lineIndex) => (
                  <>
                    {line}
                    {lineIndex < card.body.length - 1 && <br />}
                  </>
                ))}
              </p>
            </div>
          ))}
        </div>
      </article>
        ))
      }
  </div>
</section>

<style>
  .p-voice-section {
    background: #fff;
  }

  .p-voice-section__panel {
    --stack-gap: 1.5rem;
    overflow-x: clip;
    border: 1px solid var(--color-border-soft);
    border-radius: 0.125rem;
    background: #fff;
    padding: 1rem;
    box-shadow: var(--shadow-soft);
  }

  .p-voice-section__panel + .p-voice-section__panel {
    margin-top: 2rem;
  }

  .p-voice-section__top {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1.5rem;
  }

  .p-voice-section__photo-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: stretch;
    justify-content: center;
    min-height: 0;
    width: 100%;
    flex-shrink: 0;
    gap: 0.75rem;
  }

  .p-voice-section__photo {
    min-height: 0;
    min-width: 0;
    flex: 1 1 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 0.125rem;
  }

  .p-voice-section__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .p-voice-section__table-wrap {
    flex: 1 1 auto;
    min-width: 0;
    overflow-x: auto;
  }

  .p-voice-section__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
  }

  .p-voice-section__tr {
    border-bottom: 1px solid var(--color-border-soft);
  }

  .p-voice-section__th {
    padding: 0.5rem 1rem 0.5rem 0;
    text-align: left;
    font-weight: 500;
    color: var(--color-black-03);
    white-space: nowrap;
    vertical-align: top;
  }

  .p-voice-section__td {
    padding: 0.5rem 0;
    color: var(--color-black-03);
    vertical-align: top;
  }

  .p-voice-section__td-note {
    font-size: 0.8em;
    line-height: 1.4;
  }

  .p-voice-section__quote {
    border-radius: 0.125rem;
    background: var(--color-bg-warm);
    padding: 1rem;
    @media (--bp-md-up) {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
  }

  .p-voice-section__quote-title {
    margin: 0 0 1rem;
    font-family: var(--font-family-base);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-black-03);
    text-align: center;
  }

  .p-voice-section__quote-list {
    margin: 0;
    padding: 0;
    list-style: none;
    --stack-gap: 1rem;
  }

  .p-voice-section__quote-item {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    line-height: var(--line-height-base);
    color: var(--color-black-03);
  }

  .p-voice-section__bullet {
    flex-shrink: 0;
    font-weight: 700;
    color: var(--color-black-03);
  }

  .p-voice-section__compare {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .p-voice-section__compare-card {
    --stack-gap: 0.5rem;
    border: 1px solid var(--color-border-soft);
    border-radius: 0.125rem;
    padding: 1rem;
    text-align: center;
  }

  .p-voice-section__compare-label {
    margin: 0;
    font-family: var(--font-family-base);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-black-03);
  }

  .p-voice-section__compare-body {
    margin: 0;
    text-align: left;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    line-height: var(--line-height-base);
    color: var(--color-black-03);
  }

  @media (--bp-md-up) {
    .p-voice-section__photo-row {
      gap: 1rem;
    }
  }

  @media (--bp-md-up) {
    .p-voice-section__panel {
      padding: 1.5rem;
    }

    .p-voice-section__top {
      gap: 2rem;
    }

    .p-voice-section__photo-row {
      gap: 1.25rem;
    }

    .p-voice-section__quote {
      padding: 1.5rem;
    }

    .p-voice-section__quote-title {
      font-size: 1.3rem;
      width: 800px;
      max-width: 100%;
      margin-bottom: 0;
      text-align: left;
    }

    .p-voice-section__quote-item {
      font-size: 0.9375rem;
      line-height: 1.6;
      font-weight: 400;
    }

    .p-voice-section__compare-body {
      font-size: 0.9375rem;
      line-height: 1.6;
      font-weight: 400;
    }

    .p-voice-section__compare {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (--bp-lg-up) {
    .p-voice-section__top {
      flex-direction: row;
      align-items: flex-start;
    }

    .p-voice-section__photo-row {
      width: auto;
      max-width: min(100%, 580px);
      flex-shrink: 0;
      justify-content: flex-start;
    }

    .p-voice-section__photo {
      width: 268px;
      flex: 0 0 268px;
    }
  }
</style>
