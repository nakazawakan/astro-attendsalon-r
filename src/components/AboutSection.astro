---
const gridImages = [
  { src: '/images/about-grid-1.jpg', alt: '介護の現場で利用者の手を取り、笑顔で向き合う様子' },
  { src: '/images/about-grid-2.jpg', alt: 'ヘッドセットを装着し、パソコンで対応するコールセンター業務の様子' },
  { src: '/images/about-grid-3.jpg', alt: '医療スタッフがタブレットを見ながら相談する様子' },
  { src: '/images/about-grid-4.jpg', alt: '接客カウンターで対応するスタッフの様子' },
];

const industries = [
  { label: '医療・介護', icon: '/images/about-icon-iryo.svg' },
  { label: 'お客様窓口', icon: '/images/about-icon-madoguchi.svg' },
  { label: 'ホテル・飲食', icon: '/images/about-icon-hotel.svg' },
  { label: '教育・保育', icon: '/images/about-icon-kyoiku.svg' },
  { label: '官公庁・自治体', icon: '/images/about-icon-kanko.svg' },
  { label: '営業', icon: '/images/about-icon-eigyo.svg' },
];
---
<section id="about" class="p-about" data-reveal>
  <div class="l-page-shell">
    <div class="l-page-inner">
    <div class="p-about__intro">
      <div
        class="p-about__grid"
      >
        {gridImages.map(({ src, alt }, i) => (
          <img
            src={src}
            alt={alt}
            width="194"
            height="148"
            class="p-about__grid-image"
            loading={i < 2 ? 'eager' : 'lazy'}
            decoding="async"
          />
        ))}
      </div>

      <div class="p-about__copy">
        <h2 class="p-about__title">
          <span class="p-about__title-row">
            <span class="p-about__title-main">
              <span class="p-about__title-main-text">アテンドサロンR</span>
              <span
                class="p-about__title-marker"
                aria-hidden="true"
              />
            </span>
            <span class="p-about__title-tail">は</span>
          </span>
        </h2>

        <p class="p-about__lead-strong">
          感情労働の現場経験及び指導経験を活かした<br />
          実践型マネジメント研修を提供します
        </p>

        <p class="p-about__lead-normal">
          働く現場の感情を適切に管理し、感情→行動→組織をつなぐことで、個人、組織の相互支援（心理的安全性）の実現を提案します。
        </p>

        <a
          href="/#features"
          class="p-about__cta"
        >
          <img
            src="/images/about-chevron-cta.svg"
            alt=""
            width="10"
            height="10"
            class="p-about__cta-icon"
            aria-hidden="true"
            decoding="async"
          />
          <span class="p-about__cta-label">私たちが選ばれる理由</span>
        </a>
      </div>
    </div>

    <div class="p-about__panel">
      <div class="p-about__panel-content">
        <div class="p-about__panel-head">
          <div class="p-about__panel-bar" aria-hidden="true" />
          <p class="p-about__panel-title">感情労働とは？</p>
        </div>

        <div class="p-about__panel-body">
          <div class="p-about__panel-copy">
            <p class="p-about__panel-text">
              感情労働とは、仕事上の役割に応じて感情をコントロールし、適切な態度や振る舞いを求められる労働です。感情を抑えたり演出したりするため、精神的な負担が生じやすい特徴があります。
            </p>
            <a
              href="/kanjorodou/"
              class="p-about__panel-link"
            >
              <img
                src="/images/about-chevron-link.svg"
                alt=""
                width="10"
                height="10"
                class="p-about__panel-link-icon"
                aria-hidden="true"
                decoding="async"
              />
              感情労働とは
            </a>
          </div>

          <div class="p-about__industry-grid">
            {industries.map(({ label, icon }) => (
              <div
                class="p-about__industry-item"
              >
                <img
                  src={icon}
                  alt=""
                  width="28"
                  height="28"
                  class="p-about__industry-icon"
                  loading="lazy"
                  decoding="async"
                  aria-hidden="true"
                />
                <span class="p-about__industry-label">{label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  .p-about {
    padding-top: 3rem;
    padding-bottom: 80px;
  }

  .p-about__intro {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .p-about__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    width: 100%;
    max-width: none;
    flex-shrink: 0;
  }

  .p-about__grid-image {
    width: 100%;
    aspect-ratio: 194 / 148;
    object-fit: cover;
    border-radius: 5px;
  }

  .p-about__copy {
    flex: 1;
    min-width: 0;
    width: 100%;
    max-width: none;
  }

  .p-about__title {
    margin: 0;
    color: var(--color-black-03);
  }

  .p-about__title-row {
    position: relative;
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.125rem;
  }

  .p-about__title-main {
    position: relative;
    display: inline-block;
    padding-bottom: 0.25rem;
    font-size: 1.75rem;
    line-height: 1.25;
    font-weight: 700;
  }

  .p-about__title-main-text {
    position: relative;
    z-index: 10;
  }

  .p-about__title-marker {
    position: absolute;
    left: 0;
    bottom: 0.25rem;
    z-index: 0;
    width: min(100%, 265px);
    max-width: 100%;
    height: 0.75rem;
    border-radius: 0.125rem;
    background: #ffddd2;
  }

  .p-about__title-tail {
    font-size: 1.125rem;
    line-height: 1.25;
    font-weight: 700;
  }

  .p-about__lead-strong {
    margin: 0;
    color: var(--color-black-03);
    font-size: 1rem;
    line-height: 1.7;
    font-weight: 700;
  }

  .p-about__lead-normal {
    margin: 1rem 0 0;
    color: var(--color-black-05);
    font-size: 1rem;
    line-height: 1.6;
    font-weight: 400;
  }

  .p-about__cta {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    min-width: min(100%, 300px);
    max-width: 100%;
    padding: 1.3rem 1.5rem;
    border-radius: 9999px;
    background: var(--color-pink-01);
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    transition: opacity 0.2s ease;
  }

  .p-about__cta:hover {
    opacity: 0.9;
  }

  .p-about__cta-icon {
    width: 0.625rem;
    height: 0.625rem;
    flex-shrink: 0;
    transform: rotate(180deg);
  }

  .p-about__cta-label {
    line-height: 1.1;
    text-align: center;
    white-space: nowrap;
  }

  .p-about__panel {
    margin-top: 2.5rem;
    width: 100%;
    border: 1px solid var(--color-border-softer);
    border-radius: 0.5rem;
    background: #fff;
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.05);
    padding: 1.5rem 1.25rem;
  }

  .p-about__panel-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .p-about__panel-head {
    display: flex;
    align-items: flex-start;
    gap: 7px;
  }

  .p-about__panel-bar {
    width: 6px;
    height: 2rem;
    flex-shrink: 0;
    border-radius: 0.125rem;
    background: var(--color-blue-01);
  }

  .p-about__panel-title {
    margin: 0;
    padding-top: 0.125rem;
    color: var(--color-black-03);
    font-size: 17px;
    line-height: 1.6;
    font-weight: 700;
  }

  .p-about__panel-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .p-about__panel-copy {
    flex: 1;
    min-width: 0;
    width: 100%;
    max-width: none;
  }

  .p-about__panel-text {
    margin: 0 0 1.5rem;
    color: var(--color-black-03);
    font-size: 15px;
    line-height: 1.4;
    font-weight: 500;
  }

  .p-about__panel-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-link);
    color: var(--color-link);
    font-size: 1rem;
    font-weight: 700;
    transition: opacity 0.2s ease;
  }

  .p-about__panel-link:hover {
    opacity: 0.8;
  }

  .p-about__panel-link-icon {
    width: 0.625rem;
    height: 0.625rem;
    flex-shrink: 0;
    transform: rotate(180deg);
  }

  .p-about__industry-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
    width: 100%;
    flex-shrink: 0;
  }

  .p-about__industry-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    min-height: 50px;
    height: 50px;
    padding-inline: 0.625rem;
    border: 1px solid var(--color-border-softer);
    border-radius: 0.25rem;
    background: #fff;
    overflow: hidden;
  }

  .p-about__industry-icon {
    width: 1.75rem;
    height: 1.75rem;
    flex-shrink: 0;
    object-fit: contain;
  }

  .p-about__industry-label {
    color: var(--color-black-03);
    font-size: 0.875rem;
    line-height: 1;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (min-width: 640px) {
    .p-about__industry-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 768px) {
    .p-about {
      padding-top: 130px;
    }

    .p-about__intro {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 2rem;
    }

    .p-about__grid {
      flex: 1;
      min-width: 0;
    }

    .p-about__copy {
      max-width: 460px;
      margin-left: auto;
    }

    .p-about__title-main {
      font-size: 34px;
    }

    .p-about__title-tail {
      font-size: 22px;
    }

    .p-about__lead-strong {
      font-size: 20px;
    }

    .p-about__panel {
      padding: 1.5rem 25px;
    }

    .p-about__panel-body {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }

    .p-about__panel-copy {
      max-width: 370px;
    }

    .p-about__industry-grid {
      width: auto;
      max-width: 500px;
    }
  }
</style>
