---
export interface InstructorCard {
  nameJa: string;
  nameEn: string;
  tags: string[];
  image: string;
  imageAlt: string;
  imgWidth: number;
  imgHeight: number;
  objectPosition: string;
}

interface Props {
  instructors: InstructorCard[];
}

const { instructors } = Astro.props;
---

<div class="flex flex-row flex-nowrap justify-center items-stretch gap-3 md:gap-[39px] w-full min-w-0">
  {
    instructors.map(({ nameJa, nameEn, tags, image, imageAlt, imgWidth, imgHeight, objectPosition }) => (
      <article class="flex min-w-0 flex-1 basis-0 flex-col gap-[14px] max-w-[480px] md:flex-none md:w-[460px] md:shrink-0">
        <div class="relative w-full h-[200px] md:h-[300px] rounded-lg overflow-hidden bg-surface-01">
          <img
            src={image}
            alt={imageAlt}
            width={imgWidth}
            height={imgHeight}
            class:list={['absolute inset-0 w-full h-full object-cover', objectPosition]}
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="flex flex-col gap-[7px] font-zen font-bold text-black-03">
          <h3 class="text-lg leading-none">{nameJa}</h3>
          <p class="text-sm leading-none text-black-03">{nameEn}</p>
        </div>
        <div class="flex flex-wrap gap-1">
          {tags.map((t) => (
            <span class="inline-flex items-center justify-center bg-white px-2 py-1 rounded-sm text-sm font-zen font-bold text-black-03 whitespace-nowrap shadow-sm border border-black/[0.06]">
              {t}
            </span>
          ))}
        </div>
      </article>
    ))
  }
</div>
