---
import type { InstructorCard } from '../data/instructors';

export type { InstructorCard } from '../data/instructors';

interface Props {
  instructors: InstructorCard[];
}

const { instructors } = Astro.props;

/** 旧 Tailwind 任意 `object-[x_y]` を object-position 用 CSS 値へ（データ文字列は据え置き） */
function objectPositionValue(twClass: string): string {
  const m = twClass.match(/^object-\[([^\]]+)\]$/);
  if (!m) return '50% 50%';
  return m[1].replace(/_/g, ' ');
}
---

<div class="p-instructor-cards">
  {
    instructors.map(
      ({ nameJa, nameEn, tags, qualifications, image, imageAlt, imgWidth, imgHeight, objectPosition }) => (
        <article class="p-instructor-cards__item">
          <div class="p-instructor-cards__media">
            <img
              src={image}
              alt={imageAlt}
              width={imgWidth}
              height={imgHeight}
              class="p-instructor-cards__img"
              style={`object-position: ${objectPositionValue(objectPosition)}`}
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-instructor-cards__names">
            <h3 class="p-instructor-cards__name-ja">{nameJa}</h3>
            <p class="p-instructor-cards__name-en">{nameEn}</p>
          </div>
          <div class="p-instructor-cards__tags">
            {tags.map((t) => (
              <span class="p-instructor-cards__tag">{t}</span>
            ))}
          </div>
          {qualifications && qualifications.length > 0 && (
            <ul class="p-instructor-cards__qualifications">
              {qualifications.map((q) => (
                <li class="p-instructor-cards__qualification">{q}</li>
              ))}
            </ul>
          )}
        </article>
      )
    )
  }
</div>

<style>
  .p-instructor-cards {
    display: flex;
    width: 100%;
    min-width: 0;
    flex-direction: column;
    align-items: stretch;
    gap: 2rem;
  }

  .p-instructor-cards__item {
    display: flex;
    width: 100%;
    min-width: 0;
    max-width: 480px;
    margin-inline: auto;
    flex-direction: column;
    flex-shrink: 0;
    gap: 14px;
  }

  .p-instructor-cards__media {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--color-surface-01);
  }

  .p-instructor-cards__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .p-instructor-cards__names {
    display: flex;
    flex-direction: column;
    gap: 7px;
    font-family: var(--font-family-base);
    font-weight: 700;
    color: var(--color-black-03);
  }

  .p-instructor-cards__name-ja {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1;
  }

  .p-instructor-cards__name-en {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1;
    color: var(--color-black-03);
  }

  .p-instructor-cards__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .p-instructor-cards__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.125rem;
    border: 1px solid rgb(0 0 0 / 0.06);
    background: #fff;
    padding: 0.25rem 0.5rem;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-black-03);
    white-space: nowrap;
    box-shadow: var(--shadow-soft);
  }

  .p-instructor-cards__qualifications {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .p-instructor-cards__qualification {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-black-03);
    line-height: 1.4;
  }

  .p-instructor-cards__qualification::before {
    content: '・';
    flex-shrink: 0;
  }

  @media (--bp-md-up) {
    .p-instructor-cards {
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: stretch;
      justify-content: center;
      gap: 39px;
    }

    .p-instructor-cards__item {
      width: 460px;
      max-width: none;
      margin-inline: 0;
      flex: none;
      flex-shrink: 0;
    }

    .p-instructor-cards__media {
      height: 300px;
    }
  }
</style>
