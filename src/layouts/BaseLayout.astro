---
import '../styles/foundation/layers.css';
import '../styles/foundation/tokens.css';
import '../styles/foundation/reset.css';
import '../styles/foundation/base.css';
import '../styles/layout/container.css';
import '../styles/layout/section.css';
import '../styles/components/button.css';
import '../styles/components/cta.css';
import '../styles/components/icon.css';
import '../styles/components/link.css';
import '../styles/components/breadcrumb.css';
import '../styles/components/section-mark.css';
import '../styles/utilities/visually-hidden.css';
import '../styles/utilities/motion.css';
import '../styles/utilities/visibility-bp.css';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  noindex?: boolean;
  /** 指定時は `noindex` より優先（例: thanks ページの `noindex, nofollow`） */
  robots?: string;
  publishedTime?: string;
  modifiedTime?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const {
  title,
  description = 'アテンドサロンRは、感情労働のフィールドでイキイキ働く組織づくりを支援します。',
  canonicalPath = Astro.url.pathname,
  ogType = 'website',
  ogImage,
  noindex = false,
  robots,
  publishedTime,
  modifiedTime,
  jsonLd,
} = Astro.props;
const site = Astro.site ?? new URL('https://attendsalon-r.com');
const canonicalUrl = canonicalPath ? new URL(canonicalPath, site).toString() : undefined;
const ogImageUrl = ogImage ? new URL(ogImage, site).toString() : undefined;
const jsonLdItems = (Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []);
const safeJsonLd = (item: Record<string, unknown>) =>
  JSON.stringify(item)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots ? <meta name="robots" content={robots} /> : noindex && <meta name="robots" content="noindex" />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:site_name" content="アテンドサロンR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <!-- Google Fonts: Zen / Noto / Lato + Rubik（ヒーロー装飾「R」は SVG text。Ruika 未読込時は Rubik 900 にフォールバック） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@900&family=Rubik:ital,wght@0,900;1,900&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={safeJsonLd(item)} />)}
  </head>
  <body>
    <script is:inline>
      try {
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('is-reveal-active');
        }
      } catch (_) {}
    </script>
    <slot />
    <script>
      import { initSoftReveal } from '../scripts/soft-reveal';
      const run = () => initSoftReveal();
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run, { once: true });
      else run();
    </script>
  </body>
</html>
