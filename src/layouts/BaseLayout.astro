---
import '../styles/soft-motion.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'アテンドサロンRは、感情労働のフィールドでイキイキ働く組織づくりを支援します。' } = Astro.props;
---
<!doctype html>
<html lang="ja" class="overflow-x-clip">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Fonts: Zen / Noto / Lato + Rubik（ヒーロー装飾「R」は SVG text。Ruika 未読込時は Rubik 900 にフォールバック） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@900&family=Rubik:ital,wght@0,900;1,900&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="overflow-x-clip font-zen antialiased text-black-03 bg-bg-warm">
    <script is:inline>
      try {
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('soft-reveal-active');
        }
      } catch (_) {}
    </script>
    <slot />
    <script>
      import { initSoftReveal } from '../scripts/soft-reveal';
      const run = () => initSoftReveal();
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run, { once: true });
      else run();
    </script>
  </body>
</html>
