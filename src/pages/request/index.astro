---
import DocumentPageLayout from '../../layouts/DocumentPageLayout.astro';

const title = '資料請求';
const description =
  '研修概要資料などのご請求は、下記フォームに必要事項をご入力のうえお送りください。';
---
<DocumentPageLayout
  title={title}
  description={description}
  canonicalPath="/request/"
  eyebrow="Request"
  breadcrumbItems={[
    { label: 'ホーム', href: '/' },
    { label: title },
  ]}
>
  <div class="p-request-subpage">
    <form id="document-request-form" class="p-contact-form" name="document_request" method="post" action="#">
      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="request-company">
          会社名 <span class="p-contact-form__req">必須</span>
        </label>
        <input
          class="p-contact-form__control"
          id="request-company"
          name="company"
          type="text"
          autocomplete="organization"
          required
          maxlength="200"
        />
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="request-name">
          担当者名 <span class="p-contact-form__req">必須</span>
        </label>
        <input
          class="p-contact-form__control"
          id="request-name"
          name="contact_name"
          type="text"
          autocomplete="name"
          required
          maxlength="100"
        />
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="request-email">
          メールアドレス <span class="p-contact-form__req">必須</span>
        </label>
        <input
          class="p-contact-form__control"
          id="request-email"
          name="contact_email"
          type="email"
          autocomplete="email"
          inputmode="email"
          required
          maxlength="254"
        />
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="request-tel">
          電話番号 <span class="p-contact-form__req">必須</span>
        </label>
        <input
          class="p-contact-form__control"
          id="request-tel"
          name="contact_tel"
          type="tel"
          autocomplete="tel"
          inputmode="tel"
          required
          maxlength="30"
        />
      </div>

      <div class="p-contact-form__actions">
        <button type="submit" class="c-button c-button--solid-pink p-contact-form__submit">資料請求を送信</button>
      </div>
    </form>
  </div>
</DocumentPageLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('#document-request-form');
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    window.location.assign('/request/thanks/');
  });
</script>

<style>
  .p-request-subpage {
    padding-bottom: 2rem;
  }

  .p-contact-form {
    box-sizing: border-box;
    max-width: 36rem;
    margin-inline: auto;
    padding: 1.5rem;
    border: 1px solid var(--color-border-soft);
    border-radius: 1rem;
    background: #fff;
    box-shadow: var(--shadow-soft);
  }

  @media (--bp-md-up) {
    .p-contact-form {
      padding: 2rem;
    }
  }

  .p-contact-form__field {
    margin-bottom: 1.25rem;
  }

  .p-contact-form__field:last-of-type {
    margin-bottom: 1.5rem;
  }

  .p-contact-form__label {
    display: block;
    margin-bottom: 0.375rem;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-black-03);
  }

  .p-contact-form__req {
    margin-inline-start: 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-pink-01);
  }

  .p-contact-form__control {
    box-sizing: border-box;
    width: 100%;
    min-width: 0;
    margin: 0;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    color: var(--color-black-03);
    background: #fff;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .p-contact-form__control:focus {
    outline: none;
    border-color: var(--color-blue-01);
    box-shadow: 0 0 0 2px rgb(127 154 168 / 0.25);
  }

  .p-contact-form__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 0.5rem;
  }

  .p-contact-form__submit {
    width: 100%;
    max-width: 22rem;
    text-align: center;
  }

  @media (--bp-md-up) {
    .p-contact-form__submit {
      width: auto;
      max-width: none;
      min-width: min(100%, 20rem);
    }
  }
</style>
