---
import DocumentPageLayout from '../../layouts/DocumentPageLayout.astro';
import ContactFormField from '../../components/form/ContactFormField.astro';
import ContactFormShell from '../../components/form/ContactFormShell.astro';

const title = '資料請求';
const description =
  '研修概要資料などのご請求は、下記フォームに必要事項をご入力のうえお送りください。';
---
<DocumentPageLayout
  title={title}
  description={description}
  canonicalPath="/request/"
  eyebrow="Request"
  breadcrumbItems={[
    { label: 'ホーム', href: '/' },
    { label: title },
  ]}
>
  <ContactFormShell
    formId="document-request-form"
    formName="document_request"
    submitLabel="資料請求を送信"
    thanksPath="/request/thanks/"
  >
    <ContactFormField id="request-company" label="事業所名" required>
      <input
        class="p-contact-form__control"
        id="request-company"
        name="company"
        type="text"
        autocomplete="organization"
        required
        maxlength="200"
      />
    </ContactFormField>

    <ContactFormField id="request-name" label="担当者名" required>
      <input
        class="p-contact-form__control"
        id="request-name"
        name="contact_name"
        type="text"
        autocomplete="name"
        required
        maxlength="100"
      />
    </ContactFormField>

    <ContactFormField id="request-email" label="メールアドレス" required>
      <input
        class="p-contact-form__control"
        id="request-email"
        name="contact_email"
        type="email"
        autocomplete="email"
        inputmode="email"
        required
        maxlength="254"
      />
    </ContactFormField>

    <ContactFormField id="request-tel" label="電話番号" required>
      <input
        class="p-contact-form__control"
        id="request-tel"
        name="contact_tel"
        type="tel"
        autocomplete="tel"
        inputmode="tel"
        required
        maxlength="30"
      />
    </ContactFormField>
  </ContactFormShell>
</DocumentPageLayout>
