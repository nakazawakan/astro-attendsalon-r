---
import DocumentPageLayout from '../../../layouts/DocumentPageLayout.astro';
import FormThanksMessage from '../../../components/form/FormThanksMessage.astro';

const title = '資料請求完了';
const description = '資料請求の送信が完了しました。';
---
<DocumentPageLayout
  title={title}
  description={description}
  canonicalPath="/request/thanks/"
  robots="noindex, nofollow"
  eyebrow="Request"
  breadcrumbItems={[
    { label: 'ホーム', href: '/' },
    { label: '資料請求', href: '/request/' },
    { label: title },
  ]}
>
  <FormThanksMessage
    lead="資料請求を受け付けました。ご入力のメールアドレス宛に、概要資料などをお送りします。"
    note="送信処理のバックエンド接続前の場合、自動返信やメール送信は行われないことがあります。"
    primaryHref="/"
    primaryLabel="トップへ戻る"
    secondaryHref="/request/"
    secondaryLabel="資料請求へ戻る"
  />
</DocumentPageLayout>
