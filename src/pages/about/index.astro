---
import SiteChrome from '../../layouts/SiteChrome.astro';
---
<SiteChrome title="運営者情報｜アテンドサロンR">
  <div class="p-about-subpage" data-reveal>
    <div class="l-page-shell">
      <div class="l-page-inner">
    <h1 class="p-about-subpage__title">運営者情報</h1>
    <div class="p-about-subpage__table-wrap">
      <table class="p-about-subpage__table">
        <tbody>
          <tr class="p-about-subpage__tr">
            <th class="p-about-subpage__th p-about-subpage__th--name">名称</th>
            <td class="p-about-subpage__td">アテンドサロンR（運営者名は準備中）</td>
          </tr>
          <tr class="p-about-subpage__tr">
            <th class="p-about-subpage__th">事業内容</th>
            <td class="p-about-subpage__td">感情労働の職場向け研修、メンタルヘルス・ハラスメント関連研修、組織コンサルティング</td>
          </tr>
          <tr class="p-about-subpage__tr">
            <th class="p-about-subpage__th">お問い合わせ</th>
            <td class="p-about-subpage__td">
              <a href="/contact/" class="c-link">お問い合わせフォーム</a>よりご連絡ください。
            </td>
          </tr>
          <tr>
            <th class="p-about-subpage__th">備考</th>
            <td class="p-about-subpage__td">本ページの記載事項は、正式な会社情報が確定次第更新いたします。</td>
          </tr>
        </tbody>
      </table>
    </div>
      </div>
    </div>
  </div>
</SiteChrome>
<style>
  .p-about-subpage {
    padding-top: 130px;
    padding-bottom: 80px;
  }

  .p-about-subpage__title {
    margin: 0 0 2rem;
    font-family: var(--font-family-base);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-black-03);
  }

  @media (min-width: 768px) {
    .p-about-subpage__title {
      font-size: 1.875rem;
    }
  }

  .p-about-subpage__table-wrap {
    overflow: hidden;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
    background: #fff;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    font-family: var(--font-family-base);
    font-size: 0.875rem;
  }

  @media (min-width: 768px) {
    .p-about-subpage__table-wrap {
      font-size: 1rem;
    }
  }

  .p-about-subpage__table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .p-about-subpage__tr {
    border-bottom: 1px solid var(--color-border-soft);
  }

  .p-about-subpage__tr:last-child {
    border-bottom: none;
  }

  .p-about-subpage__th,
  .p-about-subpage__td {
    padding: 1rem;
    vertical-align: top;
  }

  @media (min-width: 768px) {
    .p-about-subpage__th,
    .p-about-subpage__td {
      padding: 1rem 1.5rem;
    }
  }

  .p-about-subpage__th {
    width: 140px;
    background: var(--color-surface-01);
    color: var(--color-black-03);
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .p-about-subpage__th--name {
      width: 180px;
    }
  }

  .p-about-subpage__td {
    color: var(--color-black-03);
  }
</style>
