---
import SiteChrome from '../../layouts/SiteChrome.astro';
---
<SiteChrome title="運営者情報｜アテンドサロンR">
  <div
    class="mx-auto w-full min-w-0 max-w-pageShell px-6 pb-[80px] pt-[130px]"
    data-reveal
  >
    <div class="mx-auto w-full min-w-0 max-w-page">
    <h1 class="text-2xl md:text-3xl font-zen font-bold text-black-03 mb-8">運営者情報</h1>
    <div class="border border-border-soft rounded-lg overflow-hidden bg-white shadow-sm font-zen text-sm md:text-base">
      <table class="w-full text-left">
        <tbody>
          <tr class="border-b border-border-soft">
            <th class="py-4 px-4 md:px-6 bg-surface-01 text-black-05 font-medium w-[140px] md:w-[180px]">名称</th>
            <td class="py-4 px-4 md:px-6 text-black-03">アテンドサロンR（運営者名は準備中）</td>
          </tr>
          <tr class="border-b border-border-soft">
            <th class="py-4 px-4 md:px-6 bg-surface-01 text-black-05 font-medium">事業内容</th>
            <td class="py-4 px-4 md:px-6 text-black-03">感情労働の職場向け研修、メンタルヘルス・ハラスメント関連研修、組織コンサルティング</td>
          </tr>
          <tr class="border-b border-border-soft">
            <th class="py-4 px-4 md:px-6 bg-surface-01 text-black-05 font-medium">お問い合わせ</th>
            <td class="py-4 px-4 md:px-6 text-black-03">
              <a href="/contact/" class="text-link underline">お問い合わせフォーム</a>よりご連絡ください。
            </td>
          </tr>
          <tr>
            <th class="py-4 px-4 md:px-6 bg-surface-01 text-black-05 font-medium">備考</th>
            <td class="py-4 px-4 md:px-6 text-black-03">本ページの記載事項は、正式な会社情報が確定次第更新いたします。</td>
          </tr>
        </tbody>
      </table>
    </div>
    </div>
  </div>
</SiteChrome>
