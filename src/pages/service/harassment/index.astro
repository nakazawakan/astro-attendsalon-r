---
import ServicePageLayout from '../../../layouts/ServicePageLayout.astro';
import ServicePageContent from './_ServicePageContent.astro';

const title = 'ハラスメント研修';
const description =
  '東京エリアを中心に、職場のハラスメント防止・コンプライアンスに関する研修のご案内ページです。';
const heroLead = [
  '注意や指導がパワハラと言われないか不安、声かけに迷いがある――。',
  'ハラスメントは悪意よりも「認識のズレ」や「伝え方」で起こりやすい問題です。',
  '本研修では、法令の基礎だけでなくグレー事例の判断軸と、相談を受けたときの初期対応まで、現場で使える形で整理し、安心して育成できる職場づくりを支援します。',
];
const heroImage = {
  src: '/images/service-harassment-hero-transparent.png',
  alt: '天秤の上で握手する二人の水彩イラスト',
  width: 1024,
  height: 768,
};
---
<ServicePageLayout
  title={title}
  description={description}
  heroLead={heroLead}
  heroImage={heroImage}
  canonicalPath="/service/harassment/"
  Content={ServicePageContent}
/>
