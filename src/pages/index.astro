---
import SiteChrome from '../layouts/SiteChrome.astro';
import TopHeroSection from '../components/TopHeroSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ServiceSection from '../components/ServiceSection.astro';
import FeatureSection from '../components/FeatureSection.astro';
import VoiceSection from '../components/VoiceSection.astro';
import InstructorSection from '../components/InstructorSection.astro';
import AreaSection from '../components/AreaSection.astro';
import FlowSection from '../components/FlowSection.astro';
import FaqSection from '../components/FaqSection.astro';
import BottomCtaSection from '../components/BottomCtaSection.astro';
import { buildOrganizationJsonLd, buildWebSiteJsonLd } from '../lib/structured-data';

const site = Astro.site ?? new URL('https://attendsalon-r.com');
const organizationJsonLd = buildOrganizationJsonLd({ site });
const websiteJsonLd = buildWebSiteJsonLd({ site });
---
<SiteChrome
  title="アテンドサロンR | 感情労働の職場向け研修支援"
  canonicalPath="/"
  jsonLd={[organizationJsonLd, websiteJsonLd]}
>
  <TopHeroSection />
  <AboutSection />
  <ServiceSection />
  <FeatureSection />
  <VoiceSection />
  <InstructorSection />
  <AreaSection />
  <FlowSection />
  <FaqSection />
  <BottomCtaSection slot="pre-footer" />
</SiteChrome>
