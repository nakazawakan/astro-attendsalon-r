---
import DocumentPageLayout from '../../layouts/DocumentPageLayout.astro';

const title = 'お問い合わせ';
const description =
  '研修内容のご相談や資料のご請求など、お問い合わせは下記フォームよりご連絡ください。（送信処理は別途実装予定のため、現時点ではメール等の案内に沿ってご連絡ください）';

/** 首都圏を先頭に、その後は都道府県コード順（埼玉・千葉・東京・神奈川を除く） */
const prefectureFirst = ['東京都', '神奈川県', '千葉県', '埼玉県'] as const;
const prefectureRest = [
  '北海道',
  '青森県',
  '岩手県',
  '宮城県',
  '秋田県',
  '山形県',
  '福島県',
  '茨城県',
  '栃木県',
  '群馬県',
  '新潟県',
  '富山県',
  '石川県',
  '福井県',
  '山梨県',
  '長野県',
  '岐阜県',
  '静岡県',
  '愛知県',
  '三重県',
  '滋賀県',
  '京都府',
  '大阪府',
  '兵庫県',
  '奈良県',
  '和歌山県',
  '鳥取県',
  '島根県',
  '岡山県',
  '広島県',
  '山口県',
  '徳島県',
  '香川県',
  '愛媛県',
  '高知県',
  '福岡県',
  '佐賀県',
  '長崎県',
  '熊本県',
  '大分県',
  '宮崎県',
  '鹿児島県',
  '沖縄県',
] as const;
const prefectures = [...prefectureFirst, ...prefectureRest];
---
<DocumentPageLayout
  title={title}
  description={description}
  canonicalPath="/contact/"
  eyebrow="Contact"
>
  <div class="p-contact-subpage">

    <form id="contact-inquiry-form" class="p-contact-form" name="contact" method="post" action="#">
      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="contact-company">
          会社名 <span class="p-contact-form__req">必須</span>
        </label>
        <input
          class="p-contact-form__control"
          id="contact-company"
          name="company"
          type="text"
          autocomplete="organization"
          required
          maxlength="200"
        />
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="contact-company-url">会社URL</label>
        <input
          class="p-contact-form__control"
          id="contact-company-url"
          name="company_url"
          type="url"
          autocomplete="url"
          inputmode="url"
          placeholder="https://"
          maxlength="500"
        />
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="contact-prefecture">
          都道府県 <span class="p-contact-form__req">必須</span>
        </label>
        <select class="p-contact-form__control p-contact-form__control--select" id="contact-prefecture" name="prefecture" required>
          <option value="" disabled selected hidden>選択してください</option>
          {prefectures.map((name) => <option value={name}>{name}</option>)}
        </select>
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="contact-address">
          所在地 <span class="p-contact-form__req">必須</span>
        </label>
        <input
          class="p-contact-form__control"
          id="contact-address"
          name="address"
          type="text"
          autocomplete="street-address"
          required
          maxlength="300"
        />
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="contact-name">
          担当者名 <span class="p-contact-form__req">必須</span>
        </label>
        <input
          class="p-contact-form__control"
          id="contact-name"
          name="contact_name"
          type="text"
          autocomplete="name"
          required
          maxlength="100"
        />
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="contact-email">
          担当者メールアドレス <span class="p-contact-form__req">必須</span>
        </label>
        <input
          class="p-contact-form__control"
          id="contact-email"
          name="contact_email"
          type="email"
          autocomplete="email"
          inputmode="email"
          required
          maxlength="254"
        />
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="contact-tel">
          担当者電話番号 <span class="p-contact-form__req">必須</span>
        </label>
        <input
          class="p-contact-form__control"
          id="contact-tel"
          name="contact_tel"
          type="tel"
          autocomplete="tel"
          inputmode="tel"
          required
          maxlength="30"
        />
      </div>

      <div class="p-contact-form__field">
        <label class="p-contact-form__label" for="contact-message">
          お問い合わせ内容 <span class="p-contact-form__req">必須</span>
        </label>
        <textarea
          class="p-contact-form__control p-contact-form__control--textarea"
          id="contact-message"
          name="message"
          rows="8"
          required
          maxlength="8000"></textarea>
      </div>

      <div class="p-contact-form__actions">
        <button type="submit" class="c-button c-button--solid-pink p-contact-form__submit">研修の無料相談を送信</button>
      </div>
    </form>
  </div>
</DocumentPageLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('#contact-inquiry-form');
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    window.location.assign('/contact/thanks/');
  });
</script>

<style>
  .p-contact-subpage {
    padding-bottom: 2rem;
  }

  .p-contact-form {
    box-sizing: border-box;
    max-width: 36rem;
    margin-inline: auto;
    padding: 1.5rem;
    border: 1px solid var(--color-border-soft);
    border-radius: 1rem;
    background: #fff;
    box-shadow: var(--shadow-soft);
  }

  @media (--bp-md-up) {
    .p-contact-form {
      padding: 2rem;
    }
  }

  .p-contact-form__field {
    margin-bottom: 1.25rem;
  }

  .p-contact-form__field:last-of-type {
    margin-bottom: 1.5rem;
  }

  .p-contact-form__label {
    display: block;
    margin-bottom: 0.375rem;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-black-03);
  }

  .p-contact-form__req {
    margin-inline-start: 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-pink-01);
  }

  .p-contact-form__control {
    box-sizing: border-box;
    width: 100%;
    min-width: 0;
    margin: 0;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    color: var(--color-black-03);
    background: #fff;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .p-contact-form__control:focus {
    outline: none;
    border-color: var(--color-blue-01);
    box-shadow: 0 0 0 2px rgb(127 154 168 / 0.25);
  }

  .p-contact-form__control--select {
    padding-block: 0.5rem;
    cursor: pointer;
  }

  .p-contact-form__control--textarea {
    display: block;
    resize: vertical;
    min-height: 8rem;
    line-height: 1.6;
  }

  .p-contact-form__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 0.5rem;
  }

  .p-contact-form__submit {
    width: 100%;
    max-width: 22rem;
    text-align: center;
  }

  @media (--bp-md-up) {
    .p-contact-form__submit {
      width: auto;
      max-width: none;
      min-width: min(100%, 20rem);
    }
  }
</style>
