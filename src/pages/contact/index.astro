---
import DocumentPageLayout from '../../layouts/DocumentPageLayout.astro';
import ContactFormField from '../../components/form/ContactFormField.astro';
import ContactFormShell from '../../components/form/ContactFormShell.astro';

const title = '研修の無料相談';
const description =
  '研修内容のご相談や資料のご請求など、研修の無料相談は下記フォームよりご連絡ください。（送信処理は別途実装予定のため、現時点ではメール等の案内に沿ってご連絡ください）';

/** 首都圏を先頭に、その後は都道府県コード順（埼玉・千葉・東京・神奈川を除く） */
const prefectureFirst = ['東京都', '神奈川県', '千葉県', '埼玉県'] as const;
const prefectureRest = [
  '北海道',
  '青森県',
  '岩手県',
  '宮城県',
  '秋田県',
  '山形県',
  '福島県',
  '茨城県',
  '栃木県',
  '群馬県',
  '新潟県',
  '富山県',
  '石川県',
  '福井県',
  '山梨県',
  '長野県',
  '岐阜県',
  '静岡県',
  '愛知県',
  '三重県',
  '滋賀県',
  '京都府',
  '大阪府',
  '兵庫県',
  '奈良県',
  '和歌山県',
  '鳥取県',
  '島根県',
  '岡山県',
  '広島県',
  '山口県',
  '徳島県',
  '香川県',
  '愛媛県',
  '高知県',
  '福岡県',
  '佐賀県',
  '長崎県',
  '熊本県',
  '大分県',
  '宮崎県',
  '鹿児島県',
  '沖縄県',
] as const;
const prefectures = [...prefectureFirst, ...prefectureRest];
---
<DocumentPageLayout
  title={title}
  description={description}
  canonicalPath="/contact/"
  eyebrow="Contact"
>
  <ContactFormShell
    formId="contact-inquiry-form"
    formName="contact"
    submitLabel="研修の無料相談を送信"
    thanksPath="/contact/thanks/"
  >
    <ContactFormField id="contact-company" label="事業所名" required>
      <input
        class="p-contact-form__control"
        id="contact-company"
        name="company"
        type="text"
        autocomplete="organization"
        required
        maxlength="200"
      />
    </ContactFormField>

    <ContactFormField id="contact-company-url" label="事業所URL">
      <input
        class="p-contact-form__control"
        id="contact-company-url"
        name="company_url"
        type="url"
        autocomplete="url"
        inputmode="url"
        placeholder="https://"
        maxlength="500"
      />
    </ContactFormField>

    <ContactFormField id="contact-prefecture" label="都道府県" required>
      <select class="p-contact-form__control p-contact-form__control--select" id="contact-prefecture" name="prefecture" required>
        <option value="" disabled selected hidden>選択してください</option>
        {prefectures.map((name) => <option value={name}>{name}</option>)}
      </select>
    </ContactFormField>

    <ContactFormField id="contact-address" label="所在地" required>
      <input
        class="p-contact-form__control"
        id="contact-address"
        name="address"
        type="text"
        autocomplete="street-address"
        required
        maxlength="300"
      />
    </ContactFormField>

    <ContactFormField id="contact-name" label="担当者名" required>
      <input
        class="p-contact-form__control"
        id="contact-name"
        name="contact_name"
        type="text"
        autocomplete="name"
        required
        maxlength="100"
      />
    </ContactFormField>

    <ContactFormField id="contact-email" label="担当者メールアドレス" required>
      <input
        class="p-contact-form__control"
        id="contact-email"
        name="contact_email"
        type="email"
        autocomplete="email"
        inputmode="email"
        required
        maxlength="254"
      />
    </ContactFormField>

    <ContactFormField id="contact-tel" label="担当者電話番号" required>
      <input
        class="p-contact-form__control"
        id="contact-tel"
        name="contact_tel"
        type="tel"
        autocomplete="tel"
        inputmode="tel"
        required
        maxlength="30"
      />
    </ContactFormField>

    <ContactFormField id="contact-message" label="ご相談内容" required>
      <textarea
        class="p-contact-form__control p-contact-form__control--textarea"
        id="contact-message"
        name="message"
        rows="8"
        required
        maxlength="8000"></textarea>
    </ContactFormField>
  </ContactFormShell>
</DocumentPageLayout>
