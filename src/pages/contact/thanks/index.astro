---
import DocumentPageLayout from '../../../layouts/DocumentPageLayout.astro';
import FormThanksMessage from '../../../components/form/FormThanksMessage.astro';

const title = '送信完了';
const description = '研修の無料相談の送信が完了しました。';
---
<DocumentPageLayout
  title={title}
  description={description}
  canonicalPath="/contact/thanks/"
  robots="noindex, nofollow"
  eyebrow="Contact"
  breadcrumbItems={[
    { label: 'ホーム', href: '/' },
    { label: '研修の無料相談', href: '/contact/' },
    { label: title },
  ]}
>
  <FormThanksMessage
    lead="研修の無料相談を受け付けました。内容を確認のうえ、担当よりご連絡いたします。"
    note="送信処理のバックエンド接続前の場合、自動返信やメール通知は行われないことがあります。"
    primaryHref="/"
    primaryLabel="トップへ戻る"
    secondaryHref="/contact/"
    secondaryLabel="研修の無料相談フォームへ戻る"
  />
</DocumentPageLayout>
