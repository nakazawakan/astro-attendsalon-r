---
import DocumentPageLayout from '../../../layouts/DocumentPageLayout.astro';

const title = 'お問い合わせ完了';
const description = 'お問い合わせの送信が完了しました。';
---
<DocumentPageLayout
  title={title}
  description={description}
  canonicalPath="/contact/thanks/"
  eyebrow="Contact"
  breadcrumbItems={[
    { label: 'ホーム', href: '/' },
    { label: 'お問い合わせ', href: '/contact/' },
    { label: title },
  ]}
>
  <div class="p-thanks-page">
    <p class="p-thanks-page__lead">
      お問い合わせを受け付けました。内容を確認のうえ、担当よりご連絡いたします。
    </p>
    <p class="p-thanks-page__note">
      送信処理のバックエンド接続前の場合、自動返信やメール通知は行われないことがあります。
    </p>
    <p class="p-thanks-page__actions">
      <a href="/" class="c-button c-button--outline-pink">トップへ戻る</a>
      <a href="/contact/" class="c-button c-button--solid-pink">お問い合わせへ戻る</a>
    </p>
  </div>
</DocumentPageLayout>

<style>
  .p-thanks-page {
    max-width: 36rem;
    margin-inline: auto;
    padding-bottom: 1rem;
    font-family: var(--font-family-base);
    color: var(--color-black-03);
  }

  .p-thanks-page__lead {
    margin: 0 0 1rem;
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .p-thanks-page__note {
    margin: 0 0 2rem;
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-black-05);
  }

  .p-thanks-page__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  @media (--bp-md-up) {
    .p-thanks-page__actions {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
