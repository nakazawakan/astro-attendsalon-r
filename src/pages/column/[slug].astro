---
import type { CollectionEntry } from 'astro:content';
import ColumnArticleLayout from '../../layouts/ColumnArticleLayout.astro';
import { listPublishedColumnEntries } from '../../lib/content-entries';

export async function getStaticPaths() {
  const articles: CollectionEntry<'column'>[] = await listPublishedColumnEntries();

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: CollectionEntry<'column'>;
}

const { article } = Astro.props;
const { Content } = await article.render();
const canonicalPath = `/column/${article.slug}/`;
---
<ColumnArticleLayout article={article} canonicalPath={canonicalPath}>
  <Content />
</ColumnArticleLayout>
