---
import DocumentPageLayout from '../../layouts/DocumentPageLayout.astro';
import { faqs, FAQ_CATEGORY_ORDER } from '../../data/faqs';
import { buildFaqPageJsonLd } from '../../lib/structured-data';

const title = 'よくある質問';
const description =
  'アテンドサロンRの研修・お見積り・実施形式など、よくいただくご質問と回答をまとめました。';

const faqPageJsonLd = buildFaqPageJsonLd(faqs, { normalizeAnswerWhitespace: true });

const faqGroups = FAQ_CATEGORY_ORDER.map((category) => ({
  category,
  items: faqs.filter((f) => f.category === category),
})).filter((g) => g.items.length > 0);
---
<DocumentPageLayout
  title={title}
  description={description}
  canonicalPath="/faq/"
  eyebrow="FAQ"
  additionalJsonLd={[faqPageJsonLd]}
>
  <div class="p-faq-subpage">
    {
      faqGroups.map(({ category, items }, idx) => (
        <section
          class="p-faq-subpage__group"
          aria-labelledby={`faq-cat-${idx}`}
        >
          <h2
            id={`faq-cat-${idx}`}
            class="p-faq-subpage__category"
          >
            {category}
          </h2>
          <dl class="p-faq-subpage__list">
            {items.map(({ q, a, cta }) => (
              <div class="p-faq-subpage__item">
                <dt class="p-faq-subpage__q">{q}</dt>
                <dd class="p-faq-subpage__a">
                  {a}
                  {cta && (
                    <span class="p-faq-subpage__cta-line">
                      <a
                        href={cta.href}
                        class="p-faq-subpage__cta-link"
                      >
                        {cta.label}
                      </a>
                    </span>
                  )}
                </dd>
              </div>
            ))}
          </dl>
        </section>
      ))
    }
  </div>
</DocumentPageLayout>
<style>
  .p-faq-subpage__group + .p-faq-subpage__group {
    margin-top: 2rem;
  }

  .p-faq-subpage__category {
    margin: 0 0 1rem;
    border-left: 5px solid var(--color-pink-01);
    padding-left: 0.875rem;
    font-family: var(--font-family-base);
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.55;
    color: var(--color-black-03);
  }

  @media (--bp-md-up) {
    .p-faq-subpage__category {
      font-size: 1.25rem;
    }
  }

  .p-faq-subpage__list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 0;
    font-family: var(--font-family-base);
  }

  .p-faq-subpage__item {
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    background: #fff;
  }

  .p-faq-subpage__q {
    margin: 0 0 0.5rem;
    font-weight: 700;
    color: var(--color-black-03);
  }

  .p-faq-subpage__a {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.625;
    color: var(--color-black-03);
  }

  @media (--bp-md-up) {
    .p-faq-subpage__a {
      font-size: 1rem;
    }
  }

  .p-faq-subpage__cta-line {
    display: block;
    margin-top: 0.5rem;
  }

  .p-faq-subpage__cta-link {
    font-weight: 700;
    color: var(--color-pink-01);
    text-decoration: underline;
    text-decoration-color: rgb(251 107 106 / 0.4);
    text-underline-offset: 4px;
  }

  .p-faq-subpage__cta-link:hover {
    opacity: 0.85;
  }

  .p-faq-subpage__foot {
    margin: 2.5rem 0 0;
    text-align: center;
  }

  .p-faq-subpage__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    background: var(--color-pink-01);
    color: #fff;
    font-weight: 700;
    font-family: var(--font-family-base);
    font-size: 0.875rem;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .p-faq-subpage__pill:hover {
    opacity: 0.9;
  }
</style>
