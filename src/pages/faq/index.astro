---
import SiteChrome from '../../layouts/SiteChrome.astro';
import { faqs } from '../../data/faqs';
---
<SiteChrome title="よくある質問｜アテンドサロンR">
  <div
    class="mx-auto w-full min-w-0 max-w-pageShell px-6 pb-[80px] pt-[130px]"
    data-reveal
  >
    <div class="mx-auto w-full min-w-0 max-w-page">
    <h1 class="text-2xl md:text-3xl font-zen font-bold text-black-03 mb-10 text-center">よくある質問</h1>
    <dl class="space-y-6 font-zen">
      {faqs.map(({ q, a, cta }) => (
        <div class="border border-border-soft rounded-lg p-5 bg-white">
          <dt class="font-bold text-black-03 mb-2">{q}</dt>
          <dd class="text-sm md:text-base text-black-05 leading-relaxed">
            {a}
            {cta && (
              <span class="mt-2 block">
                <a
                  href={cta.href}
                  class="font-bold text-pink-01 underline decoration-pink-01/40 underline-offset-4 hover:opacity-85"
                >
                  {cta.label}
                </a>
              </span>
            )}
          </dd>
        </div>
      ))}
    </dl>
    <p class="mt-10 text-center">
      <a href="/contact/" class="inline-flex items-center rounded-full bg-pink-01 text-white font-zen font-bold px-6 py-3 text-sm hover:opacity-90">
        その他のご質問はお問い合わせへ
      </a>
    </p>
    </div>
  </div>
</SiteChrome>
