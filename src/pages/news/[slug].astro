---
import type { CollectionEntry } from 'astro:content';
import DocumentPageLayout from '../../layouts/DocumentPageLayout.astro';
import { listPublishedNewsEntries } from '../../lib/content-entries';
import { buildArticleJsonLd } from '../../lib/structured-data';

export async function getStaticPaths() {
  const items: CollectionEntry<'news'>[] = await listPublishedNewsEntries();

  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

interface Props {
  item: CollectionEntry<'news'>;
}

const { item } = Astro.props;
const { Content } = await item.render();
const canonicalPath = `/news/${item.slug}/`;
const site = Astro.site ?? new URL('https://attendsalon-r.com');
const pageUrl = new URL(canonicalPath, site).toString();
const publishedIso = item.data.publishedAt.toISOString();
const modifiedDate = item.data.updatedAt ?? item.data.publishedAt;
const modifiedIso = modifiedDate.toISOString();

const articleJsonLd = buildArticleJsonLd({
  title: item.data.title,
  description: item.data.description,
  pageUrl,
  site,
  publishedIso,
  modifiedIso,
});

// 本文: bodyProse でラッパーに p-document-page-section__body--prose を付与（DocumentPageLayout）
---

<DocumentPageLayout
  title={item.data.title}
  description={item.data.description}
  canonicalPath={canonicalPath}
  eyebrow="News"
  breadcrumbItems={[
    { label: 'ホーム', href: '/' },
    { label: 'お知らせ', href: '/news/' },
    { label: item.data.title },
  ]}
  bodyProse={true}
  additionalJsonLd={[articleJsonLd]}
>
  <Content />
</DocumentPageLayout>
