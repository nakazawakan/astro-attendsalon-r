---
import SiteChrome from '../../layouts/SiteChrome.astro';
import InstructorSection from '../../components/InstructorSection.astro';
---
<SiteChrome title="講師紹介｜アテンドサロンR">
  <div class="max-w-[960px] mx-auto px-4 md:px-6 pt-12 md:pt-16 pb-4">
    <p class="text-center text-black-05 font-zen text-sm mb-2">アテンドサロンR</p>
    <h1 class="text-2xl md:text-3xl font-zen font-bold text-black-03 text-center mb-2">講師紹介</h1>
    <p class="text-center text-sm text-black-05 font-noto max-w-xl mx-auto">
      現場経験と専門資格を兼ね備えた講師が、貴社の研修を担当します。
    </p>
  </div>
  <InstructorSection embedded />
</SiteChrome>
