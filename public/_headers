# 古い index.html がキャッシュされ、ハッシュ違いの /_astro/*.css を読みに行くと「色が抜けた」ように見えることがある
/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# 差し替えが続く写真は短キャッシュ（同一 URL の古いバイトが残らないように）
/images/voice-01.png
  Cache-Control: public, max-age=0, must-revalidate
/images/voice-02.png
  Cache-Control: public, max-age=0, must-revalidate

/images/*
  Cache-Control: public, max-age=86400
